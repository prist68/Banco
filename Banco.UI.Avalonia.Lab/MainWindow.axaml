<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Banco.UI.Avalonia.Lab"
        xmlns:vm="using:Banco.UI.Avalonia.Lab.ViewModels"
        x:Class="Banco.UI.Avalonia.Lab.MainWindow"
        Title="Banco Avalonia Lab"
        Width="1500"
        Height="930"
        MinWidth="1180"
        MinHeight="720"
        Background="{DynamicResource PageBackground}"
        FontFamily="Inter">
    <Window.Resources>
        <local:IconPathConverter x:Key="IconPathConverter" />
    </Window.Resources>

    <Design.DataContext>
        <vm:DesktopPrototypeViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="76,*">
        <Border Grid.RowSpan="2"
                Background="{DynamicResource PageBackground}" />

        <Border Grid.Row="0"
                Background="{DynamicResource TopBarBackground}"
                BorderBrush="{DynamicResource Stroke}"
                BorderThickness="0,0,0,1">
            <Grid Margin="22,12"
                  ColumnDefinitions="Auto,*,Auto">
                <StackPanel Orientation="Horizontal"
                            Spacing="12">
                    <Border Width="50"
                            Height="50"
                            CornerRadius="16"
                            Background="{DynamicResource BrandTile}">
                        <Grid>
                            <Path Width="30"
                                  Height="30"
                                  Stretch="Uniform"
                                  Fill="#FFFFFF"
                                  Data="M3,20V4H13C16.2,4 18.5,6.1 18.5,9C18.5,10.4 17.9,11.6 16.9,12.5C18.8,13.2 20,14.7 20,16.7C20,20 17.4,22 13.8,22H3M7,8V11H12.6C13.7,11 14.4,10.4 14.4,9.5C14.4,8.6 13.7,8 12.6,8M7,15V18H13.5C14.8,18 15.6,17.4 15.6,16.5C15.6,15.6 14.8,15 13.5,15Z" />
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Banco Avalonia Lab"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedText}" />
                        <TextBlock Text="Scrivania operativa"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MainText}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <Button Classes="labChromeButton"
                            Width="118"
                            Click="ThemeToggle_OnClick"
                            Padding="10,0">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="7">
                            <TextBlock x:Name="ThemeGlyph"
                                       Text="Dark"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource MainText}" />
                        </StackPanel>
                    </Button>
                    <Border Height="34"
                            Padding="12,0"
                            Background="{DynamicResource SoftSurface}"
                            BorderBrush="{DynamicResource Stroke}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock Text="Banco.Vendita.C"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource MainText}" />
                    </Border>
                    <Border Height="34"
                            Padding="14,0"
                            Background="{DynamicResource ElevatedSurface}"
                            BorderBrush="{DynamicResource Stroke}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock Text="1.0.0.0"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MainText}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="88,*">
            <Border Grid.Column="0"
                    Background="{DynamicResource RailBackground}">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Margin="0,14,0,12"
                               Text="MENU"
                               HorizontalAlignment="Center"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{DynamicResource RailMuted}" />
                    <ItemsControl Grid.Row="1"
                                  Margin="8,0"
                                  ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:NavigationItem">
                                <Button Classes="labRailButton"
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Center">
                                    <Grid RowDefinitions="34,Auto"
                                          Width="72">
                                        <Border Width="34"
                                                Height="34"
                                                HorizontalAlignment="Center"
                                                CornerRadius="11"
                                                Background="{Binding AccentColor}">
                                            <Path Width="18"
                                                  Height="18"
                                                  Stretch="Uniform"
                                                  Fill="#FFFFFF"
                                                  Data="{Binding IconData, Converter={StaticResource IconPathConverter}}" />
                                        </Border>
                                        <TextBlock Grid.Row="1"
                                                   Margin="0,5,0,0"
                                                   Width="72"
                                                   Text="{Binding Title}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource RailText}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
            <Grid x:Name="DesktopWorkspace"
                  Margin="16"
                  RowDefinitions="Auto,14,*">
                <Border Background="{DynamicResource HeroSurface}"
                        BorderBrush="{DynamicResource Stroke}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="18">
                    <Grid ColumnDefinitions="*,440,Auto,Auto">
                        <StackPanel>
                            <TextBlock Text="Desktop sperimentale"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MainText}" />
                            <TextBlock Text="Tema dinamico, icone vettoriali, superfici custom e densita da gestionale moderno."
                                       Margin="0,4,0,0"
                                       FontSize="13"
                                       Foreground="{DynamicResource MutedText}" />
                        </StackPanel>

                        <Grid Grid.Column="1"
                              Margin="16,0"
                              VerticalAlignment="Center">
                            <TextBox Classes="labCommandSearch"
                                     Watermark="Cerca comando..."
                                     Text="" />
                            <Path Width="14"
                                  Height="14"
                                  Margin="11,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Fill="{DynamicResource MutedText}"
                                  Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L20.5,19L19,20.5L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3Z" />
                        </Grid>

                        <Border Grid.Column="2"
                                Height="30"
                                Padding="12,0"
                                Background="{DynamicResource AccentSoft}"
                                CornerRadius="10">
                            <TextBlock Text="Prototype"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentText}" />
                        </Border>

                        <StackPanel Grid.Column="3"
                                    Margin="8,0,0,0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <Button Classes="labPrimaryButton"
                                    Content="+ Widget">
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Meteo"
                                                  Tag="weather"
                                                  Click="AddWidget_OnClick" />
                                        <MenuItem Header="Calendario"
                                                  Tag="calendar"
                                                  Click="AddWidget_OnClick" />
                                        <MenuItem Header="Note sticky"
                                                  Tag="notes"
                                                  Click="AddWidget_OnClick" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Button Classes="labChromeButton"
                                    Width="78"
                                    Content="Pulisci"
                                    Click="ResetWidgets_OnClick" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2"
                      ColumnDefinitions="1.45*,14,0.95*"
                      RowDefinitions="Auto,14,*">
                    <Border Classes="labPanel">
                        <StackPanel>
                            <TextBlock Text="Azioni operative"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MainText}" />
                            <ItemsControl Margin="0,10,0,0"
                                          ItemsSource="{Binding QuickActions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:QuickActionItem">
                                        <Button Height="68"
                                                Margin="0,0,10,10"
                                                Padding="10"
                                                Background="{DynamicResource ElevatedSurface}"
                                                BorderBrush="{DynamicResource Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                HorizontalContentAlignment="Stretch">
                                            <Grid ColumnDefinitions="38,*">
                                                <Border Width="32"
                                                        Height="32"
                                                        CornerRadius="10"
                                                        Background="{Binding AccentColor}">
                                                    <Path Width="17"
                                                          Height="17"
                                                          Stretch="Uniform"
                                                          Fill="#FFFFFF"
                                                          Data="{Binding IconData, Converter={StaticResource IconPathConverter}}" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="12.5"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource MainText}" />
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               Margin="0,3,0,0"
                                                               FontSize="11.5"
                                                               Foreground="{DynamicResource MutedText}" />
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Classes="labPanel">
                        <StackPanel>
                            <TextBlock Text="Control room"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MainText}" />
                            <ItemsControl Margin="0,10,0,0"
                                          ItemsSource="{Binding StatusTiles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:StatusTileItem">
                                        <Border Margin="0,0,10,10"
                                                MinHeight="132"
                                                Padding="12"
                                                Background="{DynamicResource ElevatedSurface}"
                                                BorderBrush="{DynamicResource Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <Grid RowDefinitions="Auto,*,Auto">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource MutedText}" />
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Value}"
                                                           Margin="0,12,0,0"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource MainText}" />
                                                <Grid Grid.Row="2"
                                                      ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="{Binding Footer}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedText}" />
                                                    <Border Grid.Column="1"
                                                            Padding="8,2"
                                                            BorderBrush="{Binding AccentColor}"
                                                            BorderThickness="1"
                                                            CornerRadius="9">
                                                        <TextBlock Text="{Binding Badge}"
                                                                   FontSize="10.5"
                                                                   Foreground="{Binding AccentColor}" />
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="2"
                          Grid.RowSpan="3"
                          RowDefinitions="Auto,14,1.05*,14,0.95*">
                        <Border Padding="12,9"
                                Background="{DynamicResource GlassSurface}"
                                BorderBrush="{DynamicResource Stroke}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBlock Text="Dock rapido"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource MainText}"
                                           VerticalAlignment="Center" />
                                <Border Padding="10,4"
                                        Background="{DynamicResource ElevatedSurface}"
                                        CornerRadius="10">
                                    <TextBlock Text="Gestione articolo"
                                               FontSize="11.5"
                                               Foreground="{DynamicResource MainText}" />
                                </Border>
                                <Button Classes="labChromeButton"
                                        Content="Vendita Banco"
                                        Click="OpenAvaloniaBanco_OnClick" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Classes="labPanel">
                            <StackPanel>
                                <TextBlock Text="Segnalazioni"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource MainText}" />
                                <ItemsControl Margin="0,10,0,0"
                                              ItemsSource="{Binding Alerts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AlertItem">
                                            <Border Margin="0,0,0,9"
                                                    Padding="11"
                                                    Background="{DynamicResource ElevatedSurface}"
                                                    BorderBrush="{DynamicResource Stroke}"
                                                    BorderThickness="1"
                                                    CornerRadius="13">
                                                <Grid ColumnDefinitions="5,*,Auto">
                                                    <Border Background="{Binding AccentColor}"
                                                            CornerRadius="4" />
                                                    <StackPanel Grid.Column="1"
                                                                Margin="10,0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="12.5"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource MainText}" />
                                                        <TextBlock Text="{Binding Subtitle}"
                                                                   FontSize="11.5"
                                                                   Foreground="{DynamicResource MutedText}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Badge}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding AccentColor}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl Margin="0,4,0,0"
                                              ItemsSource="{Binding Widgets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:DashboardWidget">
                                            <Border Margin="0,0,0,9"
                                                    Padding="10"
                                                    Background="{DynamicResource ElevatedSurface}"
                                                    BorderBrush="{DynamicResource Stroke}"
                                                    BorderThickness="1"
                                                    CornerRadius="13">
                                                <Grid ColumnDefinitions="5,*,Auto">
                                                    <Border Background="{Binding AccentColor}"
                                                            CornerRadius="4" />
                                                    <StackPanel Grid.Column="1"
                                                                Margin="10,0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="12.5"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource MainText}" />
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="11.5"
                                                                   Foreground="{DynamicResource MutedText}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <Button Grid.Column="2"
                                                            Classes="labWidgetToolButton"
                                                            Content="×"
                                                            Click="CloseWidget_OnClick" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4"
                                Classes="labPanel">
                            <StackPanel>
                                <TextBlock Text="Attivita recenti"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource MainText}" />
                                <ItemsControl Margin="0,10,0,0"
                                              ItemsSource="{Binding RecentItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RecentItem">
                                            <Border Margin="0,0,0,7"
                                                    Padding="10,8"
                                                    Background="{DynamicResource ElevatedSurface}"
                                                    BorderBrush="{DynamicResource Stroke}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <Grid ColumnDefinitions="50,*,Auto">
                                                    <TextBlock Text="{Binding Time}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedText}"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="12"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource MainText}" />
                                                        <TextBlock Text="{Binding Subtitle}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource MutedText}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Badge}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource MutedText}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>

                    </Grid>
                </Grid>
            </Grid>
            <Border x:Name="InternalWorkspace"
                    Margin="16"
                    Background="{DynamicResource PageBackground}"
                    BorderBrush="{DynamicResource Stroke}"
                    BorderThickness="1"
                    CornerRadius="18"
                    IsVisible="False"
                    ClipToBounds="True">
                <ContentControl x:Name="InternalWorkspaceHost" />
            </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
