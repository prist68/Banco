<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="TextBox.bancoSaleInput">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="9,4" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{DynamicResource InputSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource StrokeStrong}" />
        <Setter Property="Foreground" Value="{DynamicResource MainText}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="ComboBox.bancoSaleInput">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="9,3" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{DynamicResource InputSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource StrokeStrong}" />
        <Setter Property="Foreground" Value="{DynamicResource MainText}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="Button.bancoSaleButton">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{DynamicResource SoftSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
        <Setter Property="Foreground" Value="{DynamicResource MainText}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.bancoSaleButton.primary">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.bancoSaleButton.warning">
        <Setter Property="Background" Value="{DynamicResource Warning}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Warning}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.bancoSaleButton.danger">
        <Setter Property="Background" Value="{DynamicResource Danger}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Danger}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.gridActionButton">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Danger}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="Button.gridActionButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Danger}" />
    </Style>

    <Style Selector="TextBox.gridLookupTextBox">
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MainText}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>

    <Style Selector="TextBox.gridLookupTextBox:pointerover">
        <Setter Property="Background" Value="{DynamicResource InputSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>

    <Style Selector="TextBox.gridLookupTextBox:focus">
        <Setter Property="Background" Value="{DynamicResource InputSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>

    <Style Selector="Button.paymentTender">
        <Setter Property="Height" Value="58" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{DynamicResource ElevatedSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
        <Setter Property="Foreground" Value="{DynamicResource MainText}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.paymentTender:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>

    <Style Selector="Border.paymentRow">
        <Setter Property="Background" Value="{DynamicResource ElevatedSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="6" />
    </Style>

    <Style Selector="Border.paymentRow:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>

    <Style Selector="TextBox.paymentAmount">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MainText}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
    </Style>

    <Style Selector="TextBox.paymentAmount:pointerover">
        <Setter Property="Background" Value="{DynamicResource InputSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>

    <Style Selector="TextBox.paymentAmount:focus">
        <Setter Property="Background" Value="{DynamicResource InputSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>

    <Style Selector="Border.salePanel">
        <Setter Property="Background" Value="{DynamicResource PanelSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style Selector="Border.saleField">
        <Setter Property="Background" Value="{DynamicResource ElevatedSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10,7" />
    </Style>

    <Style Selector="DataGrid.saleGrid">
        <Setter Property="Background" Value="{DynamicResource ElevatedSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource MainText}" />
        <Setter Property="RowHeight" Value="32" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="CanUserResizeColumns" Value="True" />
        <Setter Property="CanUserReorderColumns" Value="True" />
        <Setter Property="CanUserSortColumns" Value="True" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="DataGrid.saleGrid TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="DataGrid.saleGrid.headerAccent DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="DataGrid.saleGrid.headerInfo DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource Info}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="DataGrid.saleGrid.headerSuccess DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource Success}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="DataGrid.saleGrid.headerWarning DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource Warning}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="DataGrid.saleGrid.headerDanger DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource Danger}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
</Styles>
