<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Banco.UI.Avalonia.Banco.Views.BancoSaleView"
        FontFamily="Inter"
        KeyDown="BancoSaleView_OnKeyDown">
    <Grid RowDefinitions="56,*,30">
        <Border Grid.Row="0"
                Background="{DynamicResource TopBarBackground}"
                BorderBrush="{DynamicResource Stroke}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,8"
                  ColumnDefinitions="Auto,*,Auto">
                <StackPanel Orientation="Horizontal"
                            Spacing="10">
                    <Border Width="38"
                            Height="38"
                            CornerRadius="12"
                            Background="{DynamicResource Accent}">
                        <TextBlock Text="B"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Vendita al banco"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MainText}" />
                        <TextBlock Text="Layout Avalonia vicino alla versione Windows"
                                   FontSize="11.5"
                                   Foreground="{DynamicResource MutedText}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <Border Classes="saleField"
                            Padding="10,5">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock Text="{Binding LegacyBadgeText}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource Accent}" />
                            <TextBlock Text="{Binding LegacyStatusDetail}"
                                       FontSize="12"
                                       Foreground="{DynamicResource MutedText}" />
                        </StackPanel>
                    </Border>
                    <Button Classes="bancoSaleButton"
                            Width="80"
                            Content="Dark"
                            Click="ThemeToggle_OnClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="14"
              RowDefinitions="Auto,10,*"
              ColumnDefinitions="*,14,330">
            <Border Grid.ColumnSpan="3"
                    Classes="salePanel">
                <Grid ColumnDefinitions="2*,12,1.45*,8,Auto">
                    <TextBox Classes="bancoSaleInput"
                             Watermark="Codice / barcode / ricerca articolo"
                             Text="{Binding ArticleSearchText, Mode=TwoWay}"
                             TextInput="ArticleSearchTextBox_OnTextInput"
                             TextChanged="ArticleSearchTextBox_OnTextChanged"
                             LostFocus="ArticleSearchTextBox_OnLostFocus"
                             KeyDown="ArticleSearchTextBox_OnKeyDown" />
                    <ComboBox Grid.Column="2"
                              Classes="bancoSaleInput"
                              IsEditable="True"
                              Text="{Binding CustomerSearchText, Mode=TwoWay}"
                              ItemsSource="{Binding CustomerResults}"
                              SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                              PlaceholderText="Cliente / carta fedelta">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto"
                                      MinWidth="320">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DisplayLabel}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MutedText}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PuntiLabel}"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource Accent}" />
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel Grid.Column="4"
                                Orientation="Horizontal"
                                Spacing="8">
                        <ComboBox Classes="bancoSaleInput"
                                  Width="126"
                                  ItemsSource="{Binding Operators}"
                                  SelectedItem="{Binding SelectedOperator, Mode=TwoWay}" />
                        <ComboBox Classes="bancoSaleInput"
                                  Width="142"
                                  ItemsSource="{Binding PriceLists}"
                                  SelectedItem="{Binding SelectedPriceList, Mode=TwoWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Border Classes="salePanel"
                        Padding="0">
                    <DataGrid x:Name="SaleRowsGrid"
                              Classes="saleGrid"
                              KeyDown="SaleRowsDataGrid_OnKeyDown"
                              LoadingRow="SaleRowsDataGrid_OnLoadingRow"
                              AutoGenerateColumns="False"
                              ItemsSource="{Binding Rows}"
                              SelectedItem="{Binding SelectedRow, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="R" Width="34" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Classes="saleField"
                                                Padding="0"
                                                Width="22"
                                                Height="22"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding IsInReorderList}">
                                            <TextBlock Text="R"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource Warning}"
                                                       ToolTip.Tip="In lista riordino" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Codice" Width="128">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Classes="gridLookupTextBox"
                                                 Text="{Binding Codice, Mode=TwoWay}"
                                                 Watermark="Codice"
                                                 GotFocus="GridRowEditor_OnGotFocus"
                                                 TextChanged="GridArticleCodeTextBox_OnTextChanged"
                                                 KeyDown="GridArticleCodeTextBox_OnKeyDown" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Descrizione" Binding="{Binding Descrizione, Mode=TwoWay}" Width="*" />
                            <DataGridTextColumn Header="Um" Binding="{Binding UnitaMisura, Mode=TwoWay}" Width="54" />
                            <DataGridTextColumn Header="Q.ta" Binding="{Binding Quantita, Mode=TwoWay, StringFormat={}{0:N2}}" Width="76" />
                            <DataGridTextColumn Header="Prezzo" Binding="{Binding Prezzo, Mode=TwoWay, StringFormat={}{0:N2}}" Width="88" />
                            <DataGridTextColumn Header="Sc. %" Binding="{Binding Sconto, Mode=TwoWay, StringFormat={}{0:N2}}" Width="70" />
                            <DataGridTextColumn Header="Importo" Binding="{Binding Importo, StringFormat={}{0:N2}}" Width="92" IsReadOnly="True" />
                            <DataGridTextColumn Header="Disp." Binding="{Binding Disponibilita, Mode=TwoWay, StringFormat={}{0:N2}}" Width="76" />
                            <DataGridTextColumn Header="Iva" Binding="{Binding AliquotaIva, Mode=TwoWay, StringFormat={}{0:N2}}" Width="62" />
                            <DataGridTextColumn Header="Stato" Binding="{Binding Stato, Mode=TwoWay}" Width="88" />
                            <DataGridTemplateColumn Header="" Width="42" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Classes="gridActionButton"
                                                Content="x"
                                                ToolTip.Tip="Elimina riga"
                                                Click="DeleteRowButton_OnClick" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <Grid Grid.Column="2"
                  Grid.Row="2"
                  RowDefinitions="Auto,10,Auto,10,*,10,Auto">
                <Border Classes="salePanel">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10">
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="17"
                                    Background="{DynamicResource AccentSoft}">
                                <TextBlock Text="D"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}" />
                            </Border>
                            <TextBlock Text="Documento operativo"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MainText}" />
                        </StackPanel>
                        <Border Classes="saleField">
                            <Grid RowDefinitions="Auto,4,Auto"
                                  ColumnDefinitions="*,Auto">
                                <TextBlock Text="Cliente"
                                           FontSize="14"
                                           Foreground="{DynamicResource MutedText}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CustomerPointsDisplay}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}" />
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding CustomerDisplay}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource MainText}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Imponibile"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       Foreground="{DynamicResource MutedText}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SubtotalDisplay}"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MainText}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Sconto documento"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       Foreground="{DynamicResource MutedText}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DocumentDiscountDisplay}"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MainText}" />
                        </Grid>
                        <Border Background="{DynamicResource AccentSoft}"
                                CornerRadius="10"
                                Padding="14,12">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Totale"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource MainText}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalDisplay}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Classes="salePanel">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Pagamenti"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MainText}" />
                            <TextBlock Grid.Column="1"
                                       Text="POS"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource Accent}" />
                        </Grid>

                        <Button Classes="paymentTender"
                                Tag="contanti"
                                Click="PaymentTypeButton_OnClick">
                            <Grid ColumnDefinitions="42,*,118">
                                <Border Width="30"
                                        Height="30"
                                        CornerRadius="8"
                                        Background="{DynamicResource AccentSoft}">
                                    <TextBlock Text="€"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource Accent}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="Contanti"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           Foreground="{DynamicResource MutedText}" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding CashAmountDisplay}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MainText}" />
                            </Grid>
                        </Button>
                        <Button Classes="paymentTender"
                                Tag="carta"
                                Click="PaymentTypeButton_OnClick">
                            <Grid ColumnDefinitions="42,*,118">
                                <Border Width="30"
                                        Height="30"
                                        CornerRadius="8"
                                        Background="{DynamicResource SoftSurface}">
                                    <TextBlock Text="C"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource Info}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="Carta"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           Foreground="{DynamicResource MutedText}" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding CardAmountDisplay}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MainText}" />
                            </Grid>
                        </Button>
                        <Button Classes="paymentTender"
                                Tag="sospeso"
                                Click="PaymentTypeButton_OnClick">
                            <Grid ColumnDefinitions="42,*,118">
                                <Border Width="30"
                                        Height="30"
                                        CornerRadius="8"
                                        Background="{DynamicResource SoftSurface}">
                                    <TextBlock Text="S"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource Warning}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="Sospeso"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           Foreground="{DynamicResource MutedText}" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SuspendedAmountDisplay}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MainText}" />
                            </Grid>
                        </Button>

                        <Border Classes="saleField"
                                Margin="0,8,0,0">
                            <Grid RowDefinitions="Auto,12,Auto"
                                  ColumnDefinitions="*,Auto">
                                <TextBlock Text="Pagato"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource MainText}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PaidTotalDisplay}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource MainText}" />
                                <Border Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Height="1"
                                        Background="{DynamicResource Stroke}" />
                                <TextBlock Grid.Row="2"
                                           Text="Residuo"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}" />
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Text="{Binding ResidualDisplay}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Classes="salePanel">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Stato operativo"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MainText}" />
                        <TextBlock Text="{Binding LegacyStatusTitle}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MainText}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource MutedText}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="6"
                        Classes="salePanel">
                    <Grid RowDefinitions="Auto,8,Auto,8,Auto,8,Auto">
                        <Button Classes="bancoSaleButton primary"
                                Content="Salva"
                                Command="{Binding SaveDocumentCommand}" />
                        <Button Grid.Row="2"
                                Classes="bancoSaleButton"
                                Content="Cortesia"
                                Command="{Binding CourtesyCommand}" />
                        <Grid Grid.Row="4"
                              ColumnDefinitions="*,8,*">
                            <Button Classes="bancoSaleButton"
                                    Content="POS80"
                                    Command="{Binding PrintPos80Command}" />
                            <Button Grid.Column="2"
                                    Classes="bancoSaleButton warning"
                                    Content="Scontrino"
                                    Command="{Binding ReceiptCommand}" />
                        </Grid>
                        <Grid Grid.Row="6"
                              ColumnDefinitions="*,8,*">
                            <Button Classes="bancoSaleButton warning"
                                    Content="Anteprima"
                                    Command="{Binding PreviewPos80Command}" />
                            <Button Grid.Column="2"
                                    Classes="bancoSaleButton danger"
                                    Content="Azzera"
                                    Command="{Binding ClearDocumentCommand}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource TopBarBackground}"
                BorderBrush="{DynamicResource Stroke}"
                BorderThickness="0,1,0,0">
            <Grid Margin="14,0"
                  ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           FontSize="11.5"
                           Foreground="{DynamicResource MutedText}" />
                <TextBlock Grid.Column="1"
                           Text="F4 Salva   F6 POS80   F7 Anteprima   F8 Cortesia   F9 Scontrino"
                           VerticalAlignment="Center"
                           FontSize="11.5"
                           Foreground="{DynamicResource MutedText}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
