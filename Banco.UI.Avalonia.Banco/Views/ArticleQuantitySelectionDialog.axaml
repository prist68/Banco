<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Banco.UI.Avalonia.Banco.Views.ArticleQuantitySelectionDialog"
        Title="Quantita articolo"
        Width="720"
        Height="520"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource PageBackground}"
        FontFamily="Inter">
    <Border Margin="12"
            Padding="16"
            Background="{DynamicResource PanelSurface}"
            BorderBrush="{DynamicResource Stroke}"
            BorderThickness="1"
            CornerRadius="16">
        <Grid RowDefinitions="Auto,14,*,14,Auto">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="BANCO / QUANTITA"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{DynamicResource MutedText}" />
                    <TextBlock Text="{Binding DialogTitle}"
                               Margin="0,4,0,0"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource MainText}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding RulesText}"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedText}"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        Classes="bancoSaleButton"
                        Content="Chiudi"
                        Click="CancelButton_OnClick" />
            </Grid>

            <Grid Grid.Row="2"
                  ColumnDefinitions="240,12,*">
                <Border Classes="salePanel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Quantita"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedText}" />
                        <TextBox x:Name="QuantityTextBox"
                                 Classes="bancoSaleInput"
                                 MinHeight="52"
                                 FontSize="24"
                                 FontWeight="Bold"
                                 HorizontalContentAlignment="Center"
                                 TextAlignment="Center"
                                 KeyDown="QuantityTextBox_OnKeyDown"
                                 TextChanged="QuantityTextBox_OnTextChanged" />
                        <Border Classes="saleField">
                            <TextBlock x:Name="AppliedPriceTextBlock"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource MainText}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Classes="salePanel">
                    <Grid RowDefinitions="Auto,8,*">
                        <TextBlock Text="Fasce prezzo disponibili"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedText}" />
                        <ListBox x:Name="QuantityTiersListBox"
                                 Grid.Row="2"
                                 SelectionChanged="QuantityTiersListBox_OnSelectionChanged"
                                 DoubleTapped="QuantityTiersListBox_OnDoubleTapped"
                                 KeyDown="QuantityTiersListBox_OnKeyDown"
                                 Background="{DynamicResource ElevatedSurface}"
                                 BorderBrush="{DynamicResource Stroke}"
                                 BorderThickness="1"
                                 CornerRadius="10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="10,7"
                                          ColumnDefinitions="*,Auto,Auto">
                                        <TextBlock Text="{Binding QuantitaLabel}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MainText}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PrezzoLabel}"
                                                   Margin="14,0,0,0"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource Success}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TotaleLabel}"
                                                   Margin="10,0,0,0"
                                                   Foreground="{DynamicResource MutedText}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="4"
                  ColumnDefinitions="*,Auto,8,Auto">
                <TextBlock Text="Con Invio confermi. I tasti 1-9 selezionano rapidamente una fascia."
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedText}" />
                <Button Grid.Column="1"
                        Classes="bancoSaleButton"
                        Content="Annulla"
                        Click="CancelButton_OnClick" />
                <Button Grid.Column="3"
                        Classes="bancoSaleButton primary"
                        Content="Conferma"
                        Click="ConfirmButton_OnClick" />
            </Grid>
        </Grid>
    </Border>
</Window>
