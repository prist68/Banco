<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Banco.UI.Avalonia.Banco.App"
             RequestedThemeVariant="Light">
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Banco.UI.Avalonia.Controls/Themes/BancoAvaloniaControls.axaml" />
        <StyleInclude Source="avares://Banco.AvaloniaBanco/DesignSystem/BancoSaleTheme.axaml" />
    </Application.Styles>
</Application>
