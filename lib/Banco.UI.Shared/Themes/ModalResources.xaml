<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="ModalOverlayBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#52F8FBFE" Offset="0" />
        <GradientStop Color="#44F3F7FC" Offset="0.45" />
        <GradientStop Color="#34EDF3FA" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ModalChromeBrush" Color="#FFF1F4F9" />
    <SolidColorBrush x:Key="ModalAccentBorderBrush" Color="#FFE0E8F2" />
    <SolidColorBrush x:Key="ModalInfoSurfaceBrush" Color="#FFF7FAFF" />
    <SolidColorBrush x:Key="ModalInfoBorderBrush" Color="#FFD3E0F2" />
    <SolidColorBrush x:Key="ModalInfoForegroundBrush" Color="#FF2F5EA5" />
    <SolidColorBrush x:Key="ModalFieldSurfaceBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ModalFieldAltSurfaceBrush" Color="#FFF8FBFF" />
    <SolidColorBrush x:Key="ModalFieldBorderBrush" Color="#FFD8E4F2" />
    <SolidColorBrush x:Key="ModalSurfaceBorderBrush" Color="#D8E4F1" />
    <SolidColorBrush x:Key="ModalCloseHoverBrush" Color="#FFF6F9FD" />
    <SolidColorBrush x:Key="ModalCloseHoverBorderBrush" Color="#FFBFD1E8" />
    <SolidColorBrush x:Key="ModalClosePressedBrush" Color="#FFE9F0F9" />
    <DropShadowEffect x:Key="ModalSurfaceShadowEffect"
                      BlurRadius="42"
                      ShadowDepth="0"
                      Opacity="0.18"
                      Color="#FF1F3250" />

    <Style x:Key="ModalOverlayHostStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ModalOverlayBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="ModalSurfaceCardStyle" TargetType="Border">
        <Setter Property="Margin" Value="28" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ModalSurfaceBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Effect" Value="{StaticResource ModalSurfaceShadowEffect}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="ModalHeaderCloseButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Margin" Value="12,0,0,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ToolTip" Value="Chiudi" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Opacity" Value="0.92" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ModalHeaderCloseChromeStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ModalChromeBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushBase}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="7" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                <Setter Property="Background" Value="{DynamicResource ModalCloseHoverBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ModalCloseHoverBorderBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsPressed, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                <Setter Property="Background" Value="{DynamicResource ModalClosePressedBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
