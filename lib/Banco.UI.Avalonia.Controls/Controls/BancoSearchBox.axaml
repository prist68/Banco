<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Banco.UI.Avalonia.Controls.Controls.BancoSearchBox">
    <Grid>
        <TextBox x:Name="PART_TextBox"
                 Classes="bancoSearchBox"
                 Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                 Watermark="{Binding Watermark, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        <Path Width="14"
              Height="14"
              Margin="10,0,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              Stretch="Uniform"
              Fill="{DynamicResource BancoMutedTextBrush}"
              Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L20.5,19L19,20.5L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3Z" />
    </Grid>
</UserControl>
