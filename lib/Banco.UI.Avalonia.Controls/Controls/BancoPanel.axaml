<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Banco.UI.Avalonia.Controls.Controls.BancoPanel">
    <Border Classes="bancoPanel">
        <Grid RowDefinitions="Auto,10,*">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BancoMainTextBrush}" />
                    <TextBlock Text="{Binding Subtitle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Margin="0,3,0,0"
                               FontSize="11.5"
                               Foreground="{DynamicResource BancoMutedTextBrush}"
                               IsVisible="{Binding HasSubtitle, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </StackPanel>
            </Grid>
            <ContentPresenter Grid.Row="2"
                              Content="{Binding Body, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </Grid>
    </Border>
</UserControl>
