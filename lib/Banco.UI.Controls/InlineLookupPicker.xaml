<UserControl x:Class="Banco.UI.Controls.InlineLookupPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="InlineLookupClosedFieldTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MaxHeight" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="InlineLookupListBoxStyle"
               TargetType="ListBox"
               BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="InlineLookupListBoxItemStyle"
               TargetType="ListBoxItem"
               BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="ClosedFieldHost"
                Background="Transparent"
                Cursor="Hand"
                PreviewMouseLeftButtonUp="ClosedFieldHost_OnPreviewMouseLeftButtonUp">
            <Grid>
                <TextBox Text="{Binding DisplayText, ElementName=Root}"
                         Style="{StaticResource InlineLookupClosedFieldTextBoxStyle}"
                         IsReadOnly="True"
                         IsHitTestVisible="False" />
                <TextBlock HorizontalAlignment="Right"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           Text="▼"
                           IsHitTestVisible="False" />
            </Grid>
        </Border>

        <Popup x:Name="LookupPopup"
               IsOpen="{Binding IsOpen, ElementName=Root, Mode=TwoWay}"
               PlacementTarget="{Binding ElementName=ClosedFieldHost}"
               Placement="Bottom"
               HorizontalOffset="0"
               VerticalOffset="4"
               AllowsTransparency="True"
               PopupAnimation="None"
               StaysOpen="False"
               Opened="LookupPopup_OnOpened"
               Closed="LookupPopup_OnClosed">
            <Border MinWidth="{Binding ElementName=ClosedFieldHost, Path=ActualWidth}"
                    MaxWidth="720"
                    Padding="6"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushBase}"
                    BorderThickness="1"
                    CornerRadius="8"
                    SnapsToDevicePixels="True">
                <StackPanel>
                    <TextBox x:Name="FilterTextBox"
                             Text="{Binding SearchText, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="{Binding ElementName=ClosedFieldHost, Path=ActualWidth}"
                             Style="{StaticResource CompactTextBoxStyle}"
                             MinHeight="30"
                             MaxHeight="30"
                             Padding="8,0"
                             FontSize="12"
                             VerticalContentAlignment="Center" />

                    <Border Margin="0,6,0,0"
                            Padding="2"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushBase}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <ListBox x:Name="ItemsListBox"
                                     ItemsSource="{Binding ItemsSource, ElementName=Root}"
                                     SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay}"
                                     SelectionChanged="ItemsListBox_OnSelectionChanged"
                                     MaxHeight="{Binding MaxListHeight, ElementName=Root}"
                                     Visibility="{Binding HasItems, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     Style="{StaticResource InlineLookupListBoxStyle}"
                                     ItemContainerStyle="{StaticResource InlineLookupListBoxItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Label}"
                                                   TextWrapping="NoWrap" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Padding="8,6"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="{Binding EmptyText, ElementName=Root}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasItems, ElementName=Root}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
