<UserControl x:Class="Banco.Sidebar.Views.SidebarContextPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Banco.Sidebar.Converters"
             xmlns:vm="clr-namespace:Banco.Sidebar.ViewModels">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />

        <Style x:Key="ShortcutButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card"
                                Background="{DynamicResource ShellContextCardBrush}"
                                BorderBrush="{DynamicResource ShellContextCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="{Binding AccentBrush}" CornerRadius="4" />
                                <ContentPresenter Grid.Column="2" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource ShellContextCardHoverBrush}" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ShellContextCardHoverBorderBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource ShellContextCardActiveBrush}" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ShellAccentBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ShellHighlightBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Card" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource ShellContextOverlayBrush}"
            BorderBrush="{DynamicResource ShellContextOverlayBorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="18"
            Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="11"
                           FontWeight="Bold"
                           Foreground="{DynamicResource ShellContextMutedBrush}"
                           Text="PANNELLO CATEGORIA" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Text="{Binding SelectedMacroCategory.Title, TargetNullValue=Navigazione}" />
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          Margin="0,16,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding SelectedGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SidebarSectionGroupViewModel}">
                                <StackPanel Margin="0,0,0,14">
                                    <TextBlock Margin="0,0,0,8"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="{Binding Title}" />
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:SidebarShortcutItemViewModel}">
                                                <Button Style="{StaticResource ShortcutButtonStyle}"
                                                        Command="{Binding OpenCommand}"
                                                        IsEnabled="{Binding IsEnabled}">
                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Text="{Binding DisplayTitle}" />
                                                        <TextBlock Margin="0,2,0,0"
                                                                   FontSize="11.5"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Text="{Binding InfoText}"
                                                                   TextWrapping="Wrap"
                                                                   Visibility="{Binding IsInformational, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Padding="14"
                            Background="{DynamicResource ShellContextEmptyStateBrush}"
                            BorderBrush="{DynamicResource ShellContextCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="{Binding HasSelectedGroups, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding EmptyCategoryMessage}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
