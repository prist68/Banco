<UserControl x:Class="Banco.Sidebar.Views.SidebarContextPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Banco.Sidebar.Converters"
             xmlns:vm="clr-namespace:Banco.Sidebar.ViewModels">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />

        <Style x:Key="GroupTitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="ShortcutButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card"
                                Background="{DynamicResource ShellContextCardBrush}"
                                BorderBrush="{DynamicResource ShellContextCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.RowSpan="2"
                                        Width="4"
                                        Margin="0,1"
                                        Background="{Binding AccentBrush}"
                                        CornerRadius="4" />
                                <ContentPresenter Grid.Column="2"
                                                  VerticalAlignment="Center" />
                                <Path Grid.Column="3"
                                      Width="9"
                                      Height="9"
                                      Margin="6,0,1,0"
                                      VerticalAlignment="Center"
                                      Stretch="Uniform"
                                      Fill="{DynamicResource ShellContextMutedBrush}"
                                      Data="M 0 0 L 6 5 L 0 10 Z"
                                      Opacity="0.72" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource ShellContextCardHoverBrush}" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ShellContextCardHoverBorderBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource ShellContextCardActiveBrush}" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ShellAccentBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ShellHighlightBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Card" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource ShellContextOverlayBrush}"
            BorderBrush="{DynamicResource ShellContextOverlayBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="10"
            Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="11"
                           FontWeight="Bold"
                           Foreground="{DynamicResource ShellContextMutedBrush}"
                           Text="PANNELLO CATEGORIA" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Text="{Binding SelectedMacroCategory.Title, TargetNullValue=Navigazione}" />
                <Border Margin="0,8,0,0"
                        Height="1"
                        Background="{DynamicResource ShellContextCardBorderBrush}"
                        Opacity="0.85" />
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          Margin="0,8,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="True">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding SelectedGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SidebarSectionGroupViewModel}">
                                <StackPanel Margin="0,0,0,6">
                                    <TextBlock Style="{StaticResource GroupTitleStyle}"
                                               Text="{Binding Title}" />
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:SidebarShortcutItemViewModel}">
                                                <Button Style="{StaticResource ShortcutButtonStyle}"
                                                        Command="{Binding OpenCommand}"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        PreviewMouseLeftButtonDown="ShortcutButton_OnPreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="ShortcutButton_OnPreviewMouseMove"
                                                        Click="ShortcutButton_OnClick">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock FontSize="11.5"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Text="{Binding DisplayTitle}" />
                                                        <TextBlock Margin="0,2,0,0"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Text="{Binding InfoText}"
                                                                   TextWrapping="Wrap"
                                                                   Visibility="{Binding IsInformational, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Padding="12"
                            Background="{DynamicResource ShellContextEmptyStateBrush}"
                            BorderBrush="{DynamicResource ShellContextCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="{Binding HasSelectedGroups, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding EmptyCategoryMessage}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
