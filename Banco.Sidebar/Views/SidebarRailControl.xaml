<UserControl x:Class="Banco.Sidebar.Views.SidebarRailControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Banco.Sidebar.Converters"
             xmlns:vm="clr-namespace:Banco.Sidebar.ViewModels">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <conv:ResourceKeyToGeometryConverter x:Key="ResourceKeyToGeometryConverter" />

        <Style x:Key="RailSearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ShellRailSearchBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShellRailSearchBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource ShellRailForegroundBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="SearchBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Path Width="13"
                                      Height="13"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"
                                      Stretch="Uniform"
                                      Fill="{DynamicResource ShellRailMutedBrush}"
                                      Data="{StaticResource IconSearch}" />
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="{DynamicResource ShellRailSearchHoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="{DynamicResource ShellAccentBrush}" />
                                <Setter TargetName="SearchBorder" Property="Background" Value="{DynamicResource ShellRailFooterBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RailButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="10,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RailBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RailBorder" Property="Background" Value="{DynamicResource ShellRailHoverBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="RailBorder" Property="Background" Value="{DynamicResource ShellRailActiveBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RailSearchResultButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ResultBorder"
                                Background="{DynamicResource ShellRailFooterBrush}"
                                BorderBrush="{DynamicResource ShellRailFooterBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ResultBorder" Property="Background" Value="{DynamicResource ShellRailHoverBrush}" />
                                <Setter TargetName="ResultBorder" Property="BorderBrush" Value="{DynamicResource ShellAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource ShellRailSurfaceBrush}"
            BorderBrush="{DynamicResource ShellRailBorderBrush}"
            BorderThickness="0,0,1,0">
        <Border.ContextMenu>
            <ContextMenu Style="{DynamicResource ThemedContextMenuStyle}">
                <MenuItem Header="Personalizza sidebar"
                          Command="{Binding CustomizeSidebarCommand}"
                          Style="{DynamicResource ThemedContextMenuItemStyle}" />
                <MenuItem Header="Ripristina layout sidebar"
                          Command="{Binding ResetCustomizationCommand}"
                          Style="{DynamicResource ThemedContextMenuItemStyle}" />
            </ContextMenu>
        </Border.ContextMenu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="12,14,12,0">
                <TextBlock FontSize="10.5"
                           FontWeight="Bold"
                           Foreground="{DynamicResource ShellRailMutedBrush}"
                           Text="NAVIGAZIONE" />
                <TextBox Margin="0,10,0,0"
                         Style="{StaticResource RailSearchBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="12,12,12,0"
                    Visibility="{Binding SearchResults.Count, Converter={StaticResource CountToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding SearchResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SidebarSearchResultViewModel}">
                            <Button Click="SearchResultButton_OnClick"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource RailSearchResultButtonStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource ShellRailForegroundBrush}"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource ShellRailMutedBrush}"
                                               Text="{Binding Subtitle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <ItemsControl Grid.Row="2"
                          Margin="8,14,8,0"
                          ItemsSource="{Binding MacroCategories}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:SidebarMacroCategoryViewModel}">
                        <Button Style="{StaticResource RailButtonStyle}"
                                Command="{Binding ActivateCommand}"
                                Tag="{Binding Key}"
                                MouseEnter="MacroCategoryButton_OnMouseEnter"
                                GotKeyboardFocus="MacroCategoryButton_OnGotKeyboardFocus">
                            <StackPanel>
                                <Border Width="42"
                                        Height="42"
                                        HorizontalAlignment="Center"
                                        CornerRadius="12"
                                        Background="{Binding AccentBrush}">
                                    <Path Width="22"
                                          Height="22"
                                          Stretch="Uniform"
                                          Fill="{DynamicResource ShellRailIconBrush}"
                                          Data="{Binding IconResourceKey, Converter={StaticResource ResourceKeyToGeometryConverter}}" />
                                </Border>
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ShellRailForegroundBrush}"
                                           Text="{Binding Title}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="3"
                    Margin="12,0,12,14"
                    Padding="10,12"
                    Background="{DynamicResource ShellRailFooterBrush}"
                    BorderBrush="{DynamicResource ShellRailFooterBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock FontSize="10.5"
                               FontWeight="Bold"
                               Foreground="{DynamicResource ShellRailMutedBrush}"
                               Text="SHELL" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="11.5"
                               Foreground="{DynamicResource ShellRailForegroundBrush}"
                               Text="Hover su categoria per aprire il pannello overlay."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
