<Window x:Class="Banco.Sidebar.Views.SidebarCustomizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Banco.Sidebar.ViewModels"
        Title="Personalizza sidebar"
        Width="860"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="24"
                   FontWeight="Bold"
                   Text="Personalizza sidebar" />

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="14"
                    Background="#FFFFFFFF"
                    BorderBrush="#DDE6F1"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="15"
                               FontWeight="Bold"
                               Text="Categorie principali" />
                    <ItemsControl Margin="0,14,0,0"
                                  ItemsSource="{Binding MacroCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SidebarMacroCategoryViewModel}">
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Background="#FFF8FBFF"
                                        BorderBrush="#E2EAF4"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Title}" />
                                            <ComboBox Margin="0,8,0,0"
                                                      Tag="{Binding}"
                                                      SelectionChanged="MacroAccentCombo_OnSelectionChanged"
                                                      SelectedValue="{Binding AccentColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Content">
                                                <ComboBoxItem Content="#4F86DC" />
                                                <ComboBoxItem Content="#3FA06E" />
                                                <ComboBoxItem Content="#C47F1F" />
                                                <ComboBoxItem Content="#B55454" />
                                                <ComboBoxItem Content="#7059B8" />
                                                <ComboBoxItem Content="#4E748F" />
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right">
                                            <Button Margin="0,0,6,0"
                                                    Click="MacroMoveUp_OnClick"
                                                    CommandParameter="{Binding}"
                                                    Content="Su" />
                                            <Button Click="MacroMoveDown_OnClick"
                                                    CommandParameter="{Binding}"
                                                    Content="Giu`" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="14"
                    Background="#FFFFFFFF"
                    BorderBrush="#DDE6F1"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="15"
                               FontWeight="Bold"
                               Text="Scorciatoie personalizzabili" />
                    <ScrollViewer Margin="0,14,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CustomizableEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:SidebarCustomizationEntryViewModel}">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            Background="#FFF8FBFF"
                                            BorderBrush="#E2EAF4"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="140" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding SlotTitle}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           FontSize="11.5"
                                                           Foreground="#6B7E99"
                                                           Text="{Binding GroupTitle}" />
                                                <ComboBox Margin="0,8,0,0"
                              ItemsSource="{Binding AvailableDestinations}"
                                                          DisplayMemberPath="Title"
                                                          SelectedValuePath="Key"
                              SelectedValue="{Binding DestinationKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEnabled="{Binding SupportsTargetOverride}" />
                                                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                                    <CheckBox Content="Visibile"
                                                              IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                              IsEnabled="{Binding SupportsVisibility}" />
                                                    <ComboBox Margin="12,0,0,0"
                                                              Width="110"
                                                              SelectedValue="{Binding AccentColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              SelectedValuePath="Content"
                                                              IsEnabled="{Binding SupportsAccentCustomization}">
                                                        <ComboBoxItem Content="#4F86DC" />
                                                        <ComboBoxItem Content="#3FA06E" />
                                                        <ComboBoxItem Content="#C47F1F" />
                                                        <ComboBoxItem Content="#B55454" />
                                                        <ComboBoxItem Content="#7059B8" />
                                                        <ComboBoxItem Content="#4E748F" />
                                                    </ComboBox>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Margin="0,0,6,0"
                                                        Command="{Binding MoveUpCommand}"
                                                        Content="Su" />
                                                <Button Command="{Binding MoveDownCommand}"
                                                        Content="Giu`" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Margin="0,0,10,0"
                    Padding="14,8"
                    Command="{Binding ResetCustomizationCommand}"
                    Content="Ripristina" />
            <Button Padding="14,8"
                    Click="CloseButton_OnClick"
                    Content="Chiudi" />
        </StackPanel>
    </Grid>
</Window>
