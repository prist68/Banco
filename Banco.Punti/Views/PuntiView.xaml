<UserControl x:Class="Banco.Punti.Views.PuntiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- Override locale: Padding compatto e font ridotto per campi a 30px -->
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="OfficeFormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="PanelHeaderStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFF6F8FD" Offset="0" />
                        <GradientStop Color="#FFF1F5FD" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <LinearGradientBrush x:Key="HeaderAccentBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF2F66C7" Offset="0" />
            <GradientStop Color="#FF4C80DA" Offset="0.72" />
            <GradientStop Color="#FF86B6E8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="EditorAccentBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFF8FBF4" Offset="0" />
            <GradientStop Color="#FFF4FAF1" Offset="1" />
        </LinearGradientBrush>
    </UserControl.Resources>

    <Grid Background="#FFF7F8FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,10" ClipToBounds="True">
            <Grid>
                <Border Height="3" VerticalAlignment="Top" Background="{StaticResource HeaderAccentBrush}" />
                <Grid Margin="10,11,12,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF2F66C7" Offset="0" />
                                <GradientStop Color="#FF1F4E96" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Viewbox Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Fill="White" Data="{StaticResource IconPoints}" />
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Titolo}" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Margin="0,3,0,0"
                                   Text="Campagna punti nativa del gestionale e regole premio locali."
                                   Style="{StaticResource SectionHintStyle}" />
                    </StackPanel>

                    <WrapPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Nuova campagna"
                                Command="{Binding NewCampaignCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,5" Margin="0,0,6,0" />
                        <Button Content="Salva"
                                Command="{Binding SaveCampaignCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="10,5" Margin="0,0,6,0" />
                        <Button Content="Annulla"
                                Command="{Binding CancelCampaignCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,5" Margin="0,0,6,0" />
                        <Button Content="Aggiorna"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,5" />
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Corpo: colonna sinistra + destra -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Colonna sinistra -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Campagna Attiva -->
                    <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,8" ClipToBounds="True">
                        <StackPanel>
                            <Border Style="{StaticResource PanelHeaderStyle}">
                                <TextBlock Text="Campagna Attiva" Style="{StaticResource SectionTitleStyle}" />
                            </Border>
                            <StackPanel Margin="10,8,10,10">
                                <Border Padding="8" CornerRadius="6"
                                        Background="#FFFFFFFF"
                                        BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="5" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="5" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0">
                                            <TextBlock Text="CODICE" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox IsReadOnly="True"
                                                     Text="{Binding SelectedCampaignSummary.Oid}"
                                                     Height="30" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2">
                                            <TextBlock Text="DESCRIZIONE BREVE" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox IsReadOnly="True"
                                                     Text="{Binding EditedCampaignTitle, Mode=OneWay}"
                                                     Height="30" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="4">
                                            <TextBlock Text="ELENCO CAMPAGNE" Style="{StaticResource FieldLabelStyle}" />
                                            <DataGrid AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      HeadersVisibility="Column"
                                                      SelectionMode="Single"
                                                      ItemsSource="{Binding Campaigns}"
                                                      SelectedItem="{Binding SelectedCampaignSummary, Mode=TwoWay}"
                                                      Height="110"
                                                      RowHeight="22"
                                                      ColumnHeaderHeight="24"
                                                      BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Campagna" Binding="{Binding NomeOperazione}" Width="*" />
                                                    <DataGridTextColumn Header="Periodo" Binding="{Binding PeriodoLabel}" Width="110" />
                                                    <DataGridTextColumn Header="Stato" Binding="{Binding StatoLabel}" Width="66" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Cliente e Simulazione -->
                    <Border Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                        <Expander IsExpanded="True" Background="Transparent">
                            <Expander.Header>
                                <TextBlock Text="Cliente e Simulazione" Style="{StaticResource SectionTitleStyle}" />
                            </Expander.Header>
                            <StackPanel Margin="10,6,10,10">
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Height="30"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Ricerca cliente in tempo reale." />

                                <ListBox Margin="0,5,0,0"
                                         Height="70"
                                         ItemsSource="{Binding CustomerResults}"
                                         SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                                         DisplayMemberPath="DisplayLabel"
                                         BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1" />

                                <Border Margin="0,7,0,0" Padding="8,6" CornerRadius="6"
                                        Background="#FFF3F6FC"
                                        BorderBrush="#FFE0E7F2" BorderThickness="1">
                                    <TextBlock Text="{Binding SelectedCustomerLoyaltyLabel}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <!-- Riepilogo punti -->
                                <Border Margin="0,7,0,0" Padding="8,6" CornerRadius="6"
                                        Background="#FFFFFFFF"
                                        BorderBrush="#FFE0E7F2" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Storici" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding HistoricalPointsLabel}" FontSize="13" FontWeight="Bold" Foreground="#FF2F66C7" />
                                        <TextBlock Grid.Row="1" Margin="0,3,0,0" Text="Corrente" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,3,0,0" Text="{Binding CurrentDocumentPointsLabel}" FontSize="13" FontWeight="Bold" Foreground="#FF2F66C7" />
                                        <TextBlock Grid.Row="2" Margin="0,3,0,0" Text="Disponibili" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,3,0,0" Text="{Binding TotalAvailablePointsLabel}" FontSize="13" FontWeight="Bold" Foreground="#FF2F66C7" />
                                        <TextBlock Grid.Row="3" Margin="0,3,0,0" Text="Soglia" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,3,0,0" Text="{Binding RequiredPointsLabel}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Grid>
                                </Border>

                                <!-- Regola e stato premio -->
                                <Grid Margin="0,7,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="7" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Padding="8,6" CornerRadius="6"
                                            Background="#FFFFFFFF"
                                            BorderBrush="#FFE0E7F2" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Regola" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Margin="0,3,0,0"
                                                       Text="{Binding SelectedRuleDisplayName}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Padding="8,6" CornerRadius="6"
                                            Background="#FFFFFFFF"
                                            BorderBrush="#FFE0E7F2" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Stato premio" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Margin="0,3,0,0"
                                                       Text="{Binding RewardStatusLabel}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Text="{Binding RewardDistanceLabel}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Expander>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Colonna destra -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Dettaglio campagna Punti -->
                    <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,8" ClipToBounds="True">
                        <StackPanel>
                            <Border Style="{StaticResource PanelHeaderStyle}">
                                <TextBlock Text="Dettaglio campagna Punti" Style="{StaticResource SectionTitleStyle}" />
                            </Border>

                            <Border Margin="10,8,10,10"
                                    Padding="10,8"
                                    BorderBrush="{StaticResource BorderBrushBase}"
                                    BorderThickness="1"
                                    Background="#FFFCFCFD">
                                <Grid DataContext="{Binding EditedCampaign}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="78" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="68" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Riga 0: Nome campagna | Data inizio | Data fine -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome campagna" Style="{StaticResource OfficeFormLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             Text="{Binding NomeOperazione, UpdateSourceTrigger=PropertyChanged}"
                                             Height="30" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Data inizio" Style="{StaticResource OfficeFormLabelStyle}" />
                                    <DatePicker Grid.Row="0" Grid.Column="4"
                                                SelectedDate="{Binding Inizio, Mode=TwoWay}"
                                                Height="30" />
                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Data fine" Style="{StaticResource OfficeFormLabelStyle}" />
                                    <DatePicker Grid.Row="0" Grid.Column="7"
                                                SelectedDate="{Binding Fine, Mode=TwoWay}"
                                                Height="30" />

                                    <!-- Riga 2: Euro/punto | Importo min | Attiva | Base calcolo | IVA inclusa — tutto in linea -->
                                    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="Euro per punto" Style="{StaticResource OfficeFormLabelStyle}" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding EuroPerPunto, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30" />

                                        <TextBlock Grid.Column="3" Text="Importo minimo" Style="{StaticResource OfficeFormLabelStyle}" />
                                        <TextBox Grid.Column="4"
                                                 Text="{Binding ImportoMinimo, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30" />

                                        <Border Grid.Column="6" Height="30"
                                                CornerRadius="4" Background="#FFF8FAFD"
                                                BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                                                Padding="8,0">
                                            <CheckBox IsChecked="{Binding Attiva, Mode=TwoWay}"
                                                      Content="Attiva" VerticalAlignment="Center" />
                                        </Border>

                                        <TextBlock Grid.Column="8" Text="Base calcolo" Style="{StaticResource OfficeFormLabelStyle}" />
                                        <ComboBox Grid.Column="9"
                                                  ItemsSource="{Binding DataContext.BaseCalculationOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding DataContext.SelectedBaseCalculation, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Height="30" />

                                        <Border Grid.Column="11" Height="30"
                                                CornerRadius="4" Background="#FFF8FAFD"
                                                BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                                                Padding="8,0">
                                            <CheckBox IsChecked="{Binding CalcolaSuValoreIva, Mode=TwoWay}"
                                                      Content="IVA inclusa" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Regole Premio -->
                    <Border Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                        <StackPanel>
                            <Border Style="{StaticResource PanelHeaderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Regole Premio" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />

                                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <Button Content="+ Aggiungi"
                                                Command="{Binding AddRewardRuleCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Padding="10,5" Margin="0,0,5,0" />
                                        <Button Content="Salva"
                                                Command="{Binding SaveCampaignCommand}"
                                                Style="{StaticResource GreenButtonStyle}"
                                                Padding="10,5" Margin="0,0,5,0" />
                                        <Button Content="Modifica"
                                                Command="{Binding EditRewardRuleCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="10,5" Margin="0,0,5,0" />
                                        <Button Content="Elimina"
                                                Command="{Binding DeleteRewardRuleCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="10,5" Margin="0,0,5,0" />
                                        <Button Content="Duplica"
                                                Command="{Binding DuplicateRewardRuleCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="10,5" />
                                    </WrapPanel>
                                </Grid>
                            </Border>

                            <DataGrid Margin="10,8,10,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      ItemsSource="{Binding RewardRules}"
                                      SelectedItem="{Binding SelectedRewardRule, Mode=TwoWay}"
                                      BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                                      Height="110"
                                      RowHeight="22"
                                      ColumnHeaderHeight="24">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Regola" Binding="{Binding RuleName}" Width="*" />
                                    <DataGridTextColumn Header="Tipo Premio" Binding="{Binding RewardTypeLabel}" Width="120" />
                                    <DataGridTextColumn Header="Punti" Binding="{Binding RequiredPoints}" Width="60" />
                                    <DataGridTextColumn Header="Premio" Binding="{Binding RewardDescription}" Width="200" />
                                    <DataGridTextColumn Header="Stato" Binding="{Binding StateLabel}" Width="66" />
                                    <DataGridCheckBoxColumn Header="Ctrl" Binding="{Binding EnableSaleCheck}" Width="46" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Editor Regola Premio -->
                            <Expander Margin="10,8,10,10"
                                      IsExpanded="True"
                                      IsEnabled="{Binding HasSelectedRewardRule}">
                                <Expander.Header>
                                    <TextBlock Text="Editor Regola Premio"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                </Expander.Header>
                                <Border Margin="0,6,0,0"
                                        Padding="0"
                                        CornerRadius="8"
                                        BorderBrush="#FFDCE8D3"
                                        BorderThickness="1"
                                        ClipToBounds="True">
                                    <StackPanel>
                                        <Border Padding="10,7" BorderBrush="#FFDCE8D3" BorderThickness="0,0,0,1"
                                                Background="{StaticResource EditorAccentBrush}">
                                            <TextBlock Text="Configurazione compatta della regola selezionata"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </Border>

                                        <!-- Campi principali: nome, punti, tipo, flag -->
                                        <Border Margin="10,8,10,0"
                                                Padding="8,7"
                                                BorderBrush="{StaticResource BorderBrushBase}"
                                                BorderThickness="1"
                                                Background="#FFFCFCFD">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="88" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="74" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="76" />
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="82" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="98" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="Nome regola" Style="{StaticResource OfficeFormLabelStyle}" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding EditedRuleName, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="30" />

                                                <TextBlock Grid.Column="3" Text="Punti" Style="{StaticResource OfficeFormLabelStyle}" />
                                                <TextBox Grid.Column="4"
                                                         Text="{Binding EditedRuleRequiredPoints, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="30" />

                                                <TextBlock Grid.Column="6" Text="Tipo premio" Style="{StaticResource OfficeFormLabelStyle}" />
                                                <ComboBox Grid.Column="7"
                                                          SelectedValue="{Binding SelectedRewardTypeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Tag"
                                                          Height="30">
                                                    <ComboBoxItem Content="Sconto fisso (EUR)" Tag="ScontoFisso" />
                                                    <ComboBoxItem Content="Sconto percentuale (%)" Tag="ScontoPercentuale" />
                                                    <ComboBoxItem Content="Articolo premio" Tag="ArticoloPremio" />
                                                </ComboBox>

                                                <Border Grid.Column="9"
                                                        Height="30" CornerRadius="4"
                                                        Background="#FFF8FAFD"
                                                        BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                                                        Padding="6,0">
                                                    <CheckBox IsChecked="{Binding EditedRuleActive, Mode=TwoWay}"
                                                              Content="Attiva" VerticalAlignment="Center" />
                                                </Border>

                                                <Border Grid.Column="11"
                                                        Height="30" CornerRadius="4"
                                                        Background="#FFF8FAFD"
                                                        BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                                                        Padding="6,0">
                                                    <CheckBox IsChecked="{Binding EditedRuleEnableSaleCheck, Mode=TwoWay}"
                                                              Content="Controllo" VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <!-- Sconto fisso / percentuale -->
                                        <Grid Margin="10,8,10,0">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedRuleIsFixedDiscount}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedRuleIsPercentDiscount}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="170" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="SCONTO FISSO (EUR)" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox Text="{Binding EditedRuleDiscountAmount, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="30" Width="160" HorizontalAlignment="Left" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="SCONTO PERCENTUALE (%)" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox Text="{Binding EditedRuleDiscountPercent, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="30" Width="160" HorizontalAlignment="Left" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- Articolo premio -->
                                        <Grid Margin="10,8,10,0">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedRuleIsArticleReward}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>

                                            <Border Padding="8,7" CornerRadius="8"
                                                    Background="#FFF7FBF4"
                                                    BorderBrush="#FFD6E7C9" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="5" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2.2*" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="66" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="1.8*" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                                        <TextBlock Text="ARTICOLO PREMIO" Style="{StaticResource FieldLabelStyle}" />
                                                        <Border Height="30" CornerRadius="6"
                                                                Background="#FFFFFFFF"
                                                                BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                                                                Padding="8,0">
                                                            <TextBlock Text="{Binding SelectedRewardArticleLabel}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       VerticalAlignment="Center"
                                                                       TextWrapping="NoWrap"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                                        <TextBlock Text="QTÀ" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox Text="{Binding EditedRuleRewardQuantity, UpdateSourceTrigger=PropertyChanged}"
                                                                 Height="30" Width="66" HorizontalAlignment="Left" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="0" Grid.Column="4">
                                                        <TextBlock Text="RICERCA ARTICOLO PREMIO" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox Text="{Binding RewardArticleSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                                 Height="30"
                                                                 HorizontalAlignment="Stretch"
                                                                 VerticalContentAlignment="Center"
                                                                 ToolTip="Ricerca live: i risultati si aggiornano mentre scrivi." />
                                                    </StackPanel>

                                                    <Button Grid.Row="0" Grid.Column="6"
                                                            Content="Rimuovi"
                                                            Command="{Binding ClearRewardArticleCommand}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Padding="10,5"
                                                            VerticalAlignment="Bottom" />

                                                    <ListBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7"
                                                             Height="62"
                                                             ItemsSource="{Binding RewardArticleResults}"
                                                             SelectedItem="{Binding SelectedRewardArticleSearchResult, Mode=TwoWay}"
                                                             DisplayMemberPath="DisplayLabel"
                                                             BorderBrush="#FFD6E7C9" BorderThickness="1" />
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <!-- Note operative -->
                                        <Expander Margin="10,8,10,10" IsExpanded="False">
                                            <Expander.Header>
                                                <TextBlock Text="Note operative" FontSize="11" FontWeight="Bold" />
                                            </Expander.Header>
                                            <TextBox Margin="0,6,0,0"
                                                     MinHeight="60"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalContentAlignment="Top"
                                                     Padding="8,6"
                                                     Text="{Binding EditedRuleNotes, UpdateSourceTrigger=PropertyChanged}" />
                                        </Expander>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Barra di stato -->
        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Padding="12,7"
                CornerRadius="6"
                BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                Background="#FFFFFFFF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Ellipse Width="7" Height="7" Fill="#FF5BA642" VerticalAlignment="Center" Margin="0,0,7,0" />
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           FontSize="11" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
