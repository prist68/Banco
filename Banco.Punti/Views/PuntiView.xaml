<UserControl x:Class="Banco.Punti.Views.PuntiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Banco.UI.Controls;assembly=Banco.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Root"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <!-- Override locale: Padding compatto e font ridotto per campi a 30px -->
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="OfficeFormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="PanelHeaderStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFF6F8FD" Offset="0" />
                        <GradientStop Color="#FFF1F5FD" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <LinearGradientBrush x:Key="HeaderAccentBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF2F66C7" Offset="0" />
            <GradientStop Color="#FF4C80DA" Offset="0.72" />
            <GradientStop Color="#FF86B6E8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="EditorAccentBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFF8FBF4" Offset="0" />
            <GradientStop Color="#FFF4FAF1" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="FidelityRefreshButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#FFF1F7FF" />
            <Setter Property="Foreground" Value="#FF2F67B1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="RewardGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource CompactDataGridRowStyle}">
            <Setter Property="DetailsVisibility" Value="Collapsed" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="RewardGridRow_OnPreviewMouseLeftButtonDown" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="DetailsVisibility" Value="Visible" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RewardGridHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource CompactDataGridHeaderStyle}">
            <Setter Property="Background" Value="#FFF2F7FF" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="8,7" />
        </Style>

        <Style x:Key="RewardGridCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource CompactDataGridCellStyle}">
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style x:Key="CustomerLookupListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBase}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="CustomerLookupItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <EventSetter Event="MouseEnter" Handler="CustomerResultItem_OnMouseEnter" />
            <EventSetter Event="MouseLeave" Handler="CustomerResultItem_OnMouseLeave" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#FFF7F8FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,10" ClipToBounds="True">
            <Grid>
                <Border Height="3" VerticalAlignment="Top" Background="{StaticResource HeaderAccentBrush}" />
                <Grid Margin="10,11,12,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF2F66C7" Offset="0" />
                                <GradientStop Color="#FF1F4E96" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Viewbox Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Fill="White" Data="{StaticResource IconPoints}" />
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Titolo}" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Margin="0,3,0,0"
                                   Text="Campagna punti nativa del gestionale e regole premio locali."
                                   Style="{StaticResource SectionHintStyle}" />
                    </StackPanel>

                    <WrapPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Nuova campagna"
                                Command="{Binding NewCampaignCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,5" Margin="0,0,6,0" />
                        <Button Content="Salva"
                                Command="{Binding SaveCampaignCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="10,5" Margin="0,0,6,0" />
                        <Button Content="Annulla"
                                Command="{Binding CancelCampaignCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,5" Margin="0,0,6,0" />
                        <Button Content="Aggiorna"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,5" />
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Corpo: colonna sinistra + destra -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Colonna sinistra -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Campagna Attiva -->
                    <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,8" ClipToBounds="True">
                        <StackPanel>
                            <Border Style="{StaticResource PanelHeaderStyle}">
                                <TextBlock Text="Campagna Attiva" Style="{StaticResource SectionTitleStyle}" />
                            </Border>
                            <StackPanel Margin="10,8,10,10">
                                <Border Padding="8" CornerRadius="6"
                                        Background="#FFFFFFFF"
                                        BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="5" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="5" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0">
                                            <TextBlock Text="CODICE" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox IsReadOnly="True"
                                                     Text="{Binding SelectedCampaignSummary.Oid}"
                                                     Height="30" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2">
                                            <TextBlock Text="DESCRIZIONE BREVE" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox IsReadOnly="True"
                                                     Text="{Binding EditedCampaignTitle, Mode=OneWay}"
                                                     Height="30" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="4">
                                            <TextBlock Text="ELENCO CAMPAGNE" Style="{StaticResource FieldLabelStyle}" />
                                            <DataGrid AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      HeadersVisibility="Column"
                                                      SelectionMode="Single"
                                                      ItemsSource="{Binding Campaigns}"
                                                      SelectedItem="{Binding SelectedCampaignSummary, Mode=TwoWay}"
                                                      Height="110"
                                                      RowHeight="22"
                                                      ColumnHeaderHeight="24"
                                                      BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Campagna" Binding="{Binding NomeOperazione}" Width="*" />
                                                    <DataGridTextColumn Header="Periodo" Binding="{Binding PeriodoLabel}" Width="110" />
                                                    <DataGridTextColumn Header="Stato" Binding="{Binding StatoLabel}" Width="66" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Cliente e Simulazione -->
                    <Border Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                        <Expander IsExpanded="True" Background="Transparent">
                            <Expander.Header>
                                <TextBlock Text="Cliente e Simulazione" Style="{StaticResource SectionTitleStyle}" />
                            </Expander.Header>
                            <Grid Margin="10,6,10,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="330" />
                                </Grid.RowDefinitions>

                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Grid.Row="0"
                                         Height="30"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Ricerca cliente in tempo reale." />

                                <Grid Grid.Row="2">
                                    <ListBox x:Name="CustomerResultsListBox"
                                             ItemsSource="{Binding CustomerResults}"
                                             SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                                             Style="{StaticResource CustomerLookupListBoxStyle}"
                                             ItemContainerStyle="{StaticResource CustomerLookupItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6"
                                                        CornerRadius="5"
                                                        Background="Transparent">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HaRaccoltaPunti}" Value="False">
                                                                            <Setter Property="Foreground" Value="{StaticResource SemanticDangerBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <Border Grid.Column="1"
                                                                Margin="8,0,0,0"
                                                                Padding="6,1"
                                                                CornerRadius="9"
                                                                Background="#FFF1F6FF"
                                                                BorderBrush="#FFD8E4F3"
                                                                BorderThickness="1"
                                                                VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HaRaccoltaPunti}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding PuntiLabel}"
                                                                       FontSize="10"
                                                                       FontWeight="Bold"
                                                                       Foreground="#FF2F66C7" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Popup x:Name="CustomerPreviewPopup"
                                           Placement="Custom"
                                           AllowsTransparency="True"
                                           PopupAnimation="None"
                                           StaysOpen="True"
                                           CustomPopupPlacementCallback="CustomerPreviewPopup_OnCustomPopupPlacement"
                                           Closed="CustomerPreviewPopup_OnClosed">
                                        <Border Width="232"
                                                DataContext="{Binding DataContext, ElementName=Root}"
                                                Padding="10"
                                                Background="#FFFBFDFF"
                                                BorderBrush="#FFD7E3F0"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                SnapsToDevicePixels="True">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12"
                                                                  ShadowDepth="2"
                                                                  Direction="270"
                                                                  Color="#2E4466"
                                                                  Opacity="0.18"
                                                                  RenderingBias="Performance" />
                                            </Border.Effect>
                                            <StackPanel>
                                                <TextBlock Text="{Binding SelectedCustomer.DisplayName}"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding SelectedCustomerCardCodeLabel, StringFormat=Carta: {0}}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding SelectedCustomerCardCodeLabel}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding TotalAvailablePointsLabel, StringFormat=Punti: {0}}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FF2F66C7" />
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0"
                                                               Text="Storici"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Row="0"
                                                               Grid.Column="1"
                                                               Text="{Binding HistoricalPointsLabel}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="#FF2F66C7" />
                                                    <TextBlock Grid.Row="1"
                                                               Margin="0,3,0,0"
                                                               Text="Corrente"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Row="1"
                                                               Grid.Column="1"
                                                               Margin="0,3,0,0"
                                                               Text="{Binding CurrentDocumentPointsLabel}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="#FF2F66C7" />
                                                    <TextBlock Grid.Row="2"
                                                               Margin="0,3,0,0"
                                                               Text="Disponibili"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Row="2"
                                                               Grid.Column="1"
                                                               Margin="0,3,0,0"
                                                               Text="{Binding TotalAvailablePointsLabel}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="#FF2F66C7" />
                                                    <TextBlock Grid.Row="3"
                                                               Margin="0,3,0,0"
                                                               Text="Soglia"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Row="3"
                                                               Grid.Column="1"
                                                               Margin="0,3,0,0"
                                                               Text="{Binding RequiredPointsLabel}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                </Grid>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Padding="8,6"
                                                            CornerRadius="6"
                                                            Background="#FFF8FBFE"
                                                            BorderBrush="#FFD9E4F2"
                                                            BorderThickness="1">
                                                        <StackPanel>
                                                            <TextBlock Text="Regola"
                                                                       FontSize="10"
                                                                       FontWeight="Bold"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                            <TextBlock Margin="0,3,0,0"
                                                                       Text="{Binding SelectedRuleDisplayName}"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Column="2"
                                                            Padding="8,6"
                                                            CornerRadius="6"
                                                            Background="#FFF8FBFE"
                                                            BorderBrush="#FFD9E4F2"
                                                            BorderThickness="1">
                                                        <StackPanel>
                                                            <TextBlock Text="Stato promo"
                                                                       FontSize="10"
                                                                       FontWeight="Bold"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                            <TextBlock Margin="0,3,0,0"
                                                                       Text="{Binding RewardStatusLabel}"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Margin="0,2,0,0"
                                                                       Text="{Binding RewardDistanceLabel}"
                                                                       FontSize="9"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Grid>
                        </Expander>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Colonna destra -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Dettaglio campagna Punti -->
                    <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,8" ClipToBounds="True">
                        <StackPanel>
                            <Border Style="{StaticResource PanelHeaderStyle}">
                                <TextBlock Text="Dettaglio campagna Punti" Style="{StaticResource SectionTitleStyle}" />
                            </Border>

                            <Border Margin="10,8,10,10"
                                    Padding="10,8"
                                    BorderBrush="{StaticResource BorderBrushBase}"
                                    BorderThickness="1"
                                    Background="#FFFCFCFD">
                                <Grid DataContext="{Binding EditedCampaign}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="78" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="68" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Riga 0: Nome campagna | Data inizio | Data fine -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome campagna" Style="{StaticResource OfficeFormLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             Text="{Binding NomeOperazione, UpdateSourceTrigger=PropertyChanged}"
                                             Height="30" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Data inizio" Style="{StaticResource OfficeFormLabelStyle}" />
                                    <DatePicker Grid.Row="0" Grid.Column="4"
                                                SelectedDate="{Binding Inizio, Mode=TwoWay}"
                                                Height="30" />
                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Data fine" Style="{StaticResource OfficeFormLabelStyle}" />
                                    <DatePicker Grid.Row="0" Grid.Column="7"
                                                SelectedDate="{Binding Fine, Mode=TwoWay}"
                                                Height="30" />

                                    <!-- Riga 2: Euro/punto | Importo min | Attiva | Base calcolo | IVA inclusa â€” tutto in linea -->
                                    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="Euro per punto" Style="{StaticResource OfficeFormLabelStyle}" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding EuroPerPunto, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30" />

                                        <TextBlock Grid.Column="3" Text="Importo minimo" Style="{StaticResource OfficeFormLabelStyle}" />
                                        <TextBox Grid.Column="4"
                                                 Text="{Binding ImportoMinimo, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30" />

                                        <Border Grid.Column="6" Height="30"
                                                CornerRadius="4" Background="#FFF8FAFD"
                                                BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                                                Padding="8,0">
                                            <CheckBox IsChecked="{Binding Attiva, Mode=TwoWay}"
                                                      Content="Attiva" VerticalAlignment="Center" />
                                        </Border>

                                        <TextBlock Grid.Column="8" Text="Base calcolo" Style="{StaticResource OfficeFormLabelStyle}" />
                                        <ComboBox Grid.Column="9"
                                                  ItemsSource="{Binding DataContext.BaseCalculationOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding DataContext.SelectedBaseCalculation, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Height="30" />

                                        <Border Grid.Column="11" Height="30"
                                                CornerRadius="4" Background="#FFF8FAFD"
                                                BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                                                Padding="8,0">
                                            <CheckBox IsChecked="{Binding CalcolaSuValoreIva, Mode=TwoWay}"
                                                      Content="IVA inclusa" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Regole Premio -->
                    <Border Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                        <StackPanel>
                            <Border Style="{StaticResource PanelHeaderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Regole Premio" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />

                                </Grid>
                            </Border>

                            <DataGrid x:Name="RewardRulesGrid"
                                      Margin="10,8,10,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      ItemsSource="{Binding RewardRules}"
                                      SelectedItem="{Binding SelectedRewardRule, Mode=TwoWay}"
                                      RowStyle="{StaticResource RewardGridRowStyle}"
                                      ColumnHeaderStyle="{StaticResource RewardGridHeaderStyle}"
                                      CellStyle="{StaticResource RewardGridCellStyle}"
                                      AlternationCount="2"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#FFE4EBF3"
                                      Background="#FFFBFDFF"
                                      BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                                      MinHeight="120"
                                      RowHeight="28"
                                      ColumnHeaderHeight="28"
                                      RowDetailsVisibilityMode="VisibleWhenSelected">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="34">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="Sel"
                                                       HorizontalAlignment="Center" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Loaded="RewardRuleSelectionCheckBox_OnLoaded"
                                                          Checked="RewardRuleSelectionCheckBox_OnChecked"
                                                          Unchecked="RewardRuleSelectionCheckBox_OnUnchecked"
                                                          PreviewMouseLeftButtonDown="RewardRuleSelectionCheckBox_OnPreviewMouseLeftButtonDown" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Regola" Binding="{Binding RuleName}" Width="*" />
                                    <DataGridTextColumn Header="Tipo Premio" Binding="{Binding RewardTypeLabel}" Width="120" />
                                    <DataGridTextColumn Header="Punti" Binding="{Binding RequiredPoints}" Width="60" />
                                    <DataGridTextColumn Header="Premio" Binding="{Binding RewardDescription}" Width="200" />
                                    <DataGridTextColumn Header="Stato" Binding="{Binding StateLabel}" Width="66" />
                                    <DataGridCheckBoxColumn Header="Ctrl" Binding="{Binding EnableSaleCheck}" Width="46" />
                                </DataGrid.Columns>

                                <DataGrid.RowDetailsTemplate>
                                    <DataTemplate>
                                        <Border Margin="8,0,8,8"
                                                Padding="0"
                                                CornerRadius="8"
                                                BorderBrush="#FFDCE8D3"
                                                BorderThickness="1"
                                                Background="#FFFFFFFF"
                                                ClipToBounds="True">
                                            <StackPanel>
                                                <Border Padding="10,7"
                                                        BorderBrush="#FFDCE8D3"
                                                        BorderThickness="0,0,0,1"
                                                        Background="{StaticResource EditorAccentBrush}">
                                                    <TextBlock Text="Editor integrato della regola selezionata"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                </Border>

                                                <Border Margin="10,8,10,0"
                                                        Padding="8,7"
                                                        BorderBrush="{StaticResource BorderBrushBase}"
                                                        BorderThickness="1"
                                                        Background="#FFFCFCFD">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="88" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="44" />
                                                            <ColumnDefinition Width="74" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="88" />
                                                            <ColumnDefinition Width="360" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="82" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="98" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0" Text="Nome regola" Style="{StaticResource OfficeFormLabelStyle}" />
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding DataContext.EditedRuleName, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                                                 Height="30" />

                                                        <TextBlock Grid.Column="3" Text="Punti" Style="{StaticResource OfficeFormLabelStyle}" />
                                                        <TextBox Grid.Column="4"
                                                                 Text="{Binding DataContext.EditedRuleRequiredPoints, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                                                 Height="30" />

                                                        <TextBlock Grid.Column="6" Text="Tipo premio" Style="{StaticResource OfficeFormLabelStyle}" />
                                                        <controls:InlineLookupPicker Grid.Column="7"
                                                                                     Width="360"
                                                                                     DisplayText="{Binding DataContext.SelectedRewardTypeLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                     SearchText="{Binding DataContext.RewardTypePickerSearchText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     ItemsSource="{Binding DataContext.FilteredRewardTypeOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                     SelectedItem="{Binding DataContext.SelectedRewardTypeOption, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                                                                     SearchPlaceholderText="Filtra tipo premio"
                                                                                     EmptyText="Nessun tipo premio trovato." />

                                                        <Border Grid.Column="9"
                                                                Height="30"
                                                                CornerRadius="4"
                                                                Background="#FFF8FAFD"
                                                                BorderBrush="{StaticResource BorderBrushBase}"
                                                                BorderThickness="1"
                                                                Padding="6,0">
                                                            <CheckBox IsChecked="{Binding DataContext.EditedRuleActive, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                                                      Content="Attiva"
                                                                      VerticalAlignment="Center" />
                                                        </Border>

                                                        <Border Grid.Column="11"
                                                                Height="30"
                                                                CornerRadius="4"
                                                                Background="#FFF8FAFD"
                                                                BorderBrush="{StaticResource BorderBrushBase}"
                                                                BorderThickness="1"
                                                                Padding="6,0">
                                                            <CheckBox IsChecked="{Binding DataContext.EditedRuleEnableSaleCheck, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                                                      Content="Controllo"
                                                                      VerticalAlignment="Center" />
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <Grid Margin="10,8,10,0">
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.SelectedRuleIsFixedDiscount, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.SelectedRuleIsPercentDiscount, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="170" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="170" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="SCONTO FISSO (EUR)" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox Text="{Binding DataContext.EditedRuleDiscountAmount, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                                                 Height="30" Width="160" HorizontalAlignment="Left" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="SCONTO PERCENTUALE (%)" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox Text="{Binding DataContext.EditedRuleDiscountPercent, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                                                 Height="30" Width="160" HorizontalAlignment="Left" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="10,8,10,0">
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.SelectedRuleIsArticleReward, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>

                                                    <Border Padding="8,7"
                                                            CornerRadius="8"
                                                            Background="#FFF7FBF4"
                                                            BorderBrush="#FFD6E7C9"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="2.15*" />
                                                                <ColumnDefinition Width="10" />
                                                                <ColumnDefinition Width="1.55*" />
                                                                <ColumnDefinition Width="10" />
                                                                <ColumnDefinition Width="66" />
                                                                <ColumnDefinition Width="10" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="RICERCA ARTICOLO PREMIO" Style="{StaticResource FieldLabelStyle}" />
                                                                <TextBox Text="{Binding DataContext.RewardArticleSearchText, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                                                         Height="30"
                                                                         VerticalContentAlignment="Center"
                                                                         ToolTip="Scrivi per aprire la lista di conferma articolo premio." />

                                                                <ListView Margin="0,6,0,0"
                                                                          ItemsSource="{Binding DataContext.RewardArticleResults, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                          SelectedItem="{Binding DataContext.SelectedRewardArticleSearchResult, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                                                          MaxHeight="170"
                                                                          BorderBrush="{StaticResource BorderBrushBase}"
                                                                          BorderThickness="1"
                                                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                                    <ListView.Style>
                                                                        <Style TargetType="ListView">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding DataContext.RewardArticleSearchText, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding DataContext.RewardArticleSearchText, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </ListView.Style>
                                                                    <ListView.ItemContainerStyle>
                                                                        <Style TargetType="ListViewItem">
                                                                            <Setter Property="Padding" Value="8,6" />
                                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                                        </Style>
                                                                    </ListView.ItemContainerStyle>
                                                                    <ListView.View>
                                                                        <GridView AllowsColumnReorder="False">
                                                                            <GridViewColumn Width="105" Header="Codice" DisplayMemberBinding="{Binding CodiceArticolo}" />
                                                                            <GridViewColumn Width="320" Header="Descrizione" DisplayMemberBinding="{Binding Descrizione}" />
                                                                            <GridViewColumn Width="70" Header="Giac." DisplayMemberBinding="{Binding Giacenza}" />
                                                                        </GridView>
                                                                    </ListView.View>
                                                                </ListView>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2">
                                                                <DockPanel LastChildFill="True" Margin="0,0,0,3">
                                                                    <TextBlock DockPanel.Dock="Left"
                                                                               Text="ARTICOLO PREMIO"
                                                                               Style="{StaticResource FieldLabelStyle}"
                                                                               Margin="0" />
                                                                    <TextBlock DockPanel.Dock="Right"
                                                                               Margin="10,0,0,0"
                                                                               VerticalAlignment="Center"
                                                                               Text="Seleziona una riga per il premio"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </DockPanel>
                                                                <Border Height="30"
                                                                        CornerRadius="6"
                                                                        Background="#FFFFFFFF"
                                                                        BorderBrush="{StaticResource BorderBrushBase}"
                                                                        BorderThickness="1"
                                                                        Padding="8,0">
                                                                    <TextBlock Text="{Binding DataContext.SelectedRewardArticleLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               VerticalAlignment="Center"
                                                                               TextWrapping="NoWrap"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </Border>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="4">
                                                                <TextBlock Text="QTA" Style="{StaticResource FieldLabelStyle}" />
                                                                <TextBox Text="{Binding DataContext.EditedRuleRewardQuantity, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                                                         Height="30" Width="66" HorizontalAlignment="Left" />
                                                            </StackPanel>

                                                            <Button Grid.Column="6"
                                                                    Content="Rimuovi"
                                                                    Command="{Binding DataContext.ClearRewardArticleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="10,5"
                                                                    Height="30"
                                                                    VerticalAlignment="Top" />
                                                        </Grid>
                                                    </Border>
                                                </Grid>

                                                <Expander Margin="10,8,10,10"
                                                          IsExpanded="False">
                                                    <Expander.Header>
                                                        <TextBlock Text="Note operative" FontSize="11" FontWeight="Bold" />
                                                    </Expander.Header>
                                                    <TextBox Margin="0,6,0,0"
                                                             MinHeight="60"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             VerticalContentAlignment="Top"
                                                             Padding="8,6"
                                                             Text="{Binding DataContext.EditedRuleNotes, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                                </Expander>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGrid.RowDetailsTemplate>
                            </DataGrid>

                            <controls:CompactGridCommandBar Margin="10,0,10,0"
                                                            SummaryText="{Binding RewardRulesSummary}"
                                                            NewCommand="{Binding AddRewardRuleCommand}"
                                                            EditCommand="{Binding EditRewardRuleCommand}"
                                                            SaveCommand="{Binding SaveCampaignCommand}"
                                                            CancelCommand="{Binding CancelCampaignCommand}"
                                                            DuplicateCommand="{Binding DuplicateRewardRuleCommand}"
                                                            DeleteCommand="{Binding DeleteRewardRuleCommand}" />

                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,8,0,0" ClipToBounds="True">
                        <StackPanel>
                            <Border Style="{StaticResource PanelHeaderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Storico fidelity" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Text="{Binding FidelityHistorySummaryLabel}"
                                                   Style="{StaticResource SectionHintStyle}" />
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center">
                                        <Button Content="Aggiorna storico"
                                                Command="{Binding RefreshFidelityHistoryCommand}"
                                                Style="{StaticResource FidelityRefreshButtonStyle}" />
                                        <Button Content="Apri storico fidelity"
                                                Click="OpenFidelityHistoryWindow_OnClick"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="12,6"
                                                Margin="0"
                                                VerticalAlignment="Center" />
                                    </WrapPanel>
                                </Grid>
                            </Border>

                            <Grid Margin="10,8,10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.3*" />
                                    <ColumnDefinition Width="0.7*" />
                                    <ColumnDefinition Width="0.7*" />
                                    <ColumnDefinition Width="0.7*" />
                                    <ColumnDefinition Width="0.7*" />
                                </Grid.ColumnDefinitions>

                                <Border Margin="0,0,6,0" Padding="8,6" CornerRadius="6"
                                        Background="#FFF8FAFD" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Carta fidelity" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{Binding FidelityCardCodeLabel}" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Margin="0,0,6,0" Padding="8,6" CornerRadius="6"
                                        Background="#FFF8FAFD" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Iniziali" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{Binding FidelityInitialPointsLabel}" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Margin="0,0,6,0" Padding="8,6" CornerRadius="6"
                                        Background="#FFF8FAFD" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Legacy corrente" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{Binding FidelityLegacyCurrentPointsLabel}" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Margin="0,0,6,0" Padding="8,6" CornerRadius="6"
                                        Background="#FFF4FAF1" BorderBrush="#FFD6E7C9" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Ricalcolato" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{Binding FidelityComputedCurrentPointsLabel}" FontSize="12" FontWeight="SemiBold" Foreground="#FF2E6B3E" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4" Padding="8,6" CornerRadius="6"
                                        Background="#FFFFF7F3" BorderBrush="#FFE8D5C8" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Delta" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{Binding FidelityDeltaPointsLabel}" FontSize="12" FontWeight="SemiBold" Foreground="#FF9A5A1A" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Barra di stato -->
        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Padding="12,7"
                CornerRadius="6"
                BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                Background="#FFFFFFFF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Ellipse Width="7" Height="7" Fill="#FF5BA642" VerticalAlignment="Center" Margin="0,0,7,0" />
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           FontSize="11" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
