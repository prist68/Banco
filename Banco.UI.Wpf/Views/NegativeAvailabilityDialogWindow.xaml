<Window x:Class="Banco.UI.Wpf.Views.NegativeAvailabilityDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="520"
        MaxWidth="680"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Background="{DynamicResource ModalOverlayBrush}">
        <Border Width="654"
                Margin="24"
                Padding="22"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushBase}"
                BorderThickness="1"
                CornerRadius="16" Height="372">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True">
                    <TextBlock Text="{Binding Eyebrow, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Width="28"
                            Height="28"
                            Margin="12,0,0,0"
                            Click="CloseButton_OnClick"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Chiudi">
                        <Border Background="{DynamicResource ModalChromeBrush}"
                                BorderBrush="{StaticResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="7">
                            <TextBlock Text="✕"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Button>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        BorderBrush="{DynamicResource ModalAccentBorderBrush}"
                        BorderThickness="4,0,0,0"
                        Padding="14,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding DialogTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding DialogMessage, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="13.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,18,0,0"
                        Padding="14,12"
                        Background="{DynamicResource ModalInfoSurfaceBrush}"
                        BorderBrush="{DynamicResource ModalInfoBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="{Binding ArticleLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="13.5"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding HighlightText, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                               Foreground="{DynamicResource ModalInfoForegroundBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="12.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap">
                            <Run Text="Vendi e aggiungi a lista: la riga resta articolo ufficiale e viene segnata subito per il riordino locale. " />
                            <Run Text="Scarica comunque: la riga resta articolo ufficiale con codice. " />
                            <Run Text="Riga manuale: Banco inserisce la descrizione senza codice articolo e senza legame anagrafico." />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3"
                            Margin="0,22,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Annulla"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="104"
                            Margin="0,0,10,0"
                            IsCancel="True"
                            Click="CancelButton_OnClick" Width="80" />
                    <Button Content="Riga manuale"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="124"
                            Margin="0,0,10,0"
                            Click="ManualButton_OnClick" Width="57" />
                    <Button x:Name="AddToReorderButton"
                            Content="Vendi e aggiungi a lista"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="190"
                            Margin="0,0,10,0"
                            Click="AddToReorderButton_OnClick" Height="40" />
                    <Button x:Name="ForceButton"
                            Content="Scarica comunque"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="144"
                            Click="ForceButton_OnClick" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
