<UserControl x:Class="Banco.UI.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SettingsFormTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="{Binding Titolo}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="Connessione gestionale, supporto tecnico e percorsi legacy del programma." />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- DB Gestionale Card -->
            <Border Style="{StaticResource CardStyle}"
                    Background="{StaticResource WindowBackgroundBrush}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconDatabase}"
                              Fill="{StaticResource TextPrimaryBrush}"
                              Width="18" Height="18" Stretch="Uniform"
                              VerticalAlignment="Center" />
                        <TextBlock Margin="10,0,0,0" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Text="DB gestionale" />
                    </StackPanel>

                    <TextBlock Margin="0,18,0,0" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Text="Host" />
                    <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingsFormTextBoxStyle}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Lascia vuoto per usare il DB locale del server (127.0.0.1). Sulle postazioni client inserisci l'IP del server, ad esempio 192.168.1.111." />

                    <TextBlock FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Text="Porta" />
                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingsFormTextBoxStyle}" />

                    <TextBlock FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Text="Database" />
                    <TextBox Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingsFormTextBoxStyle}" />

                    <TextBlock FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Text="Utente" />
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingsFormTextBoxStyle}" />

                    <TextBlock FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Text="Password" />
                    <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingsFormTextBoxStyle}" />
                </StackPanel>
            </Border>

            <!-- Archivio Locale Card -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}"
                    Background="{StaticResource WindowBackgroundBrush}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconFolder}"
                              Fill="{StaticResource TextPrimaryBrush}"
                              Width="18" Height="18" Stretch="Uniform"
                              VerticalAlignment="Center" />
                        <TextBlock Margin="10,0,0,0" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Text="Supporto tecnico" />
                    </StackPanel>

                    <TextBlock Margin="0,18,0,0" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Text="Cartella base" />
                    <TextBox Text="{Binding LocalStoreDirectory, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingsFormTextBoxStyle}" />

                    <Border Margin="0,12,0,0"
                            Background="{StaticResource SurfaceAltBrush}"
                            CornerRadius="8" Padding="12">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconInfo}"
                                  Fill="{StaticResource TextMutedBrush}"
                                  Width="16" Height="16" Stretch="Uniform"
                                  VerticalAlignment="Top" Margin="0,2,0,0" />
                            <TextBlock Margin="10,0,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" TextWrapping="Wrap"
                                       Text="Nel bootstrap viene inizializzato un database SQLite con tabelle tecniche di supporto e audit." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Contenuti FM Card -->
            <Border Grid.Row="2"
                    Grid.ColumnSpan="3"
                    Style="{StaticResource CardStyle}"
                    Background="{StaticResource WindowBackgroundBrush}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconFolder}"
                              Fill="{StaticResource TextPrimaryBrush}"
                              Width="18" Height="18" Stretch="Uniform"
                              VerticalAlignment="Center" />
                        <TextBlock Margin="10,0,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Text="Percorsi FM" />
                    </StackPanel>

                    <TextBlock Margin="0,12,0,0"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Configura la radice contenuti del gestionale e la cartella che contiene le immagini articoli usate da Banco." />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Radice contenuti FM" />
                            <TextBox Text="{Binding FmRootDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsFormTextBoxStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Usa la cartella principale tipo C:\Facile Manager\DILTECH se vuoi centralizzare i contenuti legacy in un solo punto." />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Cartella immagini articoli" />
                            <TextBox Text="{Binding FmArticleImagesDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsFormTextBoxStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Se la lasci vuota o la riallinei alla radice FM, Banco userà la cartella immagini collegata alla struttura DILTECH." />
                        </StackPanel>
                    </Grid>

                    <Border Margin="0,16,0,0"
                            Background="{StaticResource SurfaceAltBrush}"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel>
                            <TextBlock FontSize="12.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Percorso effettivo immagini articoli" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="13"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding FmArticleImagesResolvedPath}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4">
            <WrapPanel>
                <Button Content="Salva configurazione"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Content="Test connessione"
                        Command="{Binding TestConnectionCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </WrapPanel>

            <TextBlock Margin="0,12,0,0"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="{Binding StatusMessage}" />
        </StackPanel>
    </Grid>
</UserControl>
