<Window x:Class="Banco.UI.Wpf.Views.Pos80PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anteprima POS80"
        Width="980"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="14,12"
                Background="#FFF7FAFE"
                BorderBrush="#FFD8E3F0"
                BorderThickness="1"
                CornerRadius="12">
            <DockPanel LastChildFill="True">
                <StackPanel>
                    <TextBlock Text="Anteprima POS80"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding PreviewPath, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="96"
                            Margin="0,0,10,0"
                            Click="RefreshButton_OnClick"
                            Content="Aggiorna" />
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="88"
                            Margin="0"
                            Click="CloseButton_OnClick"
                            Content="Chiudi" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#FFD8E3F0"
                BorderThickness="1"
                CornerRadius="12"
                ClipToBounds="True">
            <WebBrowser x:Name="PreviewBrowser" />
        </Border>
    </Grid>
</Window>
