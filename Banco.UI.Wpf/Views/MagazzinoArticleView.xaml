<UserControl x:Class="Banco.UI.Wpf.Views.MagazzinoArticleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:input="clr-namespace:Banco.UI.Wpf.Infrastructure.Input">
    <UserControl.InputBindings>
        <KeyBinding Key="F4"
                    Command="{Binding PasteLocalSettingsCommand}" />
    </UserControl.InputBindings>
    <UserControl.Resources>
        <Style x:Key="SectionBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
        <Style x:Key="CompactLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="CompactFieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="BorderBrush" Value="#D6E2EF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardStyle}"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Text="Articolo magazzino" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding StatusMessage}" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Style="{StaticResource CompactLabelStyle}"
                               Text="Ricerca live articolo o barcode" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             input:TextBoxPlaceholderService.Placeholder="Scansione barcode o ricerca manuale"
                             VerticalContentAlignment="Center"
                             Padding="10,7"
                             MinHeight="36" />
                </StackPanel>

                <Border Grid.Row="4"
                        BorderBrush="{StaticResource BorderBrushBase}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Background="{StaticResource SurfaceAltBrush}">
                    <ListBox ItemsSource="{Binding SearchRows}"
                             SelectedItem="{Binding SelectedSearchRow, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,0,0">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11.5"
                                                   Text="{Binding Subtitle}" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Padding="8,2"
                                            CornerRadius="8"
                                            Background="#FFF2F7FF"
                                            BorderBrush="#D7E4F3"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding QuantityLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Border>

                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Margin" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChild}" Value="True">
                                                    <Setter Property="Margin" Value="18,0,0,0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,6" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="BorderBrush" Value="#FFE5ECF4" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="FontSize" Value="12.5" />
                                <Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                        <Setter Property="Background" Value="#FFF6FAFF" />
                                    </DataTrigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FFEAF3FF" />
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Style="{StaticResource CardStyle}"
                Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <StackPanel>
                            <TextBlock FontSize="17"
                                       FontWeight="SemiBold"
                                       Text="{Binding CodiceArticolo}" />
                            <TextBlock Margin="0,3,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding DescrizioneArticolo}" />
                        </StackPanel>

                        <WrapPanel DockPanel.Dock="Right"
                                   VerticalAlignment="Top">
                            <Button Content="Aggiorna legacy"
                                    Command="{Binding RefreshCurrentArticleCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="Salva legacy"
                                    Command="{Binding SaveLegacyCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="Salva locale"
                                    Command="{Binding SaveLocalSettingsCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0" />
                        </WrapPanel>
                    </DockPanel>

                    <TextBlock Margin="0,10,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontWeight="SemiBold"
                               Text="Dati legacy articolo" />
                    <Border Style="{StaticResource SectionBadgeStyle}"
                            HorizontalAlignment="Left"
                            Background="#FFFCE8D9"
                            BorderBrush="#F0B77B"
                            BorderThickness="1">
                        <TextBlock Foreground="#A45712"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Text="* LEGACY" />
                    </Border>

                    <UniformGrid Margin="0,8,0,0"
                                 Columns="2">
                        <Border Margin="0,0,8,8" Padding="10" CornerRadius="10" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CompactLabelStyle}" Text="Articolo OID" />
                                <TextBlock FontWeight="SemiBold" Text="{Binding ArticoloOid}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,0,8" Padding="10" CornerRadius="10" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CompactLabelStyle}" Text="Giacenza" />
                                <TextBlock FontWeight="SemiBold" Text="{Binding GiacenzaLabel}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,8,8" Padding="10" CornerRadius="10" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CompactLabelStyle}" Text="Prezzo vendita" />
                                <TextBox Margin="0"
                                         Style="{StaticResource CompactFieldTextBoxStyle}"
                                         Text="{Binding PrezzoVenditaLegacyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,0,8" Padding="10" CornerRadius="10" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CompactLabelStyle}" Text="Ultimo acquisto" />
                                <TextBlock FontWeight="SemiBold" Text="{Binding UltimoAcquistoLabel}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,8,8" Padding="10" CornerRadius="10" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CompactLabelStyle}" Text="U.M. principale" />
                                <TextBox Margin="0"
                                         Style="{StaticResource CompactFieldTextBoxStyle}"
                                         Text="{Binding UnitaPrincipaleLegacyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,0,8" Padding="10" CornerRadius="10" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CompactLabelStyle}" Text="U.M. secondaria" />
                                <TextBox Margin="0"
                                         Style="{StaticResource CompactFieldTextBoxStyle}"
                                         Text="{Binding UnitaSecondariaLegacyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,8,8" Padding="10" CornerRadius="10" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CompactLabelStyle}" Text="Rapporto U.M." />
                                <TextBox Margin="0"
                                         Style="{StaticResource CompactFieldTextBoxStyle}"
                                         Text="{Binding RapportoUnitaLegacyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,0,8" Padding="10" CornerRadius="10" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CompactLabelStyle}" Text="Vendita minima / multipla" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Margin="0"
                                             Style="{StaticResource CompactFieldTextBoxStyle}"
                                             Text="{Binding QuantitaMinimaVenditaLegacyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Text="/" />
                                    <TextBox Grid.Column="2"
                                             Margin="0"
                                             Style="{StaticResource CompactFieldTextBoxStyle}"
                                             Text="{Binding QuantitaMultiplaVenditaLegacyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Margin="0,0,0,8"
                            Padding="10"
                            CornerRadius="10"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushBase}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CompactLabelStyle}" Text="Descrizione articolo" />
                            <TextBox Margin="0"
                                     Style="{StaticResource CompactFieldTextBoxStyle}"
                                     Text="{Binding DescrizioneLegacyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <TextBlock Margin="0,10,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontWeight="SemiBold"
                               Text="Parametri locali riordino" />
                    <Border Style="{StaticResource SectionBadgeStyle}"
                            HorizontalAlignment="Left"
                            Background="#FFEAF6EB"
                            BorderBrush="#9ECEAC"
                            BorderThickness="1">
                        <TextBlock Foreground="#246848"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Text="SQLITE INTERNO" />
                    </Border>
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding LocalSettingsInfo}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding LocalSettingsScopeInfo}" />

                    <WrapPanel Margin="0,8,0,0"
                               HorizontalAlignment="Right">
                        <Button Content="Applica ai figli"
                                Command="{Binding ApplyLocalSettingsToChildrenCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Copia locale"
                                Command="{Binding CopyLocalSettingsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="8,0,0,0" />
                        <Button Content="Incolla locale (F4)"
                                Command="{Binding PasteLocalSettingsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="8,0,0,0" />
                    </WrapPanel>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Margin="0,0,10,8" VerticalAlignment="Center" Text="Acquisto a confezione" />
                        <CheckBox Grid.Column="1" Margin="0,0,0,8" VerticalAlignment="Center" IsChecked="{Binding AcquistoAConfezione, Mode=TwoWay}" />

                        <TextBlock Grid.Row="1" Margin="0,0,10,8" VerticalAlignment="Center" Text="Vendita a pezzo singolo" />
                        <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" VerticalAlignment="Center" IsChecked="{Binding VenditaAPezzoSingolo, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2" Margin="0,0,10,8" VerticalAlignment="Center" Text="Pezzi per confezione" />
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Style="{StaticResource CompactFieldTextBoxStyle}" Text="{Binding PezziPerConfezioneText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3" Margin="0,0,10,8" VerticalAlignment="Center" Text="Multiplo ordine" />
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Style="{StaticResource CompactFieldTextBoxStyle}" input:TextBoxPlaceholderService.Placeholder="Vuoto = 1" Text="{Binding MultiploOrdineText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4" Margin="0,0,10,8" VerticalAlignment="Center" Text="Lotto minimo ordine" />
                        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" Style="{StaticResource CompactFieldTextBoxStyle}" Text="{Binding LottoMinimoText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="5" Margin="0,0,10,8" VerticalAlignment="Center" Text="Giorni copertura default" />
                        <TextBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,8" Style="{StaticResource CompactFieldTextBoxStyle}" Text="{Binding GiorniCoperturaText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="6" Margin="0,2,10,0" VerticalAlignment="Top" Text="Note locali" />
                        <TextBox Grid.Row="6" Grid.Column="1" MinHeight="78" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Style="{StaticResource CompactFieldTextBoxStyle}" Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
