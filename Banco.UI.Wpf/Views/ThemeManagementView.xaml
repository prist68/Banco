<UserControl x:Class="Banco.UI.Wpf.Views.ThemeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock FontSize="22"
                   FontWeight="SemiBold"
                   Text="{Binding Titolo}" />
        <TextBlock Margin="0,6,0,0"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Text="{Binding Descrizione}" />

        <Border Margin="0,18,0,0"
                Style="{StaticResource CardStyle}"
                Background="{StaticResource WindowBackgroundBrush}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconSettings}"
                          Fill="{StaticResource TextPrimaryBrush}"
                          Width="18" Height="18" Stretch="Uniform"
                          VerticalAlignment="Center" />
                    <TextBlock Margin="10,0,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Text="Tema applicativo" />
                </StackPanel>

                <Border Margin="0,14,0,0"
                        Background="{StaticResource SurfaceAltBrush}"
                        CornerRadius="8"
                        Padding="12">
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="Modulo pronto per l'integrazione del file XML di tema. In questa fase viene esposta la sezione di navigazione e il contenitore UI." />
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
