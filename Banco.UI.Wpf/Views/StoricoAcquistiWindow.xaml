<Window x:Class="Banco.UI.Wpf.Views.StoricoAcquistiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Banco.UI.Wpf.ViewModels"
        xmlns:views="clr-namespace:Banco.UI.Wpf.Views"
        Title="{Binding TitoloFinestra}"
        Width="960" Height="660"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Window.InputBindings>
        <KeyBinding Key="Return" Command="{Binding CercaCommand}" />
    </Window.InputBindings>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="20"
                   FontWeight="Bold"
                   Text="{Binding TitoloFinestra}" />

        <Border Grid.Row="2"
                Background="#FFFFFFFF"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Effect="{StaticResource SubtleShadow}"
                Padding="14,10">
            <WrapPanel Orientation="Horizontal"
                       VerticalAlignment="Center">
                <views:DateRangeFilterBar Height="36" Loaded="DateRangeFilterBar_Loaded" />

                <StackPanel Orientation="Horizontal" Margin="12,0,14,4">
                    <TextBlock Text="Articolo:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBox Text="{Binding FiltroArticolo, UpdateSourceTrigger=PropertyChanged}"
                             Width="160"
                             FontSize="13"
                             Padding="7,5"
                             Margin="0"
                             VerticalContentAlignment="Center" Height="33" />
                </StackPanel>

                <Button Content="Reset"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ResetFiltriCommand}"
                        Padding="14,7"
                        FontSize="13" Height="32" />
            </WrapPanel>
        </Border>

        <Border Grid.Row="4"
                Background="#FFFFFFFF"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Effect="{StaticResource SubtleShadow}"
                Padding="0"
                ClipToBounds="True">
            <Grid>
                <DataGrid x:Name="StoricoGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          ItemsSource="{Binding Documenti}"
                          SelectedItem="{Binding DocumentoSelezionato, Mode=TwoWay}"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          FontSize="14"
                          RowHeight="34"
                          AlternationCount="2"
                          AlternatingRowBackground="#FFF5F7FA"
                          RowBackground="#FFFFFFFF"
                          Background="{StaticResource SurfaceBrush}"
                          BorderThickness="0"
                          RowDetailsVisibilityMode="VisibleWhenSelected">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Padding" Value="10,8" />
                            <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFE3EDFA" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFEDF2F9" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="10,0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DOCUMENTO" Binding="{Binding DocumentoLabel}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="DATA" Binding="{Binding Data, StringFormat=dd/MM/yyyy}" Width="100" />
                        <DataGridTextColumn Header="ORA" Binding="{Binding OraVenditaLabel}" Width="60" />
                        <DataGridTextColumn Header="OPERATORE" Binding="{Binding Operatore}" Width="100" />
                        <DataGridTextColumn Header="TOTALE" Binding="{Binding TotaleDocumento, StringFormat={}{0:N2} €}" Width="120" />
                        <DataGridTextColumn Header="STATO" Binding="{Binding StatoLabel}" Width="*" />
                    </DataGrid.Columns>

                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate DataType="{x:Type viewModels:StoricoDocumentoItem}">
                            <Border Background="#FFF8FAFD"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="0,1,0,1"
                                    Padding="20,10,20,14"
                                    Margin="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock FontSize="12.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="Righe documento" />

                                    <TextBlock Grid.Row="2"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Caricamento righe...">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCaricamentoDettaglio}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ItemsControl Grid.Row="2"
                                                  ItemsSource="{Binding Righe}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCaricamentoDettaglio}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="100" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding CodiceArticolo}"
                                                               FontSize="12.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Descrizione}"
                                                               FontSize="12.5"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Quantita, StringFormat={}{0:N2}}"
                                                               FontSize="12.5"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Right" />
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding PrezzoUnitario, StringFormat={}{0:N2} €}"
                                                               FontSize="12.5"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Right" />
                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding ImportoRiga, StringFormat={}{0:N2} €}"
                                                               FontSize="12.5"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Right" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
