<Window x:Class="Banco.UI.Wpf.Views.ArticleImageManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Banco.Magazzino.ViewModels;assembly=Banco.Magazzino"
        xmlns:conv="clr-namespace:Banco.UI.Wpf.Converters"
        xmlns:controls="clr-namespace:Banco.UI.Controls;assembly=Banco.UI.Controls"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False"
        SizeToContent="WidthAndHeight"
        MinWidth="980"
        MaxWidth="1100"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Window.Resources>
        <conv:LocalPathToBitmapImageConverter x:Key="LocalPathToBitmapImageConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border Style="{StaticResource ModalOverlayHostStyle}">
        <Border Width="1000"
                Padding="22"
                Style="{StaticResource ModalSurfaceCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           LastChildFill="True"
                           MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                    <TextBlock Text="Banco / gestione immagini"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource ModalHeaderCloseButtonStyle}"
                            Click="CloseButton_OnClick">
                        <Border Style="{StaticResource ModalHeaderCloseChromeStyle}">
                            <TextBlock Text="X"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Button>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        BorderBrush="{DynamicResource ModalAccentBorderBrush}"
                        BorderThickness="4,0,0,0"
                        Padding="14,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Immagini articolo"
                                   FontSize="19"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="ArticleSubtitleTextBlock"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2"
                      Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Aggiungi file..."
                            Style="{StaticResource CompactPrimaryButtonStyle}"
                            MinWidth="120"
                            Click="AddFileButton_OnClick" />

                    <Button Grid.Column="2"
                            Content="Incolla  Ctrl+V"
                            Style="{StaticResource CompactSecondaryButtonStyle}"
                            MinWidth="130"
                            Click="PasteButton_OnClick" />

                    <TextBlock Grid.Column="4"
                               Text="Variante:"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Visibility="{Binding HasVarianteScopePicker, Converter={StaticResource BoolToVis}}" />

                    <controls:InlineLookupPicker Grid.Column="6"
                                                 DisplayText="{Binding SelectedVarianteScopeLabel}"
                                                 SearchText="{Binding VarianteScopePickerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 IsOpen="{Binding IsVarianteScopePickerOpen, Mode=TwoWay}"
                                                 ItemsSource="{Binding FilteredVarianteScopeOptions}"
                                                 SelectedItem="{Binding SelectedVarianteScopeOption, Mode=TwoWay}"
                                                 SearchPlaceholderText="Filtra variante"
                                                 EmptyText="Nessuna variante trovata."
                                                 Visibility="{Binding HasVarianteScopePicker, Converter={StaticResource BoolToVis}}" />
                </Grid>

                <Grid Grid.Row="3"
                      Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               x:Name="StatusTextBlock"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Column="1"
                               Margin="16,0,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Text="{Binding InsertTargetDescription}"
                               Visibility="{Binding HasVarianteScopePicker, Converter={StaticResource BoolToVis}}" />
                </Grid>

                <Border Grid.Row="4"
                        Margin="0,14,0,0"
                        MinHeight="220"
                        MaxHeight="400"
                        Padding="8"
                        Background="{DynamicResource ModalInfoSurfaceBrush}"
                        BorderBrush="{DynamicResource ModalInfoBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        AllowDrop="True"
                        DragOver="ImageArea_OnDragOver"
                        Drop="ImageArea_OnDrop">
                    <Grid>
                        <TextBlock x:Name="EmptyPlaceholder"
                                   Text="Nessuna immagine. Trascina qui i file, incolla dagli appunti (Ctrl+V) o usa 'Aggiungi file...'."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Visibility="Collapsed" />

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ListBox x:Name="ImagesListBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionMode="Single"
                                     SelectionChanged="ImagesListBox_OnSelectionChanged"
                                     KeyDown="ImagesListBox_OnKeyDown"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="6" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ArticleImageItemViewModel}">
                                        <Border Width="130"
                                                Height="154"
                                                CornerRadius="10"
                                                Cursor="Hand">
                                            <Border.ToolTip>
                                                <ToolTip MaxWidth="420"
                                                         Padding="0"
                                                         Background="Transparent"
                                                         BorderThickness="0">
                                                    <Border CornerRadius="8"
                                                            Background="{DynamicResource ModalFieldSurfaceBrush}"
                                                            BorderBrush="{DynamicResource ModalFieldBorderBrush}"
                                                            BorderThickness="1"
                                                            Padding="8">
                                                        <StackPanel>
                                                            <Image Source="{Binding LocalPath, Converter={StaticResource LocalPathToBitmapImageConverter}, ConverterParameter=380}"
                                                                   MaxWidth="380"
                                                                   MaxHeight="380"
                                                                   Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Visibility="{Binding HasLocalFile, Converter={StaticResource BoolToVis}}" />
                                                            <TextBlock Text="{Binding DisplayFileName, StringFormat='File: {0}'}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,6,0,0"
                                                                       MaxWidth="380" />
                                                            <TextBlock Text="{Binding DisplayLocation, StringFormat='Percorso: {0}'}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,2,0,0"
                                                                       MaxWidth="380" />
                                                        </StackPanel>
                                                    </Border>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderThickness" Value="2" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource ModalFieldBorderBrush}" />
                                                    <Setter Property="Background" Value="{DynamicResource ModalFieldSurfaceBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource ModalAccentBorderBrush}" />
                                                            <Setter Property="BorderThickness" Value="2.5" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Predefinita}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#F5A623" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid ClipToBounds="True">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="30" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0"
                                                      Background="{DynamicResource ModalInfoSurfaceBrush}">
                                                    <Image Source="{Binding LocalPath, Converter={StaticResource LocalPathToBitmapImageConverter}, ConverterParameter=180}"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Visibility="{Binding HasLocalFile, Converter={StaticResource BoolToVis}}" />

                                                    <TextBlock Text="file non trovato"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="10.5"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               Padding="6">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasLocalFile}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <Border HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Margin="5"
                                                            Padding="4,2"
                                                            CornerRadius="4"
                                                            Background="#F5A623"
                                                            Visibility="{Binding Predefinita, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="*"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="White" />
                                                    </Border>
                                                </Grid>

                                                <Border Grid.Row="1"
                                                        Padding="6,4"
                                                        Background="{DynamicResource ModalFieldSurfaceBrush}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding BadgeText}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource ModalInfoForegroundBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding DisplayDescription}"
                                                                   FontSize="9.5"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Row="5"
                      Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="SetPredefinitaButton"
                            Content="* Copertina"
                            Style="{StaticResource CompactSecondaryButtonStyle}"
                            MinWidth="110"
                            IsEnabled="False"
                            Click="SetPredefinitaButton_OnClick" />

                    <Button Grid.Column="2"
                            x:Name="MoveUpButton"
                            Content="Su"
                            Style="{StaticResource CompactSecondaryButtonStyle}"
                            MinWidth="60"
                            IsEnabled="False"
                            Click="MoveUpButton_OnClick" />

                    <Button Grid.Column="4"
                            x:Name="MoveDownButton"
                            Content="Giu"
                            Style="{StaticResource CompactSecondaryButtonStyle}"
                            MinWidth="60"
                            IsEnabled="False"
                            Click="MoveDownButton_OnClick" />

                    <TextBlock Grid.Column="6"
                               Text="Sposta in:"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasSelectedImage, Converter={StaticResource BoolToVis}}" />

                    <controls:InlineLookupPicker Grid.Column="8"
                                                 DisplayText="{Binding SelectedMoveTargetLabel}"
                                                 SearchText="{Binding MoveTargetPickerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 IsOpen="{Binding IsMoveTargetPickerOpen, Mode=TwoWay}"
                                                 ItemsSource="{Binding FilteredMoveTargetOptions}"
                                                 SelectedItem="{Binding SelectedMoveTargetOption, Mode=TwoWay}"
                                                 SearchPlaceholderText="Scegli destinazione"
                                                 EmptyText="Nessuna destinazione trovata."
                                                 Visibility="{Binding HasSelectedImage, Converter={StaticResource BoolToVis}}" />

                    <Button Grid.Column="10"
                            x:Name="MoveVariantButton"
                            Content="Sposta"
                            Style="{StaticResource CompactSecondaryButtonStyle}"
                            MinWidth="78"
                            IsEnabled="False"
                            Click="MoveVariantButton_OnClick" />

                    <Button Grid.Column="12"
                            x:Name="RemoveButton"
                            Content="Rimuovi"
                            Style="{StaticResource CompactSecondaryButtonStyle}"
                            MinWidth="88"
                            IsEnabled="False"
                            Click="RemoveButton_OnClick" />

                    <Button Grid.Column="14"
                            Content="Chiudi"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="90"
                            IsCancel="True"
                            Click="CloseButton_OnClick" />
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
