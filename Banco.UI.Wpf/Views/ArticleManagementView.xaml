                                                                   Text="Disponibilità" />
                                                        <TextBox Grid.Column="6"
                                                                 Text="{Binding EcommerceAvailabilityLabel, Mode=OneWay}"
                                                                 Style="{StaticResource OptionCompactTextBoxStyle}"
                                                                 IsReadOnly="True" />
                                                    </Grid>

                                                    <Grid Grid.Row="10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Style="{StaticResource FieldLabelStyle}"
                                                                   Text="Avvertenze" />
                                                        <TextBox Grid.Column="2"
                                                                 Text="{Binding LegacyWarningsLabel, Mode=OneWay}"
                                                                 Style="{StaticResource OptionCompactTextBoxStyle}"
                                                                 IsReadOnly="True" />
                                                    </Grid>

                                                    <Grid Grid.Row="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Style="{StaticResource FieldLabelStyle}"
                                                                   Text="Condizione" />
                                                        <controls:InlineLookupPicker Grid.Column="2"
                                                                                      Style="{StaticResource OptionInlineLookupPickerStyle}"
                                                                                      DisplayText="{Binding SelectedConditionLabel}"
                                                                                      SearchText="{Binding ConditionPickerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                      IsOpen="{Binding IsConditionPickerOpen, Mode=TwoWay}"
                                                                                      ItemsSource="{Binding FilteredConditionOptions}"
                                                                                      SelectedItem="{Binding SelectedConditionOption, Mode=TwoWay}"
                                                                                      SearchPlaceholderText="Filtra condizione"
                                                                                      EmptyText="Nessuna condizione legacy disponibile." />
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Confezione"
                                 Tag="#2E8B57">
                            <Border Margin="8"
                                    Style="{StaticResource SectionBoxStyle}"
                                    Padding="0">
                                <ContentControl x:Name="EmbeddedMagazzinoArticleHost" />
                            </Border>
                        </TabItem>

                        <TabItem Header="Scheda tecnica"
                                 Tag="#C47F1F">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Border Margin="8"
                                        Style="{StaticResource SectionBoxStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Style="{StaticResource SectionCaptionStyle}"
                                                   Text="{Binding SpecificationsStatusText}" />

                                        <ItemsControl Grid.Row="2"
                                                      Margin="0,4,0,0"
                                                      ItemsSource="{Binding Specifications}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,4"
                                                            Padding="8,5"
                                                            Background="{StaticResource SurfaceBrush}"
                                                            BorderBrush="{StaticResource BorderBrushBase}"
                                                            BorderThickness="1"
                                                            CornerRadius="6">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="190" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock FontWeight="SemiBold"
                                                                       Text="{Binding Name}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Margin="8,0,0,0"
                                                                       TextWrapping="Wrap"
                                                                       Text="{Binding Value}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Listini"
                                 Tag="#8E5BBE">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Border Margin="8"
                                        Style="{StaticResource SectionBoxStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Style="{StaticResource SectionCaptionStyle}"
                                                   Text="{Binding PriceTiersStatusText}" />

                                        <DataGrid Grid.Row="2"
                                                  Margin="0,4,0,0"
                                                  ItemsSource="{Binding PriceTierRows}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  CanUserResizeRows="False"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="None"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  RowStyle="{StaticResource CompactDataGridRowStyle}"
                                                  ColumnHeaderStyle="{StaticResource CompactDataGridHeaderStyle}"
                                                  CellStyle="{StaticResource CompactDataGridCellStyle}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Q.ta minima"
                                                                    Width="110"
                                                                    Binding="{Binding QuantitaMinimaLabel}" />
                                                <DataGridTextColumn Header="Prezzo unitario"
                                                                    Width="130"
                                                                    Binding="{Binding PrezzoUnitarioLabel}" />
                                                <DataGridTextColumn Header="Valido fino"
                                                                    Width="120"
                                                                    Binding="{Binding DataFineLabel}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                </TabControl>

                <ContentPresenter Grid.Row="4"
                                  Margin="0,8,0,0"
                                  Content="{Binding SelectedContent, ElementName=ArticleTabs}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

