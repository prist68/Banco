<Window x:Class="Banco.UI.Wpf.Views.ArticleSecondaryCategoriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        Width="680"
        Height="560"
        MinWidth="620"
        MinHeight="500"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Style="{StaticResource ModalOverlayHostStyle}">
        <Border Padding="12"
                Style="{StaticResource ModalSurfaceCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           LastChildFill="True"
                           MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                    <TextBlock Text="Banco / categorie secondarie"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource ModalHeaderCloseButtonStyle}"
                            Click="CloseButton_OnClick">
                        <Border Style="{StaticResource ModalHeaderCloseChromeStyle}">
                            <TextBlock Text="X"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Button>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="0,8,0,0"
                        BorderBrush="{DynamicResource ModalAccentBorderBrush}"
                        BorderThickness="4,0,0,0"
                        Padding="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Categorie secondarie"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding PrimaryCategoryLabel, StringFormat='Categoria principale: {0}'}" />
                    </StackPanel>
                </Border>

                <DockPanel Grid.Row="2"
                           Margin="0,10,0,0"
                           LastChildFill="False">
                    <Button DockPanel.Dock="Left"
                            MinWidth="88"
                            Style="{StaticResource CompactPrimaryButtonStyle}"
                            Click="SaveButton_OnClick"
                            Content="Salva" />
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding StatusMessage}" />
                </DockPanel>

                <Border Grid.Row="3"
                        Margin="0,10,0,0"
                        Background="Transparent"
                        BorderBrush="{DynamicResource ModalInfoBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="4">
                    <Grid>
                        <TextBlock x:Name="EmptyTextBlock"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="Nessuna categoria secondaria disponibile."
                                   Visibility="Collapsed" />

                        <ListBox x:Name="CategoriesListBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Focusable" Value="False" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Padding="2,1"
                                              Margin="0">
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="NoWrap" />
                                    </CheckBox>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <DockPanel Grid.Row="4"
                           Margin="0,10,0,0"
                           LastChildFill="False">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="{Binding SelectedCount, StringFormat='Selezionate: {0}'}" />
                    <Button DockPanel.Dock="Right"
                            MinWidth="88"
                            Margin="8,0,0,0"
                            Style="{StaticResource CompactSecondaryButtonStyle}"
                            Click="CloseButton_OnClick"
                            Content="Chiudi" />
                </DockPanel>
            </Grid>
        </Border>
    </Border>
</Window>
