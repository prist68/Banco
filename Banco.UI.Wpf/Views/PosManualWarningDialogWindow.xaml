<Window x:Class="Banco.UI.Wpf.Views.PosManualWarningDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="500"
        MaxWidth="680"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Background="{DynamicResource ModalOverlayBrush}">
        <Border Width="540"
                Margin="24"
                Padding="20"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushBase}"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True">
                    <TextBlock Text="Banco / POS"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Width="28"
                            Height="28"
                            Margin="12,0,0,0"
                            Click="CloseButton_OnClick"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Chiudi">
                        <Border Background="{DynamicResource ModalChromeBrush}"
                                BorderBrush="{StaticResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="7">
                            <TextBlock Text="✕"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Button>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        BorderBrush="{DynamicResource BancoActionWarningBorderBrush}"
                        BorderThickness="4,0,0,0"
                        Padding="14,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Pagamento POS da verificare"
                                   FontSize="21"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding DialogMessage, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="13.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,18,0,0"
                        Padding="12,10"
                        Background="{DynamicResource ModalInfoSurfaceBrush}"
                        BorderBrush="{DynamicResource BancoActionWarningBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <TextBlock Text="Se il POS mostra gia` la transazione come accettata, non reinviare l'importo da Banco. Procedi con stampa manuale del registratore e poi continua dalla scheda."
                               FontSize="13.5"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BancoActionWarningForegroundBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <StackPanel Grid.Row="3"
                            Margin="0,22,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Torno alla scheda"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="128"
                            Margin="0,0,10,0"
                            Click="BackButton_OnClick" />
                    <Button Content="Stampa manualmente"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="150"
                            IsDefault="True"
                            Click="ManualButton_OnClick" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
