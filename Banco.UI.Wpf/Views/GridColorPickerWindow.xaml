<Window x:Class="Banco.UI.Wpf.Views.GridColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Colore parte superiore"
        Width="420"
        Height="515"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#FFF3F7FC"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Border Margin="14"
            Padding="18"
            CornerRadius="18"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushBase}"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="Bold"
                           Text="Colore parte superiore" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="Scegli il colore personalizzato della parte alta della griglia." />
            </StackPanel>

            <Border Grid.Row="2"
                    x:Name="PreviewBorder"
                    Height="98"
                    CornerRadius="18"
                    BorderThickness="1"
                    BorderBrush="#FFD9E3F0"
                    Background="#FFEAF3FF">
                <Grid>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock x:Name="PreviewLabel"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="PreviewHex"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="74" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="R" />
                <Slider x:Name="SliderR"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="255"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="Slider_ValueChanged" />
                <TextBox x:Name="ValueR"
                         Grid.Column="2"
                         IsReadOnly="True"
                         Height="30"
                         Margin="10,0,0,0"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="2"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="G" />
                <Slider x:Name="SliderG"
                        Grid.Row="2"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="255"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="Slider_ValueChanged" />
                <TextBox x:Name="ValueG"
                         Grid.Row="2"
                         Grid.Column="2"
                         IsReadOnly="True"
                         Height="30"
                         Margin="10,0,0,0"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="4"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="B" />
                <Slider x:Name="SliderB"
                        Grid.Row="4"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="255"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="Slider_ValueChanged" />
                <TextBox x:Name="ValueB"
                         Grid.Row="4"
                         Grid.Column="2"
                         IsReadOnly="True"
                         Height="30"
                         Margin="10,0,0,0"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center" />
            </Grid>

            <Border Grid.Row="6"
                    Padding="0,12,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#FFE2EAF3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Il colore viene salvato separatamente per ogni griglia." />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Annulla"
                                Click="CancelButton_OnClick"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="16,7"
                                MinWidth="92"
                                Margin="0,0,8,0" />
                        <Button Content="Conferma"
                                Click="ConfirmButton_OnClick"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="16,7"
                                MinWidth="104" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
