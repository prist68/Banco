<Window x:Class="Banco.UI.Wpf.Views.ConfirmationDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        MaxWidth="560"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Style="{StaticResource ModalOverlayHostStyle}">
        <Border Width="440"
                Style="{StaticResource ModalSurfaceCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True" MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                    <TextBlock Text="{Binding Eyebrow, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource ModalHeaderCloseButtonStyle}"
                            Click="CloseButton_OnClick"
                            >
                        <Border Style="{StaticResource ModalHeaderCloseChromeStyle}">
                            <TextBlock Text="✕"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Button>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        BorderBrush="{DynamicResource ModalAccentBorderBrush}"
                        BorderThickness="4,0,0,0"
                        Padding="14,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding DialogTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="21"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding DialogMessage, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="13.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,18,0,0"
                        Padding="12,10"
                        Background="{DynamicResource ModalInfoSurfaceBrush}"
                        BorderBrush="{DynamicResource ModalInfoBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HighlightText, RelativeSource={RelativeSource AncestorType=Window}}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding HighlightText, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="13.5"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ModalInfoForegroundBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <StackPanel Grid.Row="3"
                            Margin="0,22,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="{Binding SecondaryButtonText, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="104"
                            Margin="0,0,10,0"
                            IsCancel="True"
                            Click="SecondaryButton_OnClick" />
                    <Button Content="{Binding PrimaryButtonText, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="110"
                            IsDefault="True"
                            Click="PrimaryButton_OnClick" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>

