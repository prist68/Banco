<UserControl x:Class="Banco.UI.Wpf.Views.BackupImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="{Binding Titolo}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="Ripristino guidato del backup Facile Manager sul database configurato nella postazione corrente." />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}"
                    Background="{StaticResource WindowBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconFolder}"
                                  Fill="{StaticResource TextPrimaryBrush}"
                                  Width="18" Height="18" Stretch="Uniform"
                                  VerticalAlignment="Center" />
                            <TextBlock Margin="10,0,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="Backup selezionato" />
                        </StackPanel>
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Supporta archivi `zip` di Facile Manager e dump `bak/sql`." />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushBase}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <TextBlock Text="{Binding BackupFilePath, TargetNullValue=Nessun file selezionato}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </Border>

                    <Border Grid.Row="4"
                            Background="#FFF7FAFF"
                            BorderBrush="#FFD8E3F1"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Dettaglio archivio" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding BackupSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}"
                    Background="{StaticResource WindowBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconDatabase}"
                                  Fill="{StaticResource TextPrimaryBrush}"
                                  Width="18" Height="18" Stretch="Uniform"
                                  VerticalAlignment="Center" />
                            <TextBlock Margin="10,0,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="Regole operative" />
                        </StackPanel>
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Il modulo importa il dump SQL dentro il `db_diltech` configurato per questa postazione." />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushBase}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <TextBlock Text="1. Chiudi Banco e Facile Manager sulle altre postazioni prima del restore."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Border>

                    <Border Grid.Row="4"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushBase}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <TextBlock Text="2. Dopo l'importazione riavvia Banco per ricaricare liste, clienti e punti dal DB appena riallineato."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Border>

                    <Border Grid.Row="6"
                            Background="#FFFFF6E8"
                            BorderBrush="#FFE8C97C"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <TextBlock Text="3. Il restore sostituisce il contenuto locale del database corrente: fai sempre un backup prima di procedere."
                                   TextWrapping="Wrap"
                                   Foreground="#FF8B5A00" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Style="{StaticResource CardStyle}"
                Background="{StaticResource WindowBackgroundBrush}"
                Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Button Content="Seleziona backup"
                            Command="{Binding BrowseBackupCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="148"
                            Height="42"
                            Margin="0,0,0,10" />
                    <Button Content="Importa backup"
                            Command="{Binding ImportBackupCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="148"
                            Height="42"
                            Margin="0" />
                </StackPanel>

                <Border Grid.Column="4"
                        Background="#FFF8FBFF"
                        BorderBrush="{StaticResource BorderBrushBase}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="Stato importazione" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding ProgressStage}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="10,5"
                                    CornerRadius="9"
                                    BorderThickness="1"
                                    Background="#FFFFFFFF"
                                    BorderBrush="{StaticResource BorderBrushBase}">
                                <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:N0}%, Mode=OneWay}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>
                        </Grid>

                        <ProgressBar Grid.Row="2"
                                     Height="12"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding ProgressPercent, Mode=OneWay}"
                                     Foreground="#FF3D73C6"
                                     Background="#FFE8EEF7" />

                        <Border Grid.Row="4"
                                Background="#FFFFFFFF"
                                BorderBrush="{StaticResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <TextBlock Text="{Binding ProgressDetail}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <Border Grid.Row="6"
                                Background="#FFFFFFFF"
                                BorderBrush="{StaticResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                                <Setter Property="Foreground" Value="#FFC43D3D" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
