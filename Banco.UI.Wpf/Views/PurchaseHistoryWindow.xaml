<Window x:Class="Banco.UI.Wpf.Views.PurchaseHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Banco.UI.Wpf.Views"
        Title="{Binding WindowTitle}"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="22"
                       FontWeight="Bold"
                       Text="{Binding WindowTitle}" />
            <TextBlock Margin="0,6,0,0"
                       FontSize="13.5"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="{Binding WindowSubtitle}" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="#FFFFFFFF"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Effect="{StaticResource SubtleShadow}"
                Padding="14,12">
            <StackPanel>
                <WrapPanel Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                        <TextBlock Text="Articolo:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <Grid>
                            <TextBox x:Name="ArticleFilterTextBox"
                                     Width="280"
                                     Text="{Binding SearchArticleText, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding IsArticleFilterLocked}"
                                     Background="#FFFFFFFF"
                                     FontSize="13"
                                     Padding="8,5"
                                     PreviewKeyDown="ArticleFilterTextBox_OnPreviewKeyDown"
                                     VerticalContentAlignment="Center" />
                            <Popup IsOpen="{Binding IsArticlePopupOpen}"
                                   PlacementTarget="{Binding ElementName=ArticleFilterTextBox}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade">
                                <Border Width="540"
                                        Background="#FFFFFFFF"
                                        BorderBrush="{StaticResource BorderBrushBase}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6"
                                        Effect="{StaticResource CardShadow}">
                                    <DataGrid x:Name="ArticleLookupGrid"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserResizeRows="False"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              PreviewKeyDown="ArticleLookupGrid_OnKeyDown"
                                              MouseDoubleClick="ArticleLookupGrid_OnMouseDoubleClick"
                                              ItemsSource="{Binding ArticleLookupResults}"
                                              SelectedItem="{Binding SelectedArticle, Mode=OneWay}"
                                              Background="#FFFBFDFF"
                                              HorizontalGridLinesBrush="#FFE4EBF3"
                                              BorderThickness="0"
                                              RowHeight="31"
                                              FontSize="12.5"
                                              AlternationCount="2"
                                              AlternatingRowBackground="#FFF8FBFE"
                                              RowBackground="#FFFFFFFF"
                                              MinHeight="180"
                                              MaxHeight="260">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#FFF4F8FD" />
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                                <Setter Property="FontSize" Value="11.5" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Padding" Value="10,7" />
                                                <Setter Property="BorderBrush" Value="#FFDCE5F0" />
                                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Cursor" Value="Hand" />
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                <Setter Property="Background" Value="#FFFFFFFF" />
                                                <Style.Triggers>
                                                    <Trigger Property="AlternationIndex" Value="1">
                                                        <Setter Property="Background" Value="#FFF8FBFE" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#FFE8F1FB" />
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True" />
                                                            <Condition Property="IsSelected" Value="False" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter Property="Background" Value="#FFF1F6FC" />
                                                    </MultiTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Padding" Value="10,4" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Articolo" Binding="{Binding DisplayLabel}" Width="*" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="TextWrapping" Value="NoWrap" />
                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Prezzo" Binding="{Binding PrezzoVendita, StringFormat={}{0:N2}}" Width="82" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                                        <Setter Property="TextAlignment" Value="Right" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Quantita`" Binding="{Binding Giacenza, StringFormat={}{0:N2}}" Width="82" IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                                        <Setter Property="TextAlignment" Value="Right" />
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                        <TextBlock Text="Fornitore:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <Grid>
                            <TextBox x:Name="SupplierFilterTextBox"
                                     Width="260"
                                     Text="{Binding SearchSupplierText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#FFFFFFFF"
                                     FontSize="13"
                                     Padding="8,5"
                                     VerticalContentAlignment="Center" />
                            <Popup IsOpen="{Binding IsSupplierPopupOpen}"
                                   PlacementTarget="{Binding ElementName=SupplierFilterTextBox}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade">
                                <Border Width="420"
                                        Background="#FFFFFFFF"
                                        BorderBrush="{StaticResource BorderBrushBase}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6"
                                        Effect="{StaticResource CardShadow}">
                                    <ListBox x:Name="SupplierLookupList"
                                             BorderThickness="0"
                                             PreviewKeyDown="SupplierLookupList_OnKeyDown"
                                             MouseDoubleClick="SupplierLookupList_OnMouseDoubleClick"
                                             ItemsSource="{Binding SupplierLookupResults}"
                                             SelectedItem="{Binding SelectedSupplier, Mode=OneWay}"
                                             DisplayMemberPath="DisplayLabel"
                                             MinHeight="120"
                                             MaxHeight="240" />
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>

                    <views:DateRangeFilterBar />

                    <Button Content="Reset"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearFiltersCommand}"
                            Padding="14,7"
                            Margin="12,0,0,4"
                            FontSize="13" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           FontSize="12.5"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding StatusMessage}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="4"
                Background="#FFFFFFFF"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Effect="{StaticResource SubtleShadow}"
                Padding="0"
                ClipToBounds="True">
            <Grid>
                <DataGrid AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Results}"
                          Background="{StaticResource SurfaceBrush}"
                          BorderThickness="0"
                          RowHeight="34"
                          AlternatingRowBackground="#FFF7F9FC">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Data" Binding="{Binding DataDocumento, StringFormat=dd/MM/yyyy}" Width="95" />
                        <DataGridTextColumn Header="Tipo" Binding="{Binding TipoDocumento}" Width="130" />
                        <DataGridTextColumn Header="Articolo" Binding="{Binding CodiceArticolo}" Width="100" />
                        <DataGridTextColumn Header="Descrizione" Binding="{Binding DescrizioneArticolo}" Width="*" />
                        <DataGridTextColumn Header="Fornitore" Binding="{Binding FornitoreNominativo}" Width="220" />
                        <DataGridTextColumn Header="FT" Binding="{Binding RiferimentoFattura}" Width="120" />
                        <DataGridTextColumn Header="Pezzi" Binding="{Binding Quantita, StringFormat={}{0:N2}}" Width="90" />
                        <DataGridTextColumn Header="Prezzo" Binding="{Binding PrezzoUnitario, StringFormat={}{0:N2} €}" Width="110" />
                        <DataGridTextColumn Header="Totale" Binding="{Binding TotaleRiga, StringFormat={}{0:N2} €}" Width="110" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Background="#FFF9FBFE">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasResults}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="19"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Text="{Binding EmptyStateTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="13.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding EmptyStateMessage}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Width="420" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="6"
                Background="#FFFFFFFF"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Effect="{StaticResource SubtleShadow}"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           FontSize="12.5"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Riepilogo risultati correnti" />

                <StackPanel Grid.Column="1">
                    <TextBlock FontSize="11.5"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Totale acquistato" />
                    <TextBlock FontSize="18"
                               FontWeight="Bold"
                               Text="{Binding TotaleAcquistato, StringFormat={}{0:N2} €}" />
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock FontSize="11.5"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Pezzi acquistati" />
                    <TextBlock FontSize="18"
                               FontWeight="Bold"
                               Text="{Binding PezziAcquistati, StringFormat={}{0:N2}}" />
                </StackPanel>

                <StackPanel Grid.Column="5">
                    <TextBlock FontSize="11.5"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Ultimo prezzo" />
                    <TextBlock FontSize="18"
                               FontWeight="Bold"
                               Text="{Binding UltimoPrezzo, StringFormat={}{0:N2} €}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
