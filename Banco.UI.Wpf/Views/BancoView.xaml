<UserControl x:Class="Banco.UI.Wpf.Views.BancoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:input="clr-namespace:Banco.UI.Wpf.Infrastructure.Input"
             xmlns:sel="clr-namespace:Banco.UI.Wpf.Infrastructure.Selection"
             xmlns:viewModels="clr-namespace:Banco.UI.Wpf.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1600"
             d:DesignHeight="900"
             PreviewKeyDown="BancoView_OnPreviewKeyDown"
             PreviewTextInput="BancoView_OnPreviewTextInput">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="PaymentLabelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PaymentInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="input:PosAmountTextBoxBehavior.IsEnabled" Value="True" />
            <Setter Property="input:PosAmountTextBoxBehavior.CultureName" Value="it-IT" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,0,8,0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource BancoInputSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BancoInputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="PaymentBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          TextElement.FontFamily="{TemplateBinding FontFamily}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PaymentBorder" Property="BorderBrush" Value="{DynamicResource BancoInputHoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="PaymentBorder" Property="BorderBrush" Value="{DynamicResource BancoInputFocusBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Sconto inline: trasparente di default, box visibile al hover/focus -->
        <Style x:Key="ScontoInlineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="input:PosAmountTextBoxBehavior.IsEnabled" Value="True" />
            <Setter Property="input:PosAmountTextBoxBehavior.CultureName" Value="it-IT" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="6,0,18,0" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource BancoWarningForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="ScontoBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          TextElement.FontFamily="{TemplateBinding FontFamily}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ScontoBorder" Property="Background" Value="{DynamicResource BancoInputSurfaceBrush}" />
                                <Setter TargetName="ScontoBorder" Property="BorderBrush" Value="{DynamicResource BancoWarningBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="ScontoBorder" Property="Background" Value="{DynamicResource BancoInputSurfaceBrush}" />
                                <Setter TargetName="ScontoBorder" Property="BorderBrush" Value="{DynamicResource BancoWarningForegroundBrush}" />
                                <Setter TargetName="ScontoBorder" Property="BorderThickness" Value="1.5" />
                                <Setter Property="Cursor" Value="IBeam" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Pagamenti inline: contorno sottile arrotondato, box pieno al hover/focus -->
        <Style x:Key="PaymentInlineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="input:PosAmountTextBoxBehavior.IsEnabled" Value="True" />
            <Setter Property="input:PosAmountTextBoxBehavior.CultureName" Value="it-IT" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,0,22,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource BancoInputSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BancoInlineBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="PmtBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          TextElement.FontFamily="{TemplateBinding FontFamily}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PmtBorder" Property="Background" Value="{DynamicResource BancoInputSurfaceBrush}" />
                                <Setter TargetName="PmtBorder" Property="BorderBrush" Value="{DynamicResource BancoInputHoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="PmtBorder" Property="Background" Value="{DynamicResource BancoInputSurfaceBrush}" />
                                <Setter TargetName="PmtBorder" Property="BorderBrush" Value="{DynamicResource BancoInputFocusBorderBrush}" />
                                <Setter TargetName="PmtBorder" Property="BorderThickness" Value="1.5" />
                                <Setter Property="Cursor" Value="IBeam" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CurrencyGridEditingTextBoxStyle" TargetType="TextBox">
            <Setter Property="input:PosAmountTextBoxBehavior.IsEnabled" Value="True" />
            <Setter Property="input:PosAmountTextBoxBehavior.CultureName" Value="it-IT" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Language" Value="it-IT" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource BancoInputSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource BancoSelectionBrush}" />
            <Setter Property="SelectionTextBrush" Value="{DynamicResource BancoSelectionTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BancoInputFocusBorderBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Tag" Value="CurrencyInput" />
        </Style>
        <Style x:Key="HistoryButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactSecondaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BancoAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BancoAccentSoftBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BancoAccentSoftForegroundBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="BancoSettingsShortcutButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactPrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BancoActionPrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BancoSelectionTextBrush}" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BancoActionPrimaryBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Effect="{StaticResource SubtleShadow}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource BancoActionPrimaryHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Effect" Value="{StaticResource CardShadow}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource BancoActionPrimaryPressedBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Effect" Value="{x:Null}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BancoCashRegisterShortcutButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactSecondaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BancoActionWarningBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BancoActionWarningForegroundBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BancoActionWarningBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Effect="{StaticResource SubtleShadow}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource BancoActionWarningHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Effect" Value="{StaticResource CardShadow}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource BancoActionWarningPressedBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Effect" Value="{x:Null}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BancoPrintShortcutButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactGreenButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BancoActionSuccessBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BancoSelectionTextBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BancoActionSuccessBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Effect="{StaticResource SubtleShadow}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource BancoActionSuccessHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Effect" Value="{StaticResource CardShadow}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource BancoActionSuccessPressedBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Effect" Value="{x:Null}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CompactSectionCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        </Style>
        <Style x:Key="CompactCardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <Style x:Key="InlineBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="165*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Grid.ColumnSpan="2"
                Margin="0,0,0,6"
                Padding="12,10"
                CornerRadius="10"
                Background="{DynamicResource BancoHeaderSurfaceBrush}"
                BorderBrush="{DynamicResource BancoHeaderBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            MinWidth="320"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="19"
                                   FontWeight="Bold"
                                   Text="{Binding Titolo}" />
                        <Border Margin="12,0,0,0"
                                Padding="8,3"
                                Background="{DynamicResource BancoHeaderBadgeSurfaceBrush}"
                                BorderBrush="{DynamicResource BancoHeaderBadgeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource InlineBadgeTextStyle}"
                                       Text="Documento operativo" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="2"
                        Height="34"
                        Padding="8,4"
                        Background="{DynamicResource BancoHeaderControlSurfaceBrush}"
                        BorderBrush="{DynamicResource BancoHeaderControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="10.5"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="Listino" />
                        <ComboBox Grid.Column="2"
                                  Width="150"
                                  MinHeight="24"
                                  Padding="6,1"
                                  Style="{StaticResource CompactComboBoxStyle}"
                                  ItemsSource="{Binding ListiniDisponibili}"
                                  SelectedItem="{Binding ListinoSelezionato, Mode=TwoWay}"
                                  IsEnabled="{Binding CanSelectListino}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayLabel}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Grid.Column="4"
                        Height="32"
                        Padding="10,0"
                        CornerRadius="8"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource BancoNotificationBorderBrush}" />
                            <Setter Property="Background" Value="{DynamicResource BancoNotificationSurfaceBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasHeaderNotification}" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource BancoNotificationAlertBorderBrush}" />
                                    <Setter Property="Background" Value="{DynamicResource BancoNotificationAlertSurfaceBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BancoNotificationForegroundBrush}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding HeaderNotificationText}" />
                </Border>

                <StackPanel Grid.Column="6"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource CompactSecondaryButtonStyle}"
                            Command="{Binding AbilitaModificaDocumentoFiscalizzatoCommand}"
                            Content="Abilita modifica"
                            Visibility="{Binding CanEnableConsultationEdit, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTip="Sblocca la scheda fiscalizzata per una correzione manuale controllata. Salva con F4/F10 senza ristampa."
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Background="{DynamicResource BancoActionHighlightSurfaceBrush}"
                            Foreground="{DynamicResource BancoNotificationForegroundBrush}" />
                    <Button Style="{StaticResource CompactSecondaryButtonStyle}"
                            Content="Annulla contenuto"
                            Click="AzzeraContenutoButton_OnClick"
                            IsEnabled="{Binding CanAzzeraContenuto}"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Foreground="{DynamicResource BancoActionSuccessSoftForegroundBrush}"
                            Background="{DynamicResource BancoActionSuccessSoftBrush}" />
                    <Button Style="{StaticResource CompactSecondaryButtonStyle}"
                            Content="Cancella scheda"
                            Click="CancellaSchedaButton_OnClick"
                            IsEnabled="{Binding CanCancellaScheda}"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Background="{DynamicResource BancoActionDangerStrongBrush}"
                            Foreground="{DynamicResource BancoSelectionTextBrush}" />
                    <Button Style="{StaticResource CompactPrimaryButtonStyle}"
                            Content="Salva"
                            Click="SalvaDocumentoButton_OnClick"
                            IsEnabled="{Binding CanSaveDocumentoLocale}"
                            ToolTip="Pubblica o aggiorna il documento Banco su db_diltech (F4/F10)"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0" />
                    <Button Style="{StaticResource CompactSecondaryButtonStyle}"
                            Command="{Binding MostraListaDocumentiCommand}"
                            Content="Documenti"
                            VerticalAlignment="Center"
                            Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.35*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="0.56*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CompactCardStyle}" Padding="12,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Style="{StaticResource CompactCardTitleStyle}"
                                       Text="Ricerca articoli" />
                            <TextBlock Grid.Row="1"
                                       Style="{StaticResource CompactSectionCaptionStyle}"
                                       Text="Codice, barcode o parole chiave. INVIO per aggiungere subito." />

                            <Grid Grid.Row="2" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Margin="0,0,0,0">
                                    <TextBox x:Name="ArticleSearchTextBox"
                                             Style="{StaticResource CompactTextBoxStyle}"
                                             input:TextBoxPlaceholderService.Placeholder="Cerca articoli, lettore barcode o ricerca multi-termine"
                                             Text="{Binding SearchArticoloText, UpdateSourceTrigger=PropertyChanged}"
                                             PreviewKeyDown="ArticleSearchTextBox_OnKeyDown"
                                             IsEnabled="{Binding CanModifyDocument}"
                                             Background="#FFFFFFFF"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             CaretBrush="{StaticResource TextPrimaryBrush}"
                                             SelectionBrush="#663D73C6"
                                             SelectionTextBrush="{StaticResource TextPrimaryBrush}"
                                             FontSize="12.5"
                                             FontWeight="SemiBold"
                                             MinHeight="30"
                                             VerticalContentAlignment="Center"
                                             Margin="0"
                                             Padding="10,4" />
                                </Grid>
                                <Button Grid.Column="1"
                                        Content="A"
                                        Command="{Binding ApriStoricoAcquistiArticoloCommand}"
                                        Width="32"
                                        Margin="6,0,0,0"
                                        Padding="0"
                                        Height="30"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Style="{StaticResource CompactSecondaryButtonStyle}"
                                        ToolTip="Apri la ricerca acquisti libera" />
                                <Button Grid.Column="2"
                                        Content="Aggiungi"
                                        Style="{StaticResource CompactPrimaryButtonStyle}"
                                        Command="{Binding AggiungiArticoloCommand}"
                                        Width="88"
                                        Margin="6,0,0,0"
                                        Height="30" />
                            </Grid>

                            <Border Grid.Row="4"
                                    Margin="0,2,0,0"
                                    Padding="10,7"
                                    Background="#FFF4F8FD"
                                    BorderBrush="#FFE1E9F3"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasQuickArticlePurchaseInfo}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Ultimo acquisto"
                                               TextWrapping="Wrap" />

                                    <Grid Grid.Row="1"
                                          Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.4*" />
