                                             Background="{StaticResource SurfaceAltBrush}"
                                             PreviewKeyDown="CustomerLookupList_OnKeyDown"
                                             PreviewMouseLeftButtonUp="CustomerLookupList_OnPreviewMouseLeftButtonUp"
                                             MouseDoubleClick="CustomerLookupList_OnMouseDoubleClick"
                                             MinHeight="140"
                                             MaxHeight="220">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="4,3">
                                                    <TextBlock DockPanel.Dock="Right"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Text="{Binding PuntiLabel}" />
