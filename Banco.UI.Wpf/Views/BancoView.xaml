                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade">
                                <Border Width="388"
                                        Background="White"
                                        BorderBrush="{StaticResource BorderBrushBase}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="4">
                                    <ListBox x:Name="CustomerLookupList"
