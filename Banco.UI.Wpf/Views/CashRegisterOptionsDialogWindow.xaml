<Window x:Class="Banco.UI.Wpf.Views.CashRegisterOptionsDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="540"
        MaxWidth="680"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Rectangle Fill="{DynamicResource SidebarBackgroundBrush}"
                   Opacity="0.58" />

        <Border Width="517"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushBase}"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>

                <!-- Header -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Opzioni cassa"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Registratore: Ditron Elsi Retail R1"
                               FontSize="11.5"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <Rectangle Height="1"
                           Fill="{DynamicResource HairlineBrush}"
                           Margin="0,0,0,14" />

                <!-- Formato giornale -->
                <Border Padding="12,9"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrushBase}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,0,0,10">
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Formato giornale"
                                   Width="140"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <RadioButton x:Name="ShortJournalRadioButton"
                                         GroupName="JournalMode"
                                         IsChecked="True"
                                         Content="Corta"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontSize="13"
                                         FontWeight="SemiBold"
                                         VerticalAlignment="Center"
                                         Margin="0,0,18,0" />
                            <RadioButton x:Name="MediumJournalRadioButton"
                                         GroupName="JournalMode"
                                         Content="Media"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontSize="13"
                                         FontWeight="SemiBold"
                                         VerticalAlignment="Center"
                                         Margin="0,0,18,0" />
                            <RadioButton x:Name="LongJournalRadioButton"
                                         GroupName="JournalMode"
                                         Content="Lunga"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontSize="13"
                                         FontWeight="SemiBold"
                                         VerticalAlignment="Center" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Documento fiscale -->
                <Border Padding="12,10"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrushBase}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>

                        <TextBlock Text="DOCUMENTO FISCALE"
                                   FontSize="10.5"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,10" />

                        <!-- Grid unificato: col 0 = label fissa, col 1 = contenuto * -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Riga 0: scontrino + data -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Style="{StaticResource FieldLabelStyle}" ><Run Text="Sc"/><Run Language="it-it" Text="ontrino N."/></TextBlock>
                            <StackPanel Grid.Row="0" Grid.Column="1"
                                        Orientation="Horizontal">
                                <TextBox x:Name="ReceiptDocumentPrefixTextBox"
                                         Width="54"
                                         Style="{StaticResource CompactTextBoxStyle}"
                                         MaxLength="4"
                                         HorizontalContentAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         TextChanged="ReceiptFields_OnTextChanged" Height="30" />
                                <TextBlock Text="-"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="5,0" />
                                <TextBox x:Name="ReceiptNumberTextBox"
                                         Width="54"
                                         Style="{StaticResource CompactTextBoxStyle}"
                                         MaxLength="4"
                                         HorizontalContentAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         TextChanged="ReceiptFields_OnTextChanged" Height="30" />
                                <TextBlock Text="Data"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="16,0,8,0" />
                                <DatePicker x:Name="ReceiptDatePicker"
                                            Width="150"
                                            Style="{StaticResource CompactDatePickerStyle}"
                                            SelectedDateChanged="ReceiptDatePicker_OnSelectedDateChanged" />
                            </StackPanel>

                            <!-- Riga 2: matricola + azioni -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Matricola"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <DockPanel Grid.Row="2" Grid.Column="1"
                                       LastChildFill="True">
                                <Button x:Name="ReceiptCancellationButton"
                                        DockPanel.Dock="Right"
                                        Content="Annullo"
                                        MinWidth="80"
                                        Style="{StaticResource CompactSecondaryButtonStyle}"
                                        Click="ReceiptCancellationButton_OnClick" Background="#FFF18080" />
                                <Button x:Name="ReceiptReprintButton"
                                        DockPanel.Dock="Right"
                                        Content="Ristampa"
                                        MinWidth="90"
                                        Style="{StaticResource CompactSecondaryButtonStyle}"
                                        Margin="0,0,8,0"
                                        Click="ReceiptReprintButton_OnClick" Background="#FFEEF7E6" />
                                <TextBox x:Name="ReceiptMachineIdTextBox"
                                         Style="{StaticResource CompactTextBoxStyle}"
                                         VerticalContentAlignment="Center"
                                         TextChanged="ReceiptFields_OnTextChanged" Height="30" />
                            </DockPanel>
                        </Grid>

                        <!-- Validazione -->
                        <TextBlock x:Name="ValidationMessageTextBlock"
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed"
                                   FontSize="11.5"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SemanticDangerBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Footer azioni -->
                <Border Margin="0,14,0,0"
                        Padding="0,12,0,0"
                        BorderBrush="{DynamicResource HairlineBrush}"
                        BorderThickness="0,1,0,0">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Chiudi"
                                MinWidth="80"
                                Style="{StaticResource CompactSecondaryButtonStyle}"
                                IsCancel="True"
                                Click="CloseButton_OnClick" />
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <Button Content="Stampa giornale"
                                    MinWidth="120"
                                    Style="{StaticResource CompactSecondaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    Click="PrintDailyJournalButton_OnClick" />
                            <Button Content="Stampa e chiusura cassa"
                                    MinWidth="170"
                                    Style="{StaticResource CompactPrimaryButtonStyle}"
                                    IsDefault="True"
                                    Click="CloseCashAndTransmitButton_OnClick" />
                        </StackPanel>
                    </DockPanel>
                </Border>

            </StackPanel>
        </Border>
    </Grid>
</Window>
