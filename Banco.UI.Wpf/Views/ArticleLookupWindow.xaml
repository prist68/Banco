<Window x:Class="Banco.UI.Wpf.Views.ArticleLookupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Banco.UI.Wpf.Converters"
        Title="{Binding WindowTitle}"
        Width="1180"
        Height="720"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:LocalPathToBitmapImageConverter x:Key="LocalPathToBitmapImageConverter" />
        <Style x:Key="LookupValueBoxStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBase}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style x:Key="LookupLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>
        <Style x:Key="LookupEditorTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#C9D6E5" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>
    <Border Background="#080F172A">
        <Border Margin="12"
                Padding="18"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushBase}"
                BorderThickness="1"
                CornerRadius="18"
                Effect="{StaticResource SubtleShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           LastChildFill="False"
                           MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="LOOKUP ARTICOLI LEGACY" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="{Binding WindowTitle}" />
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Width="32"
                            Height="32"
                            Margin="12,0,0,0"
                            Click="CloseButton_OnClick"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Chiudi">
                        <Border Background="#FFF5F8FC"
                                BorderBrush="{StaticResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="9">
                            <TextBlock Text="X"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Button>
                </DockPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="446" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushBase}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBox x:Name="SearchTextBox"
                                     Grid.Row="0"
                                     Style="{StaticResource LookupEditorTextBoxStyle}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewKeyDown="SearchTextBox_OnPreviewKeyDown"
                                     CaretBrush="{StaticResource TextPrimaryBrush}"
                                     SelectionBrush="#663D73C6"
                                     SelectionTextBrush="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Grid.Row="2"
                                       Style="{StaticResource LookupLabelStyle}"
                                       Text="Risultati ricerca" />

                            <TextBox Grid.Row="4"
                                     HorizontalAlignment="Left"
                                     Width="180"
                                     Style="{StaticResource LookupEditorTextBoxStyle}"
                                     MinHeight="30"
                                     Padding="10,4"
                                     Text="{Binding AdditionalFilterText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="11.5"
                                     MaxLength="20">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6" />
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>

                            <Border Grid.Row="6"
                                    Style="{StaticResource LookupValueBoxStyle}"
                                    Padding="0"
                                    Background="#FFFDFEFF">
                                <ListBox x:Name="ResultsListBox"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ItemsSource="{Binding Results}"
                                         SelectedItem="{Binding SelectedArticle, Mode=TwoWay}"
                                         MouseDoubleClick="ResultsListBox_OnMouseDoubleClick"
                                         PreviewKeyDown="ResultsListBox_OnPreviewKeyDown"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="BorderBrush" Value="#E3EBF4" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#FFCEE3F5" />
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True" />
                                                        <Condition Property="IsSelected" Value="False" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="#FFF4F8FD" />
                                                </MultiTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="12,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock FontSize="12.5"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               Text="{Binding CodiceArticolo}" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               FontSize="11.75"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               Text="{Binding Descrizione}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               FontSize="10.75"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               Text="{Binding VarianteLabel}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2"
                                                            HorizontalAlignment="Right">
                                                    <TextBlock HorizontalAlignment="Right"
                                                               FontSize="12.5"
                                                               FontWeight="Bold"
                                                               Foreground="#1E7A49"
                                                               Text="{Binding PrezzoVendita, StringFormat={}{0:N2} €}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               HorizontalAlignment="Right"
                                                               FontSize="10.75"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Text="{Binding Giacenza, StringFormat=Disp. {0:N2}}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushBase}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="164" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LookupLabelStyle}"
                                                   Text="Titolo" />
                                        <Border Margin="0,6,0,0"
                                                Style="{StaticResource LookupValueBoxStyle}">
                                            <TextBlock FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding SelectedArticle.DisplayLabel}"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <TextBlock Margin="0,12,0,0"
                                                   Style="{StaticResource LookupLabelStyle}"
                                                   Text="Descrizione breve" />
                                        <Border Margin="0,6,0,0"
                                                Style="{StaticResource LookupValueBoxStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock x:Name="ShortDescriptionTextBlock"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="{Binding ShortDescriptionText}"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Height="{Binding ShortDescriptionViewportHeight}"
                                                           LineStackingStrategy="BlockLineHeight"
                                                           LineHeight="20" />
                                                <DockPanel Grid.Row="1"
                                                           Margin="0,8,0,0"
                                                           LastChildFill="False"
                                                           Visibility="{Binding HasShortDescriptionExpandToggle, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Button DockPanel.Dock="Right"
                                                            Content="{Binding ShortDescriptionToggleButtonText}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Padding="10,4"
                                                            Command="{Binding ToggleShortDescriptionCommand}" />
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LookupLabelStyle}"
                                                   Text="Immagine" />
                                        <Border Margin="0,6,0,0"
                                                Width="148"
                                                Height="148"
                                                HorizontalAlignment="Center"
                                                Style="{StaticResource LookupValueBoxStyle}"
                                                Padding="6"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Image Stretch="Uniform"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Source="{Binding SelectedDetail.ImageUrl, Converter={StaticResource LocalPathToBitmapImageConverter}, TargetNullValue={x:Null}, FallbackValue={x:Null}}">
                                                    <Image.ToolTip>
                                                        <Border Padding="8"
                                                                Background="#FFFFFFFF"
                                                                BorderBrush="{StaticResource BorderBrushBase}"
                                                                BorderThickness="1"
                                                                CornerRadius="12">
                                                            <Image Width="420"
                                                                   Height="420"
                                                                   Stretch="Uniform"
                                                                   Source="{Binding SelectedDetail.ImageUrl, Converter={StaticResource LocalPathToBitmapImageConverter}, TargetNullValue={x:Null}, FallbackValue={x:Null}}" />
                                                        </Border>
                                                    </Image.ToolTip>
                                                </Image>
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           Text="Nessuna immagine">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasImage}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource LookupLabelStyle}"
                                           Text="Descrizione lunga" />
                                <Border Margin="0,6,0,0"
                                        Style="{StaticResource LookupValueBoxStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <RichTextBox x:Name="LongDescriptionRichTextBox"
                                                     Height="{Binding DescriptionViewportHeight}"
                                                     IsReadOnly="True"
                                                     IsReadOnlyCaretVisible="False"
                                                     IsDocumentEnabled="True"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Padding="0"
                                                     VerticalScrollBarVisibility="Auto" />
                                        <DockPanel Grid.Row="1"
                                                   Margin="0,8,0,0"
                                                   LastChildFill="False">
                                            <Button DockPanel.Dock="Right"
                                                    Content="{Binding ToggleDescriptionButtonText}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="10,4"
                                                    Command="{Binding ToggleDescriptionCommand}" />
                                        </DockPanel>
                                    </Grid>
                                </Border>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LookupLabelStyle}"
                                                   Text="Prezzo vendita" />
                                        <Border Margin="0,6,0,0"
                                                Style="{StaticResource LookupValueBoxStyle}">
                                            <TextBlock FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="#1E7A49"
                                                       Text="{Binding SelectedDetail.PrezzoVendita, StringFormat={}{0:N2} €}" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LookupLabelStyle}"
                                                   Text="Data ultima vendita" />
                                        <Border Margin="0,6,0,0"
                                                Style="{StaticResource LookupValueBoxStyle}">
                                            <TextBlock FontSize="13.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding LastSaleDateLabel}" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Style="{StaticResource LookupLabelStyle}"
                                                   Text="Accisa" />
                                        <Border Margin="0,6,0,0"
                                                Style="{StaticResource LookupValueBoxStyle}">
                                            <TextBlock FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding SelectedDetail.ExciseLabel}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,12,0,0"
                                            Visibility="{Binding HasBrand, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource LookupLabelStyle}"
                                               Text="Marca" />
                                    <Border Margin="0,6,0,0"
                                            Style="{StaticResource LookupValueBoxStyle}">
                                        <TextBlock FontSize="13.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding SelectedDetail.Brand}" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Margin="0,12,0,0"
                                            Visibility="{Binding HasSpecifications, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource LookupLabelStyle}"
                                               Text="Specifiche legacy" />
                                    <Border Margin="0,6,0,0"
                                            Style="{StaticResource LookupValueBoxStyle}">
                                        <ItemsControl ItemsSource="{Binding SelectedDetail.Specifications}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="190" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="11.5"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   Text="{Binding Name}" />
                                                        <TextBlock Grid.Column="1"
                                                                   FontSize="12.5"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   Text="{Binding Value}"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                            </Border>
                                </StackPanel>

                                <StackPanel Margin="0,12,0,0"
                                            Visibility="{Binding HasTags, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource LookupLabelStyle}"
                                               Text="Tag" />
                                    <Border Margin="0,6,0,0"
                                            Style="{StaticResource LookupValueBoxStyle}">
                                        <ItemsControl ItemsSource="{Binding SelectedDetail.Tags}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,8,8"
                                                            Padding="9,4"
                                                            Background="#FFF1F6FC"
                                                            BorderBrush="#D9E5F2"
                                                            BorderThickness="1"
                                                            CornerRadius="10">
                                                        <TextBlock FontSize="11.5"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Text="{Binding}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Chiudi"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="110"
                            Margin="0,0,10,0"
                            Click="CloseButton_OnClick" />
                    <Button Content="Aggiungi articolo"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="150"
                            IsDefault="True"
                            Click="ConfirmButton_OnClick" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
