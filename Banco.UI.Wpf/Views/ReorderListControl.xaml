<UserControl x:Class="Banco.UI.Wpf.Views.ReorderListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <ContextMenu x:Key="ReorderColumnsMenu"
                     Opened="ColumnsMenu_OnOpened" />

        <Style x:Key="ReorderRowStyle"
               TargetType="DataGridRow"
               BasedOn="{StaticResource CompactDataGridRowStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsOrdered}" Value="True">
                    <Setter Property="Background" Value="#FFEAF6EB" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReorderHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource CompactDataGridHeaderStyle}">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBrush_Riordino}" />
            <Setter Property="Foreground" Value="{DynamicResource GridHeaderForegroundBrush_Riordino}" />
            <Setter Property="BorderThickness" Value="0,0,1,2" />
            <Setter Property="ContextMenu" Value="{StaticResource ReorderColumnsMenu}" />
        </Style>

        <Style x:Key="ReorderCellStyle"
               TargetType="DataGridCell"
               BasedOn="{StaticResource CompactDataGridCellStyle}" />

        <Style x:Key="LookupColumnHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource CompactDataGridHeaderStyle}">
            <Setter Property="Background" Value="#FFF4F8FD" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="SupplierDraftButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <GroupStyle x:Key="ReorderSupplierGroupStyle">
            <GroupStyle.ContainerStyle>
                <Style TargetType="GroupItem">
                    <Setter Property="Margin" Value="0,0,0,6" />
                </Style>
            </GroupStyle.ContainerStyle>
            <GroupStyle.HeaderTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,3"
                            Padding="8,5"
                            Background="#FFF3F7FC"
                            BorderBrush="#FFD7E3F0"
                            BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="False">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FF25476F"
                                       Text="{Binding Name}" />
                            <Border DockPanel.Dock="Right"
                                    Margin="10,0,0,0"
                                    Padding="7,1"
                                    Background="#FFE3EEF9"
                                    CornerRadius="9">
                                <TextBlock FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="#FF41658C"
                                           Text="{Binding ItemCount, StringFormat={}{0} righe}" />
                            </Border>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </GroupStyle.HeaderTemplate>
        </GroupStyle>
    </UserControl.Resources>

    <Border Style="{StaticResource CompactCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding ListTitle}" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="{Binding StatusMessage}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Aggiorna"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource CompactSecondaryButtonStyle}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,8,0,0"
                    Padding="10"
                    Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrushBase}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="AGGIUNGI ARTICOLO" />
                        <TextBox x:Name="ArticleSearchTextBox"
                                 Grid.Column="1"
                                 Width="320"
                                 Margin="8,0,0,0"
                                 Text="{Binding SearchArticleText, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="ArticleSearchTextBox_OnPreviewKeyDown"
                                 Style="{StaticResource CompactTextBoxStyle}" />
                        <Popup IsOpen="{Binding IsArticlePopupOpen}"
                               PlacementTarget="{Binding ElementName=ArticleSearchTextBox}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="None">
                            <Border Width="540"
                                    Background="#FFFFFFFF"
                                    BorderBrush="{StaticResource BorderBrushBase}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="4"
                                    Effect="{StaticResource SubtleShadow}">
                                <DataGrid x:Name="ArticleLookupGrid"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          PreviewKeyDown="ArticleLookupGrid_OnKeyDown"
                                          MouseDoubleClick="ArticleLookupGrid_OnMouseDoubleClick"
                                          ItemsSource="{Binding ArticleLookupResults}"
                                          SelectedItem="{Binding SelectedArticleLookup, Mode=OneWay}"
                                          Background="#FFFBFDFF"
                                          HorizontalGridLinesBrush="#FFE4EBF3"
                                          BorderThickness="0"
                                          AlternationCount="2"
                                          MaxHeight="220"
                                          RowStyle="{StaticResource CompactDataGridRowStyle}"
                                          ColumnHeaderStyle="{StaticResource LookupColumnHeaderStyle}"
                                          CellStyle="{StaticResource CompactDataGridCellStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Articolo"
                                                            Binding="{Binding DisplayLabel}"
                                                            Width="*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Giac."
                                                            Binding="{Binding Giacenza, StringFormat={}{0:N2}}"
                                                            Width="90" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Popup>
                        <Button Grid.Column="2"
                                Content="Aggiungi"
                                Width="92"
                                Margin="8,0,0,0"
                                Command="{Binding AddManualArticleCommand}"
                                Style="{StaticResource CompactPrimaryButtonStyle}" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <WrapPanel VerticalAlignment="Center">
                            <ToggleButton Content="Da confermare"
                                          Command="{Binding ShowOpenOnlyCommand}"
                                          IsChecked="{Binding IsOpenOnlyFilterSelected, Mode=OneWay}"
                                          Style="{StaticResource CompactToolbarToggleButtonStyle}" />
                            <ToggleButton Content="Tutte"
                                          Command="{Binding ShowAllCommand}"
                                          IsChecked="{Binding IsAllFilterSelected, Mode=OneWay}"
                                          Style="{StaticResource CompactToolbarToggleButtonStyle}" />
                            <ToggleButton Content="Confermate"
                                          Command="{Binding ShowOrderedOnlyCommand}"
                                          IsChecked="{Binding IsOrderedOnlyFilterSelected, Mode=OneWay}"
                                          Style="{StaticResource CompactToolbarToggleButtonStyle}" />
                            <Button Content="{Binding GroupingButtonLabel}"
                                    Command="{Binding ToggleSupplierGroupingCommand}"
                                    MinWidth="150"
                                    Margin="8,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource CompactSecondaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGroupedBySupplier}" Value="True">
                                                <Setter Property="Background" Value="#FFEBF1FA" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </WrapPanel>

                        <WrapPanel Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center">
                            <Button Content="Conferma selezionate"
                                    Command="{Binding MarkOrderedCommand}"
                                    Style="{StaticResource CompactPrimaryButtonStyle}" />
                            <Button Content="Riapri"
                                    Command="{Binding MarkPendingCommand}"
                                    Style="{StaticResource CompactSecondaryButtonStyle}" />
                            <Button Content="Modifica q.ta"
                                    Click="EditSelectedRowButton_OnClick"
                                    IsEnabled="{Binding CanEditSelectedRow}"
                                    Style="{StaticResource CompactSecondaryButtonStyle}" />
                            <Button Content="Rimuovi"
                                    Command="{Binding RemoveCommand}"
                                    IsEnabled="{Binding CanRemoveSelectedRows}"
                                    Style="{StaticResource CompactSecondaryButtonStyle}" />
                        </WrapPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,8,0,0"
                    Padding="10"
                    Background="#FFF8FBFF"
                    BorderBrush="#FFD6E3F1"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding HasSupplierDrafts, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="Liste fornitore" />
                            <Border DockPanel.Dock="Right"
                                    Padding="7,1"
                                    Background="#FFE3EEF9"
                                    CornerRadius="9">
                                <TextBlock FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="#FF41658C"
                                           Text="{Binding SupplierDraftCount, StringFormat={}{0} liste}" />
                            </Border>
                        </DockPanel>

                        <ScrollViewer Margin="0,8,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="164">
                            <ItemsControl ItemsSource="{Binding SupplierDrafts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource SupplierDraftButtonStyle}"
                                                Command="{Binding DataContext.SelectSupplierDraftCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Border Padding="8"
                                                    Background="#FFFFFFFF"
                                                    BorderBrush="#FFD8E2ED"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#FF26476F"
                                                                   Text="{Binding SupplierName}" />
                                                        <Border DockPanel.Dock="Right"
                                                                Padding="7,1"
                                                                Background="#FFF0F5FB"
                                                                CornerRadius="8">
                                                            <TextBlock FontSize="10.5"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FF58708C"
                                                                       Text="{Binding CounterLabel}" />
                                                        </Border>
                                                    </DockPanel>
                                                    <DockPanel Grid.Row="1"
                                                               Margin="0,4,0,0"
                                                               LastChildFill="False">
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Text="{Binding DateLabel}" />
                                                        <Border DockPanel.Dock="Right"
                                                                Padding="7,1"
                                                                Background="#FFE9F3EA"
                                                                CornerRadius="8">
                                                            <TextBlock FontSize="10.5"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FF3D6C45"
                                                                       Text="{Binding StatusLabel}" />
                                                        </Border>
                                                    </DockPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Background="#FFFFFFFF"
                            BorderBrush="#FFD8E2ED"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Visibility="{Binding HasSelectedSupplierDraft, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding SupplierDraftDetailTitle}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding SupplierDraftDetailStatus}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding SelectedSupplierDraft.FmDocumentLabel, StringFormat=Documento FM: {0}}" />
                                </StackPanel>

                                <WrapPanel Grid.Column="1"
                                           HorizontalAlignment="Right">
                                    <Button Content="Elimina lista"
                                            Click="RemoveSupplierDraftButton_OnClick"
                                            Style="{StaticResource CompactSecondaryButtonStyle}" />
                                    <Button Content="Ordine fatto"
                                            Command="{Binding MarkSupplierOrderDoneCommand}"
                                            Style="{StaticResource CompactSecondaryButtonStyle}" />
                                    <Button Content="Crea ordine su FM"
                                            Command="{Binding MarkSupplierOrderCreatedOnFmCommand}"
                                            Style="{StaticResource CompactSecondaryButtonStyle}" />
                                    <Button Content="Chiudi"
                                            Command="{Binding CloseSupplierOrderCommand}"
                                            Style="{StaticResource CompactSecondaryButtonStyle}" />
                                </WrapPanel>
                            </Grid>

                            <Border Grid.Row="1"
                                    Margin="0,8,0,8"
                                    Height="1"
                                    Background="{StaticResource HairlineBrush}" />

                            <ItemsControl Grid.Row="2"
                                          ItemsSource="{Binding SelectedSupplierDraft.Rows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,5"
                                                BorderBrush="#FFE5ECF4"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="84" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="70" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="{Binding CodiceArticolo}" />
                                                <TextBlock Grid.Column="1"
                                                           Margin="8,0,0,0"
                                                           Text="{Binding Descrizione}" />
                                                <TextBlock Grid.Column="2"
                                                           HorizontalAlignment="Right"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding QuantitaDaOrdinare, StringFormat={}{0:N2}}" />
                                                <TextBlock Grid.Column="3"
                                                           Margin="8,0,0,0"
                                                           Text="{Binding UnitaMisura}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Grid.Row="3"
                                       Margin="0,8,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="`Ordine fatto` conferma l'ordine sul sito fornitore. `Crea ordine su FM` crea davvero il documento ordine fornitore su FM e solo dopo abilita `Chiudi`." />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Margin="0,8,0,0"
                    BorderBrush="{StaticResource BorderBrushBase}"
                    BorderThickness="1"
                    CornerRadius="8,8,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="10,8,10,6"
                               LastChildFill="False">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="Righe di riordino" />
                            <TextBlock Margin="0,1,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Righe raccolte dal Banco o aggiunte manualmente." />
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              x:Name="ReorderGrid"
                              ItemsSource="{Binding ItemsView}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="True"
                              CanUserSortColumns="True"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              AlternationCount="2"
                              RowHeaderWidth="0"
                              PreviewMouseLeftButtonDown="ReorderGrid_OnPreviewMouseLeftButtonDown"
                              PreviewMouseRightButtonDown="ReorderGrid_OnPreviewMouseRightButtonDown"
                              PreviewKeyDown="ReorderGrid_OnPreviewKeyDown"
                              SelectionChanged="ReorderGrid_OnSelectionChanged"
                              CellEditEnding="ReorderGrid_OnCellEditEnding"
                              Background="Transparent"
                              BorderThickness="0"
                              RowStyle="{StaticResource ReorderRowStyle}"
                              ColumnHeaderStyle="{StaticResource ReorderHeaderStyle}"
                              CellStyle="{StaticResource ReorderCellStyle}">
                        <DataGrid.GroupStyle>
                            <StaticResource ResourceKey="ReorderSupplierGroupStyle" />
                        </DataGrid.GroupStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Conferma selezionati"
                                          Click="MarkOrderedMenuItem_OnClick" />
                                <MenuItem Header="Riapri selezionati"
                                          Click="MarkPendingMenuItem_OnClick" />
                                <Separator />
                                <MenuItem Header="Rimuovi dalla lista"
                                          Click="RemoveMenuItem_OnClick" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="OrdinatoColumn" Header="Stato" Binding="{Binding StatoLabel}" Width="108" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="CodiceColumn" Header="Codice" Binding="{Binding CodiceArticolo}" Width="86" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="DescrizioneColumn" Header="Descrizione" Binding="{Binding Descrizione}" Width="250" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="QuantitaColumn" Header="Qta`" Binding="{Binding Quantita, StringFormat={}{0:N2}}" Width="64" IsReadOnly="True" />
                            <DataGridTemplateColumn x:Name="QuantitaDaOrdinareColumn"
                                                    Header="Q.ta ord."
                                                    Width="96">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding QuantitaDaOrdinare, StringFormat={}{0:N2}}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding QuantitaDaOrdinare, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                 BorderThickness="0"
                                                 Padding="0"
                                                 VerticalContentAlignment="Center"
                                                 LostFocus="QuantityToOrderTextBox_OnLostFocus"
                                                 PreviewKeyDown="QuantityToOrderTextBox_OnPreviewKeyDown" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn x:Name="UnitaMisuraColumn" Header="U.M." Binding="{Binding UnitaMisura}" Width="60" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="FornitoreSuggeritoColumn" Header="Fornitore suggerito" Binding="{Binding FornitoreSuggerito}" Width="168" IsReadOnly="True" />
                            <DataGridTemplateColumn x:Name="FornitoreSelezionatoColumn" Header="Fornitore scelto" Width="210">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FornitoreSelezionatoLabel}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding SupplierOptions}"
                                                  SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                                                  SelectedValuePath="Oid"
                                                  IsDropDownOpen="True"
                                                  Style="{StaticResource CompactComboBoxStyle}"
                                                  Loaded="SupplierComboBox_OnLoaded"
                                                  SelectionChanged="SupplierComboBox_OnSelectionChanged">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayLabel}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn x:Name="PrezzoColumn" Header="Prezzo" Binding="{Binding PrezzoSuggerito, StringFormat={}{0:N2}}" Width="82" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="MotivoColumn" Header="Motivo" Binding="{Binding Motivo}" Width="112" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="OperatoreColumn" Header="Operatore" Binding="{Binding Operatore}" Width="112" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="DataColumn" Header="Data" Binding="{Binding DataInserimento, StringFormat={}{0:dd/MM/yyyy}}" Width="100" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="NoteColumn" Header="Note" Binding="{Binding Note}" Width="170" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Padding="8,6"
                    Background="#FFE3EBF6"
                    CornerRadius="0,0,8,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="{Binding SummaryLabel}" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding SelectedFilterLabel}" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="{Binding ListState}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
