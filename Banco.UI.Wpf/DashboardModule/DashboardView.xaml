<UserControl x:Class="Banco.UI.Wpf.DashboardModule.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Banco.UI.Wpf.DashboardModule"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1440">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ShellWorkspaceChromeBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShellWorkspaceChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="DashboardWidgetTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="DashboardWidgetRemoveButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="{DynamicResource WindowBackgroundBrush}">
        <Grid Margin="18,14,18,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource DashboardCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="Dashboard Banco" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Cruscotto operativo con riepiloghi, pagamenti, avvisi e ultimi documenti." />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Text="{Binding LastUpdatedDisplay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,0"
                                Command="{Binding OpenBancoCommand}"
                                Content="Apri Banco" />
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,0"
                                Command="{Binding OpenDocumentsCommand}"
                                Content="Documenti" />
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,0"
                                Command="{Binding OpenReorderCommand}"
                                Content="Lista ordini" />
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding RefreshCommand}"
                                Content="Aggiorna" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource DashboardCardStyle}"
                            Visibility="{Binding ShowSummaryWidget, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource DashboardWidgetTitleStyle}"
                                           Text="Vendite sintetiche" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource DashboardWidgetRemoveButtonStyle}"
                                        Command="{Binding HideSummaryWidgetCommand}"
                                        Content="×" />
                            </Grid>

                            <UniformGrid Grid.Row="1"
                                         Margin="0,14,0,0"
                                         Columns="4">
                                <Border Margin="0,0,10,0"
                                        Padding="14"
                                        CornerRadius="12"
                                        Background="{DynamicResource BancoMetricSurfaceBrush}"
                                        BorderBrush="{DynamicResource BancoMetricBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Text="Venduto oggi" />
                                        <TextBlock Margin="0,6,0,0"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Text="{Binding SalesTodayDisplay}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,10,0"
                                        Padding="14"
                                        CornerRadius="12"
                                        Background="{DynamicResource BancoMetricSurfaceBrush}"
                                        BorderBrush="{DynamicResource BancoMetricBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Text="Venduto ieri" />
                                        <TextBlock Margin="0,6,0,0"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Text="{Binding SalesYesterdayDisplay}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,10,0"
                                        Padding="14"
                                        CornerRadius="12"
                                        Background="{DynamicResource BancoMetricSurfaceBrush}"
                                        BorderBrush="{DynamicResource BancoMetricBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Text="Ultimi 7 giorni" />
                                        <TextBlock Margin="0,6,0,0"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Text="{Binding SalesWeekDisplay}" />
                                    </StackPanel>
                                </Border>
                                <Border Padding="14"
                                        CornerRadius="12"
                                        Background="{DynamicResource BancoMetricSurfaceBrush}"
                                        BorderBrush="{DynamicResource BancoMetricBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Text="Documenti / riordino" />
                                        <TextBlock Margin="0,6,0,0"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Text="{Binding DocumentsTodayDisplay}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding ReorderItemsDisplay}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DashboardCardStyle}"
                            Visibility="{Binding ShowPaymentsWidget, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource DashboardWidgetTitleStyle}"
                                               Text="Mix pagamenti ultimi 7 giorni" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Text="{Binding PaymentsWeekDisplay}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource DashboardWidgetRemoveButtonStyle}"
                                        Command="{Binding HidePaymentsWidgetCommand}"
                                        Content="×" />
                            </Grid>

                            <ItemsControl Grid.Row="1"
                                          Margin="0,14,0,0"
                                          ItemsSource="{Binding PaymentBreakdown}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:DashboardPaymentBreakdownItemViewModel}">
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="100" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                       Text="{Binding Label}" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="12,0,12,0"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding AmountDisplay}" />
                                            <ProgressBar Grid.Column="2"
                                                         Height="10"
                                                         VerticalAlignment="Center"
                                                         Maximum="100"
                                                         Value="{Binding Percentage}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource DashboardCardStyle}"
                            Visibility="{Binding ShowAlertsWidget, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource DashboardWidgetTitleStyle}"
                                           Text="Avvisi operativi" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource DashboardWidgetRemoveButtonStyle}"
                                        Command="{Binding HideAlertsWidgetCommand}"
                                        Content="×" />
                            </Grid>

                            <ItemsControl Grid.Row="1"
                                          Margin="0,14,0,0"
                                          ItemsSource="{Binding Alerts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:DashboardAlertItemViewModel}">
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                CornerRadius="12"
                                                Background="{DynamicResource SurfaceAltBrush}"
                                                BorderBrush="{DynamicResource BorderBrushBase}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding Title}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding Description}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DashboardCardStyle}"
                            Visibility="{Binding ShowRecentDocumentsWidget, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource DashboardWidgetTitleStyle}"
                                           Text="Ultime vendite Banco" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource DashboardWidgetRemoveButtonStyle}"
                                        Command="{Binding HideRecentDocumentsWidgetCommand}"
                                        Content="×" />
                            </Grid>

                            <ItemsControl Grid.Row="1"
                                          Margin="0,14,0,0"
                                          ItemsSource="{Binding RecentDocuments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:DashboardRecentDocumentItemViewModel}">
                                        <Button Margin="0,0,0,10"
                                                Padding="12"
                                                Command="{Binding OpenCommand}"
                                                HorizontalContentAlignment="Stretch"
                                                Style="{StaticResource SecondaryButtonStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding NumeroDisplay}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               Text="{Binding DataDisplay}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Margin="16,0,0,0">
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding ClienteDisplay}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Text="{Binding PaymentDisplay}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2"
                                                           VerticalAlignment="Center"
                                                           FontWeight="Bold"
                                                           Text="{Binding TotaleDisplay}" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource DashboardCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource DashboardWidgetTitleStyle}"
                                   Text="Stato dashboard" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding StatusText}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RestoreWidgetsCommand}"
                            Content="Ripristina widget"
                            IsEnabled="{Binding AnyWidgetHidden}" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
