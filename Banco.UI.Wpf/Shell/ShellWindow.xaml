<Window x:Class="Banco.UI.Wpf.Shell.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:Banco.UI.Wpf.Converters"
        xmlns:sidebarConv="clr-namespace:Banco.Sidebar.Converters;assembly=Banco.Sidebar"
        xmlns:desktop="clr-namespace:Banco.UI.Wpf.DesktopModule"
        xmlns:sidebar="clr-namespace:Banco.Sidebar.Views;assembly=Banco.Sidebar"
        xmlns:vm="clr-namespace:Banco.UI.Wpf.ViewModels"
        mc:Ignorable="d"
        Closing="ShellWindow_OnClosing"
        Title="{Binding TitoloApplicazione}"
        Height="920"
        Width="1480"
        MinHeight="760"
        MinWidth="1240"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <conv:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <sidebarConv:ResourceKeyToGeometryConverter x:Key="ResourceKeyToGeometryConverter" />

        <Style x:Key="ShellHeaderCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{DynamicResource ShellWorkspaceChromeBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShellWorkspaceChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="WorkspaceTabItemStyle" TargetType="TabItem">
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="{DynamicResource ShellWorkspaceTabBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShellWorkspaceTabBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinWidth" Value="136" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate DataType="{x:Type vm:ShellWorkspaceTabViewModel}">
                        <Grid MinWidth="22"
                              ClipToBounds="False"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Margin="0,0,4,0"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                       Text="{Binding DisplayTitle}" />
                            <Button Grid.Column="1"
                                    Click="WorkspaceTabCloseButton_OnClick"
                                    CommandParameter="{Binding}"
                                    Content="✕"
                                    Style="{DynamicResource TabCloseButtonStyle}"
                                    ToolTip="Chiudi scheda"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding CanClose}" />
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid ClipToBounds="False"
                              SnapsToDevicePixels="True">
                            <Border x:Name="TabBorder"
                                    Margin="0,0,0,0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10,10,8,8"
                                    Padding="0"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter ContentSource="Header"
                                                  Margin="16,8,14,10"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <Border x:Name="ActiveGlow"
                                    Width="26"
                                    Height="3"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,3"
                                    Background="Transparent"
                                    CornerRadius="3" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="2" />
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ShellWorkspaceSurfaceBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ShellAccentBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,1,1,0" />
                                <Setter TargetName="ActiveGlow" Property="Background" Value="{DynamicResource ShellAccentStrongBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ShellWorkspaceTabHoverBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ShellWorkspaceTabHoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="TabBorder" Property="Opacity" Value="0.96" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="5,2" />
            <Setter Property="Margin" Value="12,0,4,0" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseBorder" Property="Background" Value="{DynamicResource ShellContextCardHoverBrush}" />
                                <Setter TargetName="CloseBorder" Property="BorderBrush" Value="{DynamicResource ShellContextCardHoverBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseBorder" Property="Background" Value="{DynamicResource ShellContextCardActiveBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderBrandButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BrandBorder"
                                Background="Transparent"
                                CornerRadius="14"
                                Padding="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BrandBorder" Property="Background" Value="{DynamicResource ShellContextCardHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BrandBorder" Property="Background" Value="{DynamicResource ShellContextCardActiveBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShellWindowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShellWorkspaceChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ShellContextCardHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource ShellContextCardHoverBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ShellContextCardActiveBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushBase}"
                BorderThickness="0,0,0,1"
                Effect="{DynamicResource SubtleShadow}"
                MouseLeftButtonDown="HeaderChrome_OnMouseLeftButtonDown">
            <Grid Margin="20,14,20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Click="HeaderBrandButton_OnClick"
                        Style="{StaticResource HeaderBrandButtonStyle}"
                        ToolTip="Apri menu archivio">
                    <Button.ContextMenu>
                        <ContextMenu Style="{DynamicResource ThemedContextMenuStyle}"
                                     Placement="Bottom"
                                     HorizontalOffset="-8">
                            <MenuItem Click="ArchiveGeneralMenuItem_OnClick"
                                      Style="{DynamicResource ThemedContextMenuItemStyle}">
                                <MenuItem.Header>
                                    <Grid Width="240">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28"
                                                Height="28"
                                                CornerRadius="8"
                                                Background="{DynamicResource BancoAccentSoftBrush}">
                                            <Path Width="14"
                                                  Height="14"
                                                  Stretch="Uniform"
                                                  Fill="{DynamicResource BancoAccentSoftForegroundBrush}"
                                                  Data="{Binding Source=IconSettings, Converter={StaticResource ResourceKeyToGeometryConverter}}" />
                                        </Border>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Text="Impostazioni archivio" />
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="11.5"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="Generali, DB legacy e percorsi FM" />
                                        </StackPanel>
                                    </Grid>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="ArchiveBackupMenuItem_OnClick"
                                      Style="{DynamicResource ThemedContextMenuItemStyle}">
                                <MenuItem.Header>
                                    <Grid Width="240">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28"
                                                Height="28"
                                                CornerRadius="8"
                                                Background="{DynamicResource BancoAccentSoftBrush}">
                                            <Path Width="14"
                                                  Height="14"
                                                  Stretch="Uniform"
                                                  Fill="{DynamicResource BancoAccentSoftForegroundBrush}"
                                                  Data="{Binding Source=IconSaveAction, Converter={StaticResource ResourceKeyToGeometryConverter}}" />
                                        </Border>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Text="Configurazione backup" />
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="11.5"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="Default salvataggio archivio" />
                                        </StackPanel>
                                    </Grid>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="ArchiveRestoreMenuItem_OnClick"
                                      Style="{DynamicResource ThemedContextMenuItemStyle}">
                                <MenuItem.Header>
                                    <Grid Width="240">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28"
                                                Height="28"
                                                CornerRadius="8"
                                                Background="{DynamicResource BancoAccentSoftBrush}">
                                            <Path Width="14"
                                                  Height="14"
                                                  Stretch="Uniform"
                                                  Fill="{DynamicResource BancoAccentSoftForegroundBrush}"
                                                  Data="{Binding Source=IconDocOpen, Converter={StaticResource ResourceKeyToGeometryConverter}}" />
                                        </Border>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Text="Configurazione restore" />
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="11.5"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="Import e ripristino backup" />
                                        </StackPanel>
                                    </Grid>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="ArchiveSqliteMenuItem_OnClick"
                                      Style="{DynamicResource ThemedContextMenuItemStyle}">
                                <MenuItem.Header>
                                    <Grid Width="240">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28"
                                                Height="28"
                                                CornerRadius="8"
                                                Background="{DynamicResource BancoAccentSoftBrush}">
                                            <Path Width="14"
                                                  Height="14"
                                                  Stretch="Uniform"
                                                  Fill="{DynamicResource BancoAccentSoftForegroundBrush}"
                                                  Data="{Binding Source=IconDatabase, Converter={StaticResource ResourceKeyToGeometryConverter}}" />
                                        </Border>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Text="SQLite locale" />
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="11.5"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="Supporto tecnico e audit locale" />
                                        </StackPanel>
                                    </Grid>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="ArchiveAiMenuItem_OnClick"
                                      Style="{DynamicResource ThemedContextMenuItemStyle}">
                                <MenuItem.Header>
                                    <Grid Width="240">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28"
                                                Height="28"
                                                CornerRadius="8"
                                                Background="{DynamicResource BancoAccentSoftBrush}">
                                            <Path Width="14"
                                                  Height="14"
                                                  Stretch="Uniform"
                                                  Fill="{DynamicResource BancoAccentSoftForegroundBrush}"
                                                  Data="{Binding Source=IconAi, Converter={StaticResource ResourceKeyToGeometryConverter}}" />
                                        </Border>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Text="Impostazioni AI" />
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="11.5"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="API, modello e supporto SQLite" />
                                        </StackPanel>
                                    </Grid>
                                </MenuItem.Header>
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="56"
                                Height="56"
                                CornerRadius="14"
                                Background="{DynamicResource ShellWorkspaceChromeBrush}"
                                BorderBrush="{DynamicResource ShellWorkspaceChromeBorderBrush}"
                                BorderThickness="1"
                                Effect="{DynamicResource SubtleShadow}"
                                VerticalAlignment="Center">
                            <Image Source="/Immagini/Banco-64.png"
                                   Width="48"
                                   Height="48"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="Banco Workspace" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Text="{Binding TitoloApplicazione}" />
                        </StackPanel>
                    </Grid>
                </Button>

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Style="{StaticResource ShellHeaderCardStyle}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Margin="0,0,8,0"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"
                                       Text="Operatore" />
                            <ComboBox Width="150"
                                      Style="{StaticResource CompactComboBoxStyle}"
                                      ItemsSource="{Binding CurrentBancoViewModel.OperatoriDisponibili}"
                                      SelectedItem="{Binding CurrentBancoViewModel.OperatoreSelezionato, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayLabel"
                                      VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border VerticalAlignment="Center"
                            Style="{StaticResource ShellHeaderCardStyle}"
                            Effect="{DynamicResource SubtleShadow}"
                            Margin="0,0,10,0">
                        <TextBlock FontSize="15"
                                   FontWeight="Bold"
                                   Text="{Binding Versione}" />
                    </Border>

                    <Button Style="{StaticResource ShellWindowButtonStyle}"
                            Click="MinimizeWindowButton_OnClick"
                            ToolTip="Riduci a icona">
                        <Path Width="12"
                              Height="12"
                              Stretch="Uniform"
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                              Data="{StaticResource IconMinimize}" />
                    </Button>

                    <Button Style="{StaticResource ShellWindowButtonStyle}"
                            Click="ToggleWindowStateButton_OnClick"
                            ToolTip="Ridimensiona o massimizza">
                        <Path Width="12"
                              Height="12"
                              Stretch="Uniform"
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                              Data="{StaticResource IconMaximize}" />
                    </Button>

                    <Button Style="{StaticResource ShellWindowButtonStyle}"
                            Click="CloseWindowButton_OnClick"
                            ToolTip="Chiudi">
                        <Path Width="12"
                              Height="12"
                              Stretch="Uniform"
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                              Data="{StaticResource IconClose}" />
                    </Button>
                </StackPanel>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        Margin="0,12,0,0"
                        Background="{DynamicResource ShellWorkspaceFrameBrush}"
                        BorderBrush="{DynamicResource ShellWorkspaceFrameBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8,8,0,0"
                        Padding="14,10,14,6"
                        Effect="{DynamicResource SubtleShadow}"
                        Visibility="{Binding HasOpenTabs, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TabControl x:Name="WorkspaceTabs"
                                Margin="0,0,0,1"
                                ItemsSource="{Binding OpenTabs}"
                                SelectedItem="{Binding ActiveTab, Mode=TwoWay}"
                                SelectionChanged="WorkspaceTabs_OnSelectionChanged"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                ClipToBounds="False"
                                SnapsToDevicePixels="True"
                                ItemContainerStyle="{StaticResource WorkspaceTabItemStyle}">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <Grid SnapsToDevicePixels="True"
                                      ClipToBounds="False">
                                    <TabPanel IsItemsHost="True"
                                              Margin="14,0,10,0"
                                              ClipToBounds="False"
                                              KeyboardNavigation.TabIndex="1" />
                                    <Border Height="1"
                                            VerticalAlignment="Bottom"
                                            Background="{DynamicResource ShellWorkspaceFrameBorderBrush}"
                                            IsHitTestVisible="False" />
                                </Grid>
                            </ControlTemplate>
                        </TabControl.Template>
                    </TabControl>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarRailWidth, Converter={StaticResource DoubleToGridLengthConverter}}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <sidebar:SidebarRailControl Grid.Column="0"
                                       x:Name="SidebarRailHost"
                                       DataContext="{Binding Sidebar}"
                                       MouseEnter="SidebarHoverHost_OnMouseEnter"
                                       MouseLeave="SidebarHoverHost_OnMouseLeave" />

            <Border Grid.Column="1"
                    Background="{DynamicResource WindowBackgroundBrush}">
                <Border Margin="16,6,18,0"
                        Background="{DynamicResource ShellWorkspaceSurfaceBrush}"
                        BorderBrush="{DynamicResource ShellWorkspaceFrameBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Effect="{DynamicResource SubtleShadow}">
                    <Grid Margin="8">
                        <ContentControl Content="{Binding ActiveTab.Content}"
                                        Visibility="{Binding HasOpenTabs, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <desktop:DesktopHomeView DataContext="{Binding DesktopHomeViewModel}"
                                                 Visibility="{Binding DataContext.IsDesktopHomeVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </Border>
            </Border>

            <Border Grid.ColumnSpan="2"
                    Panel.ZIndex="20"
                    Margin="164,0,0,0"
                    Width="{Binding SidebarContextPanelWidth}"
                    MaxHeight="680"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Visibility="{Binding Sidebar.IsContextPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="Transparent"
                    MouseEnter="SidebarHoverHost_OnMouseEnter"
                    MouseLeave="SidebarHoverHost_OnMouseLeave">
                <Border.RenderTransform>
                    <TranslateTransform Y="{Binding Sidebar.ContextPanelVerticalOffset}" />
                </Border.RenderTransform>
                <sidebar:SidebarContextPanelControl x:Name="SidebarContextOverlayHost"
                                                   DataContext="{Binding Sidebar}" />
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushBase}"
                BorderThickness="0,1,0,0"
                Visibility="Collapsed" />
    </Grid>
</Window>
