<UserControl x:Class="Banco.UI.Wpf.ArchiveSettingsModule.AiSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}"
                Background="{StaticResource WindowBackgroundBrush}">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Assistente AI" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="12.5"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Configurazione tecnica locale per le funzioni AI future della vendita Banco." />

                <CheckBox Margin="0,16,0,0"
                          Content="Abilita funzioni AI"
                          IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" />

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Provider" />
                        <TextBox Text="{Binding Provider, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource CompactTextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Modello" />
                        <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource CompactTextBoxStyle}" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Endpoint API DeepSeek" />
                        <TextBox Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource CompactTextBoxStyle}" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            Margin="0,20,0,0"
                            Content="Usa DeepSeek V4"
                            Command="{Binding UseDeepSeekCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>

                <TextBlock Margin="0,14,0,0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="API key" />
                <PasswordBox x:Name="ApiKeyPasswordBox"
                             Height="30"
                             Padding="9,4"
                             PasswordChar="*"
                             PasswordChanged="ApiKeyPasswordBox_OnPasswordChanged" />

                <TextBlock Margin="0,14,0,0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Note operative" />
                <TextBox MinHeight="74"
                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Style="{StaticResource CompactTextBoxStyle}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Background="{StaticResource WindowBackgroundBrush}">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Persistenza" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="12.5"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Questi dati vivono nel database SQLite tecnico locale e non modificano il legacy db_diltech." />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4">
            <WrapPanel>
                <Button Content="Salva impostazioni AI"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Content="Ricarica da SQLite"
                        Command="{Binding ReloadCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </WrapPanel>

            <TextBlock Margin="0,12,0,0"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="{Binding StatusMessage}" />
        </StackPanel>
    </Grid>
</UserControl>
