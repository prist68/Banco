<UserControl x:Class="Banco.UI.Wpf.ArchiveSettingsModule.ArchiveGeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}"
                    Background="{StaticResource WindowBackgroundBrush}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="DB gestionale" />

                    <TextBlock Margin="0,16,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Host" />
                    <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Lascia vuoto per usare il DB locale del server. Sulle postazioni client indica l'IP reale del server." />

                    <TextBlock Margin="0,12,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Porta" />
                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}" />

                    <TextBlock Margin="0,12,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Database" />
                    <TextBox Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}" />

                    <TextBlock Margin="0,12,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Utente" />
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}" />

                    <TextBlock Margin="0,12,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Password" />
                    <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}"
                    Background="{StaticResource WindowBackgroundBrush}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Percorsi FM" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="12.5"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Radice contenuti legacy e cartella immagini articoli usate dal Banco." />

                    <TextBlock Margin="0,16,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Radice contenuti FM" />
                    <TextBox Text="{Binding FmRootDirectory, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}" />

                    <TextBlock Margin="0,12,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Cartella immagini articoli" />
                    <TextBox Text="{Binding FmArticleImagesDirectory, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}" />

                    <Border Margin="0,16,0,0"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushBase}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel>
                            <TextBlock FontSize="12.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Percorso effettivo immagini articoli" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="13"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding FmArticleImagesResolvedPath}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Background="{StaticResource WindowBackgroundBrush}">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Dati archivio" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="12.5"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Qui convergono i parametri base dell'archivio operativo: connessione legacy e contenuti FM." />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4">
            <WrapPanel>
                <Button Content="Salva impostazioni"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Content="Test connessione"
                        Command="{Binding TestConnectionCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </WrapPanel>

            <TextBlock Margin="0,12,0,0"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="{Binding StatusMessage}" />
        </StackPanel>
    </Grid>
</UserControl>
