<UserControl x:Class="Banco.UI.Wpf.ArchiveSettingsModule.BackupConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False"
             FocusVisualStyle="{x:Null}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True">
            <Grid Margin="0,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="0.78*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardStyle}"
                        Background="{StaticResource WindowBackgroundBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Salvataggio archivio" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="12.5"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Configurazione operativa del backup FM-like: cartella, commento e preferenze base." />

                            <TextBlock Margin="0,16,0,0"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Cartella backup predefinita" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="42" />
                                </Grid.ColumnDefinitions>

                                <TextBox Text="{Binding DefaultBackupDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CompactTextBoxStyle}" />
                                <Button Grid.Column="2"
                                        Width="42"
                                        Height="30"
                                        Padding="0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Click="SelectBackupDirectoryButton_OnClick"
                                        Style="{StaticResource SecondaryButtonStyle}">
                                    <Path Width="16"
                                          Height="16"
                                          Stretch="Uniform"
                                          Fill="{StaticResource TextPrimaryBrush}"
                                          Data="{StaticResource IconFolder}" />
                                </Button>
                            </Grid>

                            <TextBlock Margin="0,12,0,0"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Commento predefinito" />
                            <TextBox Text="{Binding DefaultComment, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CompactTextBoxStyle}" />

                            <CheckBox Margin="0,16,0,0"
                                      Content="Ricorda ultime impostazioni"
                                      IsChecked="{Binding RememberLastOptions}"
                                      Style="{StaticResource CompactCheckBoxStyle}" />

                            <CheckBox Margin="0,8,0,0"
                                      Content="Disattiva copia (non suggerire backup)"
                                      IsChecked="{Binding DisableBackupPrompt}"
                                      Style="{StaticResource CompactCheckBoxStyle}" />

                            <CheckBox Margin="0,8,0,0"
                                      Content="Copia differenziale con data nel nome archivio"
                                      IsChecked="{Binding UseDifferentialBackupNaming}"
                                      Style="{StaticResource CompactCheckBoxStyle}" />

                            <CheckBox Margin="0,8,0,0"
                                      Content="Backup admin limitato"
                                      IsChecked="{Binding RestrictAdminBackup}"
                                      Style="{StaticResource CompactCheckBoxStyle}" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>

                                <CheckBox VerticalAlignment="Center"
                                          Content="Elimina backup piu` vecchi"
                                          IsChecked="{Binding DeleteOldBackupsEnabled}"
                                          Style="{StaticResource CompactCheckBoxStyle}" />

                                <Grid Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Text="{Binding DeleteOldBackupsAfterDays, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactTextBoxStyle}" />
                                    <TextBlock Grid.Column="2"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="giorni" />
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Riepilogo salvataggio" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="Le impostazioni di questa pagina sono i default usati sia dal backup manuale sia dalla pianificazione." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource CardStyle}"
                        Background="{StaticResource WindowBackgroundBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Contenuti e controlli" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="12.5"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Elementi da proporre nel backup e controlli operativi FM-like." />

                            <Border Margin="0,16,0,0"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource BorderBrushBase}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12">
                                <StackPanel>
                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="Elementi da proporre" />

                                    <CheckBox Margin="0,12,0,0"
                                              Content="Archivio dati"
                                              IsChecked="{Binding IncludeDatabase}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                    <CheckBox Margin="0,8,0,0"
                                              Content="Allegati / Archidoc"
                                              IsChecked="{Binding IncludeAttachments}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                    <CheckBox Margin="0,8,0,0"
                                              Content="Immagini"
                                              IsChecked="{Binding IncludeImages}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                    <CheckBox Margin="0,8,0,0"
                                              Content="Layout elenchi"
                                              IsChecked="{Binding IncludeLayouts}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                    <CheckBox Margin="0,8,0,0"
                                              Content="Report"
                                              IsChecked="{Binding IncludeReports}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.ColumnSpan="3">
                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Text="Controlli operativi" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="11.5"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="Allinea Banco ai campi FM legati a suggerimento copia, ultima copia e computer abilitato." />
                                </StackPanel>

                                <StackPanel Grid.Row="2">
                                    <TextBlock FontSize="12.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="Giorni suggerimento copia" />
                                    <TextBox Margin="0,6,0,0"
                                             Text="{Binding BackupSuggestionDays, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="2">
                                    <TextBlock FontSize="12.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="Ultima copia" />
                                    <TextBox Margin="0,6,0,0"
                                             Text="{Binding LastBackupSummary, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource CompactTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="4"
                                            Grid.ColumnSpan="3">
                                    <TextBlock FontSize="12.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="Computer abilitato" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Text="{Binding EnabledComputerName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CompactTextBoxStyle}" />
                                        <Button Grid.Column="2"
                                                Content="Questo computer"
                                                Command="{Binding UseCurrentComputerCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Grid.Column="4"
                                                Content="Imposta adesso"
                                                Command="{Binding SetLastBackupNowCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource CardStyle}"
                        Background="{StaticResource WindowBackgroundBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Pianificazione Backup" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="12.5"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Ripeti backup per giorni e orari. Questo pannello ospita solo la programmazione." />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <StackPanel>
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Text="Ripeti backup giorni" />
                                <WrapPanel Margin="0,12,0,0"
                                           ItemWidth="46">
                                    <CheckBox Content="Lun"
                                              IsChecked="{Binding ScheduledOnMonday}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                    <CheckBox Content="Mar"
                                              IsChecked="{Binding ScheduledOnTuesday}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                    <CheckBox Content="Mer"
                                              IsChecked="{Binding ScheduledOnWednesday}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                    <CheckBox Content="Gio"
                                              IsChecked="{Binding ScheduledOnThursday}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                    <CheckBox Content="Ven"
                                              IsChecked="{Binding ScheduledOnFriday}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                    <CheckBox Content="Sab"
                                              IsChecked="{Binding ScheduledOnSaturday}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                    <CheckBox Content="Dom"
                                              IsChecked="{Binding ScheduledOnSunday}"
                                              Style="{StaticResource CompactCheckBoxStyle}" />
                                </WrapPanel>

                                <TextBlock Margin="0,12,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="{Binding ScheduledDaysSummary}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <StackPanel>
                                <CheckBox Content="Attiva backup programmato"
                                          IsChecked="{Binding ScheduledBackupEnabled}"
                                          Style="{StaticResource CompactCheckBoxStyle}" />

                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock FontSize="12.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="Orario prima esecuzione" />
                                        <TextBox Margin="0,6,0,0"
                                                 Text="{Binding ScheduledStartTime, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CompactTextBoxStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock FontSize="12.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="Quante volte al giorno" />
                                        <TextBox Margin="0,6,0,0"
                                                 Text="{Binding ScheduledRunsPerDay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CompactTextBoxStyle}" />
                                    </StackPanel>
                                </Grid>

                                <ItemsControl Margin="0,14,0,0"
                                              ItemsSource="{Binding AdditionalScheduledTimes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock FontSize="12.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="{Binding Label}" />
                                                <TextBox Margin="0,6,0,0"
                                                         Text="{Binding TimeText, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource CompactTextBoxStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock FontSize="12.5"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding StatusMessage}" />
                <StackPanel Margin="0,8,0,0"
                            Visibility="{Binding IsBackupInProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock FontSize="11.5"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="{Binding BackupProgressStage}" />
                    <ProgressBar Margin="0,6,0,0"
                                 Height="16"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding BackupProgressPercent, Mode=OneWay}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="11.5"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="{Binding BackupProgressDetail}" />
                </StackPanel>
            </StackPanel>

            <WrapPanel Grid.Column="1"
                       HorizontalAlignment="Right"
                       ItemHeight="38"
                       Orientation="Horizontal">
                <Button Margin="0,0,12,0"
                        MinWidth="160"
                        Content="Esegui Backup"
                        Command="{Binding ExecuteBackupCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button MinWidth="190"
                        Content="Salva Impostazioni"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </WrapPanel>
        </Grid>
    </Grid>
</UserControl>
