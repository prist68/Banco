<UserControl x:Class="Banco.UI.Wpf.ArchiveSettingsModule.RestoreConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}"
                Background="{StaticResource WindowBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Default restore" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="12.5"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Impostazioni base del ripristino archivio prima di avviare l'import reale del backup." />

                    <TextBlock Margin="0,16,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Cartella restore predefinita" />
                    <TextBox Text="{Binding DefaultRestoreDirectory, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}" />

                    <CheckBox Margin="0,14,0,0"
                              Content="Seleziona automaticamente l'ultimo backup"
                              IsChecked="{Binding AutoSelectLatestBackup}" />
                </StackPanel>

                <Border Grid.Column="2"
                        Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource BorderBrushBase}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14">
                    <TextBlock FontSize="12.5"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Il pannello sottostante usa il restore guidato già presente nel progetto. Qui fissiamo i default, sotto l'operatore esegue davvero l'import del backup selezionato." />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Height="0" />

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <WrapPanel>
                    <Button Content="Salva impostazioni restore"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </WrapPanel>

                <TextBlock Margin="0,12,0,0"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding StatusMessage}" />
            </StackPanel>

            <ContentControl Grid.Row="2"
                            Content="{Binding ImportTool}" />
        </Grid>
    </Grid>
</UserControl>
