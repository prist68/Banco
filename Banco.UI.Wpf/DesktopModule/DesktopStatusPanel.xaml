<UserControl x:Class="Banco.UI.Wpf.DesktopModule.DesktopStatusPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Banco.UI.Wpf.DesktopModule">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type local:DesktopStatusTileViewModel}">
            <Border MinHeight="70"
                    Margin="0,0,8,8"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource ShellWorkspaceChromeBrush}"
                    BorderBrush="{DynamicResource ShellWorkspaceChromeBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="11.5"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding Title}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="1"
                               Margin="0,4,0,2"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="{Binding Value}"
                               TextTrimming="CharacterEllipsis" />
                    <DockPanel Grid.Row="2">
                        <Border DockPanel.Dock="Right"
                                Padding="7,2"
                                CornerRadius="7"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{Binding AccentColor}"
                                BorderThickness="1">
                            <TextBlock FontSize="10.5"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding AccentColor}"
                                       Text="{Binding StateLabel}" />
                        </Border>
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding Detail}"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}"
            Background="{DynamicResource WindowBackgroundBrush}"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Text="Situazione oggi" />
            <ItemsControl Grid.Row="2"
                          ItemsSource="{Binding StatusTiles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>
