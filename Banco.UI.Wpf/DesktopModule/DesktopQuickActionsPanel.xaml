<UserControl x:Class="Banco.UI.Wpf.DesktopModule.DesktopQuickActionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Banco.UI.Wpf.DesktopModule">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type local:DesktopQuickActionViewModel}">
            <Button Height="58"
                    Margin="0,0,8,8"
                    Padding="10"
                    HorizontalContentAlignment="Stretch"
                    Background="{DynamicResource ShellWorkspaceChromeBrush}"
                    BorderBrush="{DynamicResource ShellWorkspaceChromeBorderBrush}"
                    BorderThickness="1"
                    Click="QuickAction_OnClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ShellContextCardHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource ShellContextCardHoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ShellContextCardActiveBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="30"
                            Height="30"
                            CornerRadius="8"
                            Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{Binding AccentColor}"
                            BorderThickness="1">
                        <Path Width="17"
                              Height="17"
                              Stretch="Uniform"
                              Fill="{Binding AccentColor}"
                              Data="{Binding IconData}" />
                    </Border>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="{Binding Title}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="11.5"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding Subtitle}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}"
            Background="{DynamicResource WindowBackgroundBrush}"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Text="Operativo rapido" />

            <ItemsControl Grid.Row="2"
                          ItemsSource="{Binding QuickActions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>
