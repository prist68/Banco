<UserControl x:Class="Banco.UI.Wpf.DesktopModule.DesktopHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Banco.UI.Wpf.DesktopModule"
             xmlns:sidebarVm="clr-namespace:Banco.Sidebar.ViewModels;assembly=Banco.Sidebar"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1400">
    <UserControl.Resources>
        <Style x:Key="DesktopCommandSearchTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="0,0,0,1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>

        <Style x:Key="DesktopCommandSearchResultButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ResultBorder"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ResultBorder" Property="Background" Value="{DynamicResource ShellContextCardHoverBrush}" />
                                <Setter TargetName="ResultBorder" Property="BorderBrush" Value="{DynamicResource ShellAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ResultBorder" Property="Background" Value="{DynamicResource ShellContextCardActiveBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource ShellDesktopBackdropBrush}"
          Margin="0,0,8,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}"
                Background="{DynamicResource WindowBackgroundBrush}"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="420" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="Scrivania Banco" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Azioni, stato operativo e segnalazioni modulari del gestionale."
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Grid Grid.Column="1"
                      x:Name="CommandSearchBoxHost"
                      Margin="16,0,10,0"
                      VerticalAlignment="Center">
                    <Border Height="30"
                            Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrushBase}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid Margin="10,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Path Width="13"
                                  Height="13"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Fill="{DynamicResource TextMutedBrush}"
                                  Data="{StaticResource IconSearch}" />
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DesktopCommandSearchTextBoxStyle}"
                                     ToolTip="Cerca comando"
                                     Text="{Binding DataContext.Sidebar.SearchText, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="1"
                                       Margin="2,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="12.5"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       IsHitTestVisible="False"
                                       Text="Cerca comando...">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.Sidebar.SearchText, RelativeSource={RelativeSource AncestorType=Window}}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Popup Placement="Bottom"
                           PlacementTarget="{Binding ElementName=CommandSearchBoxHost}"
                           DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                           AllowsTransparency="True"
                           StaysOpen="False"
                           IsOpen="{Binding Sidebar.HasSearchResults, Mode=OneWay}">
                        <Border Width="{Binding ActualWidth, ElementName=CommandSearchBoxHost}"
                                Margin="0,4,0,0"
                                Padding="6"
                                Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrushBase}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Effect="{DynamicResource SubtleShadow}">
                            <ItemsControl ItemsSource="{Binding Sidebar.SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type sidebarVm:SidebarSearchResultViewModel}">
                                        <Button Click="CommandSearchResultButton_OnClick"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource DesktopCommandSearchResultButtonStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock FontSize="12.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding Title}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Row="1"
                                                           Margin="0,1,0,0"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding Subtitle}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>
                </Grid>

                <Border Grid.Column="2"
                        Height="30"
                        Padding="10,0"
                        VerticalAlignment="Center"
                        CornerRadius="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrushBase}"
                        BorderThickness="1">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Modulare" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.55*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <local:DesktopQuickActionsPanel />

            <local:DesktopStatusPanel Grid.Row="2" />

            <Grid Grid.Column="2"
                  Grid.RowSpan="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.05*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="0.95*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <local:DesktopAlertsPanel />
                <local:DesktopRecentPanel Grid.Row="2" />

                <Grid Grid.Row="4"
                      x:Name="DesktopCanvas"
                      AllowDrop="True"
                      DragOver="DesktopCanvas_OnDragOver"
                      Drop="DesktopCanvas_OnDrop">
                    <local:DesktopCustomItemsPanel />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
