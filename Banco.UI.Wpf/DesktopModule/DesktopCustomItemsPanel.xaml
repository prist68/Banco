<UserControl x:Class="Banco.UI.Wpf.DesktopModule.DesktopCustomItemsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Banco.UI.Wpf.DesktopModule">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate DataType="{x:Type local:DesktopSurfaceItemViewModel}">
            <Button Height="30"
                    Margin="0,0,6,6"
                    Padding="9,0"
                    Background="{DynamicResource ShellWorkspaceChromeBrush}"
                    BorderBrush="{DynamicResource ShellWorkspaceChromeBorderBrush}"
                    BorderThickness="1"
                    Click="CustomItem_OnClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <Border Width="8"
                            Height="8"
                            Margin="0,0,7,0"
                            VerticalAlignment="Center"
                            CornerRadius="4"
                            Background="{Binding AccentColor}" />
                    <TextBlock VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="{Binding Title}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}"
            Background="{DynamicResource WindowBackgroundBrush}"
            Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="14"
                       FontWeight="SemiBold"
                       Text="Personalizzati" />

            <Grid Grid.Row="2">
                <ItemsControl ItemsSource="{Binding DesktopItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="Trascina funzioni dal pannello laterale per creare collegamenti personali. I blocchi operativi sopra restano separati."
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasItems}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</UserControl>
