        <SolidColorBrush x:Key="ContextMenuBorderBrush"          Color="#FFD6E1ED" />
        <SolidColorBrush x:Key="ContextMenuHoverBrush"           Color="#FFEBF3FF" />
        <SolidColorBrush x:Key="ContextMenuHoverBorderBrush"     Color="#FF9EBBE6" />
