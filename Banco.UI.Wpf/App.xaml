        <!-- Hover/Pressed brushes -->
        <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#FF4A83D6" />
        <SolidColorBrush x:Key="PrimaryButtonPressedBrush" Color="#FF234F87" />
        <SolidColorBrush x:Key="GreenButtonHoverBrush" Color="#FF85C657" />
        <SolidColorBrush x:Key="GreenButtonPressedBrush" Color="#FF3A7920" />
        <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#FFF0F4FA" />
        <SolidColorBrush x:Key="SecondaryButtonPressedBrush" Color="#FFE2E8F0" />
