        <SolidColorBrush x:Key="GrigliaSelezioneSfondoBrush"     Color="#183D73C6" />
        <SolidColorBrush x:Key="GrigliaSelezioneBordoBrush"      Color="#4D3D73C6" />
        <SolidColorBrush x:Key="GrigliaSelezioneForegroundBrush" Color="#FF1F3250" />
