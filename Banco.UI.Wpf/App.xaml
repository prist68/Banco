        <SolidColorBrush x:Key="UIDocumentDangerBorderBrush" Color="#FFF1C7C7" />
        <SolidColorBrush x:Key="UIDocumentDangerBackgroundBrush" Color="#FFFFF5F5" />
        <SolidColorBrush x:Key="UIDocumentSplitterBrush" Color="#FFD8E3F0" />
        <SolidColorBrush x:Key="UIDocumentCalendarPopupBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="UIDocumentCalendarPopupBorderBrush" Color="#FFDBE2ED" />
